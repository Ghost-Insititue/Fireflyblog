---
// 编辑器专用最小布局，不含网站 header/侧边栏/footer
interface Props {
  title?: string;
}
const { title = "写文章" } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} - Markdown 编辑器</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.9.0/build/styles/atom-one-dark.min.css" />
  <style is:global>
    /* 编辑器独立运行所需的 CSS 变量 */
    :root {
      --primary: #4f6ef7;
      --line-divider: rgba(0,0,0,0.08);
      --page-bg: #f8f9fa;
      --btn-regular-bg: rgba(0,0,0,0.05);
      --btn-content: rgba(0,0,0,0.7);
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --primary: #6b8aff;
        --line-divider: rgba(255,255,255,0.1);
        --page-bg: #1a1a1a;
        --btn-regular-bg: rgba(255,255,255,0.08);
        --btn-content: rgba(255,255,255,0.8);
      }
    }
    html, body { height: 100%; overflow: hidden; margin: 0; }
    body { background: var(--page-bg); font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
  </style>
</head>
<body>
  <slot />
</body>
</html>
