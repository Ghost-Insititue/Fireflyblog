---
import { siteConfig } from "@/config";
import "@/styles/main.css";
import "@/styles/variables.styl";

interface Props {
  title?: string;
  description?: string;
}

const { title = "写文章", description = "在线 Markdown 编辑器" } = Astro.props;

const configHue = siteConfig.themeColor.hue;
const defaultMode = siteConfig.themeColor.defaultMode ?? "light";
---

<!doctype html>
<html lang="zh-CN" class="h-full" data-wallpaper-mode="none">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - {siteConfig.title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon/favicon.ico" />

    <!-- 主题初始化（必须在页面渲染前执行） -->
    <script is:inline define:vars={{ configHue, defaultMode }}>
      (function () {
        var LIGHT_MODE = "light";
        var DARK_MODE = "dark";
        var SYSTEM_MODE = "system";

        var theme = localStorage.getItem("theme") || defaultMode;

        function getSystemTheme() {
          return window.matchMedia("(prefers-color-scheme: dark)").matches
            ? DARK_MODE
            : LIGHT_MODE;
        }

        function resolveTheme(t) {
          return t === SYSTEM_MODE ? getSystemTheme() : t;
        }

        var resolvedTheme = resolveTheme(theme);
        var isDark = resolvedTheme === DARK_MODE;

        if (isDark) {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }

        var hue = localStorage.getItem("hue") || configHue;
        document.documentElement.style.setProperty("--hue", hue);
      })();
    </script>
  </head>
  <body class="h-full bg-(--page-bg) text-[14px] md:text-[16px] overflow-hidden">
    <slot />
  </body>
</html>
