    function initGalleryUpload() {
      const modal = document.getElementById('gallery-upload-modal');
      const dropzone = document.getElementById('upload-dropzone');
      if (!modal || !dropzone) return;
      if (dropzone.dataset.bound) return;
      dropzone.dataset.bound = 'true';

      const fileInput = document.getElementById('upload-file-input');
      const fileList = document.getElementById('upload-file-list');
      const statusEl = document.getElementById('upload-status');
      const btnConfirm = document.getElementById('upload-confirm');
      const btnCancel = document.getElementById('upload-cancel');
      let selectedFiles = [];

      // 拖拽区域点击
      dropzone.addEventListener('click', () => fileInput.click());
      dropzone.addEventListener('dragover', (e) => { e.preventDefault(); dropzone.classList.add('border-[var(--primary)]'); });
      dropzone.addEventListener('dragleave', () => { dropzone.classList.remove('border-[var(--primary)]'); });
      dropzone.addEventListener('drop', (e) => {
        e.preventDefault();
        dropzone.classList.remove('border-[var(--primary)]');
        addFiles(e.dataTransfer.files);
      });
      fileInput.addEventListener('change', () => addFiles(fileInput.files));

      function addFiles(files) {
        for (const f of files) {
          if (!f.type.startsWith('image/')) continue;
          if (selectedFiles.some(s => s.name === f.name && s.size === f.size)) continue;
          selectedFiles.push(f);
        }
        renderFileList();
      }

      function renderFileList() {
        if (selectedFiles.length === 0) {
          fileList.classList.add('hidden');
          btnConfirm.disabled = true;
          return;
        }
        fileList.classList.remove('hidden');
        btnConfirm.disabled = false;
        fileList.innerHTML = selectedFiles.map((f, i) => `
          <div class="flex items-center gap-3 px-3 py-2 rounded-lg bg-black/5 dark:bg-white/5">
            <div class="w-10 h-10 rounded overflow-hidden flex-shrink-0 bg-black/10 dark:bg-white/10">
              <img src="${URL.createObjectURL(f)}" class="w-full h-full object-cover" />
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-sm truncate text-black/80 dark:text-white/80">${f.name}</div>
              <div class="text-xs text-black/40 dark:text-white/40">${(f.size / 1024).toFixed(1)} KB</div>
            </div>
            <button class="text-xs text-red-500 hover:text-red-700 cursor-pointer px-2 py-1 rounded hover:bg-red-50 dark:hover:bg-red-900/20" data-remove="${i}">移除</button>
          </div>
        `).join('');

        fileList.querySelectorAll('[data-remove]').forEach(btn => {
          btn.addEventListener('click', () => {
            selectedFiles.splice(parseInt(btn.dataset.remove), 1);
            renderFileList();
          });
        });
      }

      // 上传
      btnConfirm.addEventListener('click', async () => {
        if (selectedFiles.length === 0) return;

        const token = localStorage.getItem('gh-token') || localStorage.getItem('gh-editor-token');
        const repo = localStorage.getItem('gh-editor-repo') || 'Ghost-Insititue/Fireflyblog';

        if (!token) {
          showStatus('❌ 请先在编辑器页面配置 GitHub Token（点击「发布到 GitHub」设置）', 'error');
          return;
        }

        btnConfirm.disabled = true;
        btnConfirm.textContent = '上传中...';
        let success = 0;
        let failed = 0;

        for (let i = 0; i < selectedFiles.length; i++) {
          const file = selectedFiles[i];
          btnConfirm.textContent = `上传中 (${i + 1}/${selectedFiles.length})...`;
          showStatus(`⏳ 正在上传 ${file.name} (${i + 1}/${selectedFiles.length})...`, 'uploading');

          try {
            const ext = file.name.split('.').pop() || 'jpg';
            const ts = Date.now();
            const rand = Math.random().toString(36).substring(2, 6);
            const safeName = file.name.replace(/[^a-zA-Z0-9._\-\u4e00-\u9fff]/g, '_');
            const filename = `${ts}-${rand}-${safeName}`;
            const filePath = `public/gallery/${albumId}/${filename}`;

            const arrayBuffer = await file.arrayBuffer();
            const bytes = new Uint8Array(arrayBuffer);
            let binary = '';
            for (let j = 0; j < bytes.length; j++) binary += String.fromCharCode(bytes[j]);
            const base64 = btoa(binary);

            const res = await fetch(`https://api.github.com/repos/${repo}/contents/${filePath}`, {
              method: 'PUT',
              headers: {
                'Authorization': `token ${token}`,
                'Accept': 'application/vnd.github.v3+json',
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({
                message: `gallery: upload ${filename} to ${albumId}`,
                content: base64,
                branch: 'main',
              }),
            });

            if (res.ok) success++;
            else {
              const err = await res.json();
              console.error(`Upload failed: ${file.name}`, err);
              failed++;
            }
          } catch (e) {
            console.error(`Upload error: ${file.name}`, e);
            failed++;
          }
        }

        btnConfirm.textContent = '完成';
        showStatus(`✅ 上传完成：${success} 成功，${failed} 失败`, success > 0 ? 'success' : 'error');

        if (success > 0) {
          setTimeout(() => { window.location.reload(); }, 1500);
        }
      });

      function showStatus(msg, type) {
        statusEl.classList.remove('hidden');
        statusEl.className = 'text-sm mb-4 ' +
          (type === 'error' ? 'text-red-500' :
           type === 'success' ? 'text-green-500' :
           'text-blue-500');
        statusEl.textContent = msg;
      }
    }

    // ===== 编辑/删除相册 =====
    function initAlbumEdit() {
