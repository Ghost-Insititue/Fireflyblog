    function handleEditCoverFile(file) {
      var validTypes = ['image/jpeg', 'image/png', 'image/webp'];
      if (!validTypes.includes(file.type)) {
        showEditStatus('只支持 jpg/png/webp 格式', 'error');
        return;
      }
      if (file.size > 5 * 1024 * 1024) {
        showEditStatus('封面图不能超过 5MB', 'error');
        return;
      }

      var reader = new FileReader();
      reader.onload = function(e) {
        editCoverImg.src = e.target.result;
        editCoverName.textContent = file.name;
        editCoverPreview.classList.remove('hidden');
        editCoverPlaceholder.classList.add('hidden');
