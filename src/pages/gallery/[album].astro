    // 删除相册目录下的所有文件
    async function deleteAlbumDirectory(token, repo, albumId) {
      const dirPath = `public/gallery/${albumId}`;
      // 列出目录内容
      const listRes = await fetch(`https://api.github.com/repos/${repo}/contents/${dirPath}?ref=main`, {
        headers: { 'Authorization': `token ${token}`, 'Accept': 'application/vnd.github.v3+json' },
      });
      if (!listRes.ok) {
        // 目录不存在，跳过
        if (listRes.status === 404) return;
        throw new Error('读取相册目录失败');
      }
      const files = await listRes.json();
      if (!Array.isArray(files)) return;

      // 逐个删除文件
      for (const file of files) {
        const delRes = await fetch(`https://api.github.com/repos/${repo}/contents/${dirPath}/${file.name}`, {
          method: 'DELETE',
          headers: {
            'Authorization': `token ${token}`,
            'Accept': 'application/vnd.github.v3+json',
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            message: `gallery: delete ${file.name} from ${albumId}`,
            sha: file.sha,
            branch: 'main',
          }),
        });
        if (!delRes.ok) {
          console.error(`Failed to delete ${file.name}`);
        }
      }
    }

    // 修改 galleryConfig.ts 的通用函数
    async function modifyGalleryConfig(token, repo, action, data) {
      const configPath = 'src/config/galleryConfig.ts';
      const getRes = await fetch(`https://api.github.com/repos/${repo}/contents/${configPath}?ref=main`, {
        headers: { 'Authorization': `token ${token}`, 'Accept': 'application/vnd.github.v3+json' },
      });
      if (!getRes.ok) throw new Error('读取 galleryConfig.ts 失败');
      const fileData = await getRes.json();
      const currentContent = decodeURIComponent(escape(atob(fileData.content)));
      const sha = fileData.sha;

      const esc = (s) => s.replace(/\\/g, '\\\\').replace(/"/g, '\\"');
      let updatedContent;

      if (action === 'delete') {
        const idPattern = new RegExp(`\\tid:\\s*\\"${esc(data.oldId)}\\"`);
        const lines = currentContent.split('\n');
        let startIdx = -1, endIdx = -1, braceCount = 0;
        for (let i = 0; i < lines.length; i++) {
          if (idPattern.test(lines[i])) {
            for (let j = i; j >= 0; j--) {
              if (lines[j].includes('{')) { startIdx = j; break; }
            }
            braceCount = 0;
            for (let j = startIdx; j < lines.length; j++) {
              braceCount += (lines[j].match(/\{/g) || []).length;
              braceCount -= (lines[j].match(/\}/g) || []).length;
              if (braceCount === 0) { endIdx = j; break; }
            }
            break;
          }
        }
        if (startIdx === -1 || endIdx === -1) throw new Error(`未找到相册「${data.oldId}」`);
        lines.splice(startIdx, endIdx - startIdx + 1);
        updatedContent = lines.join('\n');
      } else if (action === 'edit') {
        const idPattern = new RegExp(`\\tid:\\s*\\"${esc(data.oldId)}\\"`);
        const lines = currentContent.split('\n');
        let startIdx = -1, endIdx = -1, braceCount = 0;
        for (let i = 0; i < lines.length; i++) {
          if (idPattern.test(lines[i])) {
            for (let j = i; j >= 0; j--) {
              if (lines[j].includes('{')) { startIdx = j; break; }
            }
            braceCount = 0;
            for (let j = startIdx; j < lines.length; j++) {
              braceCount += (lines[j].match(/\{/g) || []).length;
              braceCount -= (lines[j].match(/\}/g) || []).length;
              if (braceCount === 0) { endIdx = j; break; }
            }
            break;
          }
        }
        if (startIdx === -1 || endIdx === -1) throw new Error(`未找到相册「${data.oldId}」`);

        let newAlbum = `\t\t{\n`;
        newAlbum += `\t\t\tid: "${esc(data.newId)}",\n`;
        if (data.cover) newAlbum += `\t\t\tcover: "${esc(data.cover)}",\n`;
        newAlbum += `\t\t\tname: "${esc(data.name)}",\n`;
        if (data.description) newAlbum += `\t\t\tdescription: "${esc(data.description)}",\n`;
        if (data.location) newAlbum += `\t\t\tlocation: "${esc(data.location)}",\n`;
        if (data.date) newAlbum += `\t\t\tdate: "${data.date}",\n`;
        if (data.tags) {
          const tagList = data.tags.split(/[,，]/).map(t => t.trim()).filter(Boolean);
          if (tagList.length > 0) newAlbum += `\t\t\ttags: [${tagList.map(t => `"${esc(t)}"`).join(', ')}],\n`;
        }
        if (data.password) {
          newAlbum += `\t\t\tpassword: "${esc(data.password)}",\n`;
          if (data.passwordHint) newAlbum += `\t\t\tpasswordHint: "${esc(data.passwordHint)}",\n`;
        }
        newAlbum += `\t\t},`;

        lines.splice(startIdx, endIdx - startIdx + 1, newAlbum);
        updatedContent = lines.join('\n');
      }

      if (!updatedContent) throw new Error('更新内容为空');

      const encoded = btoa(unescape(encodeURIComponent(updatedContent)));
      const updateRes = await fetch(`https://api.github.com/repos/${repo}/contents/${configPath}`, {
        method: 'PUT',
        headers: {
          'Authorization': `token ${token}`,
          'Accept': 'application/vnd.github.v3+json',
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          message: `gallery: ${action} album "${data.name || data.oldId}"`,
          content: encoded,
          sha: sha,
          branch: 'main',
        }),
      });
      if (!updateRes.ok) {
        const err = await updateRes.json();
        throw new Error(err.message || '更新失败');
      }
    }

    // ===== 照片删除（单张 + 批量） =====
    function initPhotoDelete() {
      const container = document.querySelector('.gallery-masonry');
      if (!container || container.dataset.deleteBound) return;
      container.dataset.deleteBound = 'true';

      // 批量模式状态
      let batchMode = false;
      let selectedPhotos = new Set();

      // 添加批量操作栏
      const batchBar = document.createElement('div');
      batchBar.className = 'hidden items-center justify-between px-4 py-2 mb-3 rounded-lg bg-[var(--primary)]/5 border border-[var(--line-divider)] text-sm';
      batchBar.innerHTML = `
        <div class="flex items-center gap-3">
          <label class="flex items-center gap-1.5 cursor-pointer text-xs text-black/60 dark:text-white/60">
            <input id="select-all-photos" type="checkbox" class="w-3.5 h-3.5 rounded accent-[var(--primary)]" />
            全选
          </label>
          <span id="selected-count" class="text-xs text-black/40 dark:text-white/40">已选 0 张</span>
        </div>
        <div class="flex items-center gap-2">
          <button id="btn-batch-delete-photos" class="px-3 py-1 rounded text-xs font-medium bg-red-500 text-white hover:bg-red-600 cursor-pointer disabled:opacity-50" disabled>删除选中</button>
          <button id="btn-cancel-batch" class="px-3 py-1 rounded text-xs text-black/60 dark:text-white/60 hover:bg-black/5 dark:hover:bg-white/10 cursor-pointer">取消</button>
        </div>
      `;
      container.before(batchBar);

      // 点击勾选框：进入批量模式 + 切换选中
      container.addEventListener('click', (e) => {
        const selectBtn = e.target.closest('[data-action="select-photo"]');
        if (selectBtn) {
          e.preventDefault();
          e.stopPropagation();
          const card = selectBtn.closest('.gallery-photo-card');
          if (!card) return;
          if (!batchMode) enterBatchMode();
          togglePhotoSelection(card);
          return;
        }

        // 批量模式下点击照片切换选中
        if (batchMode) {
          const photoCard = e.target.closest('.gallery-photo-card');
          if (photoCard) {
            e.preventDefault();
            e.stopPropagation();
            togglePhotoSelection(photoCard);
          }
        }
        // 非批量模式：不阻止，让 Fancybox 处理点击
      }, true);

      // 批量模式
      function enterBatchMode() {
        if (batchMode) return;
        batchMode = true;
        selectedPhotos.clear();
        batchBar.classList.remove('hidden');
        batchBar.classList.add('flex');
        container.querySelectorAll('.gallery-photo-card').forEach(card => {
          const checkbox = card.querySelector('.photo-checkbox');
          if (checkbox) {
            checkbox.style.opacity = '1';
          }
        });
      }

      function exitBatchMode() {
        batchMode = false;
        deleteConfirmMode = false;
        selectedPhotos.clear();
        batchBar.classList.add('hidden');
        batchBar.classList.remove('flex');
        // 重置删除按钮状态
        batchDeleteBtn.textContent = '删除选中';
        batchDeleteBtn.classList.remove('bg-red-700', 'hover:bg-red-800');
        batchDeleteBtn.classList.add('bg-red-500', 'hover:bg-red-600');
        container.querySelectorAll('.gallery-photo-card').forEach(card => {
          const checkbox = card.querySelector('.photo-checkbox');
          if (checkbox) {
            checkbox.style.opacity = '';
            // 重置勾选框样式
            checkbox.style.backgroundColor = '';
            checkbox.style.borderColor = '';
            const checkIcon = checkbox.querySelector('.check-icon');
            if (checkIcon) checkIcon.style.display = 'none';
          }
        });
        document.getElementById('select-all-photos').checked = false;
        updateSelectedCount();
      }

      function togglePhotoSelection(card) {
        const src = card.querySelector('[data-src]')?.dataset.src || card.querySelector('img')?.src;
        if (!src) return;
        const checkbox = card.querySelector('.photo-checkbox');
        const checkIcon = checkbox?.querySelector('.check-icon');

        if (selectedPhotos.has(src)) {
          selectedPhotos.delete(src);
          // 取消选中：恢复勾选框样式
          if (checkbox) {
            checkbox.style.backgroundColor = '';
            checkbox.style.borderColor = '';
          }
          if (checkIcon) checkIcon.style.display = 'none';
        } else {
          selectedPhotos.add(src);
          // 选中：勾选框变主题色 + 显示勾
          if (checkbox) {
            checkbox.style.backgroundColor = 'var(--primary)';
            checkbox.style.borderColor = 'var(--primary)';
          }
          if (checkIcon) checkIcon.style.display = 'block';
        }
        updateSelectedCount();
      }

      function updateSelectedCount() {
        document.getElementById('selected-count').textContent = `已选 ${selectedPhotos.size} 张`;
        document.getElementById('btn-batch-delete-photos').disabled = selectedPhotos.size === 0;
      }

      // 全选
      batchBar.querySelector('#select-all-photos').addEventListener('change', (e) => {
        container.querySelectorAll('.gallery-photo-card').forEach(card => {
          const src = card.querySelector('[data-src]')?.dataset.src || card.querySelector('img')?.src;
          if (!src) return;
          const checkbox = card.querySelector('.photo-checkbox');
          const checkIcon = checkbox?.querySelector('.check-icon');
          if (e.target.checked) {
            selectedPhotos.add(src);
            if (checkbox) {
              checkbox.style.backgroundColor = 'var(--primary)';
              checkbox.style.borderColor = 'var(--primary)';
            }
            if (checkIcon) checkIcon.style.display = 'block';
          } else {
            selectedPhotos.delete(src);
            if (checkbox) {
              checkbox.style.backgroundColor = '';
              checkbox.style.borderColor = '';
            }
            if (checkIcon) checkIcon.style.display = 'none';
          }
        });
        updateSelectedCount();
      });

      // 批量删除 - 按钮状态切换
      let deleteConfirmMode = false;
      const batchDeleteBtn = batchBar.querySelector('#btn-batch-delete-photos');
      const batchCancelBtn = batchBar.querySelector('#btn-cancel-batch');

      batchDeleteBtn.addEventListener('click', () => {
        if (selectedPhotos.size === 0) return;

        if (!deleteConfirmMode) {
          // 第一次点击：进入确认模式
          deleteConfirmMode = true;
          batchDeleteBtn.textContent = '确认删除';
          batchDeleteBtn.classList.remove('bg-red-500', 'hover:bg-red-600');
          batchDeleteBtn.classList.add('bg-red-700', 'hover:bg-red-800');
        } else {
          // 第二次点击：执行删除
          deleteConfirmMode = false;
          deletePhotos([...selectedPhotos]);
        }
      });

      // 取消批量
      batchCancelBtn.addEventListener('click', () => {
        if (deleteConfirmMode) {
          // 确认模式下点取消：恢复按钮状态
          deleteConfirmMode = false;
          batchDeleteBtn.textContent = '删除选中';
          batchDeleteBtn.classList.remove('bg-red-700', 'hover:bg-red-800');
          batchDeleteBtn.classList.add('bg-red-500', 'hover:bg-red-600');
        } else {
          // 非确认模式：退出批量模式
          exitBatchMode();
        }
      });

      // 删除照片（通过 GitHub API）
      async function deletePhotos(photoSrcs) {
        const token = localStorage.getItem('gh-token') || localStorage.getItem('gh-editor-token');
        const repo = localStorage.getItem('gh-editor-repo') || 'Ghost-Insititue/Fireflyblog';
        if (!token) { alert('请先在编辑器页面配置 GitHub Token'); return; }

        // 显示进度
        const statusBar = document.createElement('div');
        statusBar.className = 'flex items-center gap-2 px-4 py-2 mb-3 rounded-lg bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 text-sm text-blue-600 dark:text-blue-400';
        statusBar.textContent = '⏳ 正在删除...';
        container.before(statusBar);

        let success = 0, failed = 0;
        for (const src of photoSrcs) {
          try {
            // 从 URL 提取文件路径
            const match = src.match(/\/gallery\/([^/]+)\/(.+)$/);
            if (!match) { failed++; continue; }
            const [, albumDir, filename] = match;
            const filePath = `public/gallery/${albumDir}/${filename}`;

            // 获取文件 SHA
            const getRes = await fetch(`https://api.github.com/repos/${repo}/contents/${filePath}?ref=main`, {
              headers: { 'Authorization': `token ${token}`, 'Accept': 'application/vnd.github.v3+json' },
            });
            if (!getRes.ok) { failed++; continue; }
            const fileData = await getRes.json();

            // 删除文件
            const delRes = await fetch(`https://api.github.com/repos/${repo}/contents/${filePath}`, {
              method: 'DELETE',
              headers: {
                'Authorization': `token ${token}`,
                'Accept': 'application/vnd.github.v3+json',
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({
                message: `gallery: delete ${filename} from ${albumDir}`,
                sha: fileData.sha,
                branch: 'main',
              }),
            });
            if (delRes.ok) success++;
            else failed++;
          } catch {
            failed++;
          }
        }

        statusBar.className = 'flex items-center gap-2 px-4 py-2 mb-3 rounded-lg text-sm ' +
          (success > 0 ? 'bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 text-green-600 dark:text-green-400' : 'bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-600 dark:text-red-400');
        statusBar.textContent = `✅ 删除完成：${success} 成功，${failed} 失败`;

        if (success > 0) {
          exitBatchMode();
          setTimeout(() => { window.location.reload(); }, 1500);
        }
      }
    }

    // Swup 导航后重新初始化
    function reinitInternal() {
      setupAlbumDelegate();
      setTimeout(function() { initGalleryUpload(); initAlbumEdit(); initPhotoDelete(); }, 100);
    }
    document.addEventListener('DOMContentLoaded', reinitInternal);
    if (document.readyState === 'complete' || document.readyState === 'interactive') reinitInternal();
    document.addEventListener('swup:content:replaced', reinitInternal);
    document.addEventListener('swup:contentReplaced', reinitInternal);
    document.addEventListener('swup:enable', reinitInternal);
  </script>

  <style is:inline>
    /* 隐藏浏览器自带的密码眼睛按钮（Edge: ::-ms-reveal, Firefox: ::-moz-reveal） */
    input[type="password"]::-ms-reveal { display: none !important; }
    input[type="password"]::-moz-reveal { display: none !important; }
  </style>

</MainGridLayout>
