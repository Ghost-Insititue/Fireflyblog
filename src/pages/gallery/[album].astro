---
import { Icon } from "astro-icon/components";
import EncryptedContent from "@/components/features/EncryptedContent.astro";
import PhotoCard from "@/components/pages/gallery/PhotoCard.astro";
import { galleryConfig, siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getAlbumCover, scanAlbumPhotos } from "@/utils/gallery-utils";
import { getLqipProps } from "@/utils/lqip-utils";
import { url } from "@/utils/url-utils";

// 检查页面是否启用
if (!siteConfig.pages.gallery) {
	return Astro.redirect("/404/");
}

export function getStaticPaths() {
	return galleryConfig.albums.map((album) => ({
		params: { album: album.id },
	}));
}

const { album: albumId } = Astro.params;
const albumMeta = galleryConfig.albums.find((a) => a.id === albumId);

if (!albumMeta) {
	return Astro.redirect("/404/");
}

const photos = scanAlbumPhotos(albumMeta.id);
const cover = getAlbumCover(albumMeta, photos);
const columnWidth = galleryConfig.columnWidth || 240;

// LQIP 渐变占位
const coverLqipProps = cover
	? getLqipProps(cover, undefined, true)
	: { style: "" };
---

<MainGridLayout title={albumMeta.name} description={albumMeta.description || ""}>
  <!-- 相册封面横幅 -->
  <div class="w-full rounded-(--radius-large) overflow-hidden relative">
    {cover ? (
      <div class="relative w-full aspect-[3/1] min-h-[200px] max-h-[360px] overflow-hidden">
        <div class="lqip-placeholder absolute inset-0 pointer-events-none" style={coverLqipProps.style} aria-hidden="true"></div>
        <img
          src={cover}
          alt={albumMeta.name}
          class="w-full h-full object-cover opacity-0 transition-opacity duration-500 ease-out"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent" />
        <!-- 返回按钮 -->
        <a
          href={url("/gallery/")}
          class="absolute top-4 left-4 inline-flex items-center gap-1.5 text-sm text-white/90 hover:text-white bg-black/30 hover:bg-black/50 backdrop-blur-sm px-3 py-1.5 rounded-lg transition-colors"
        >
          <Icon is:inline name="material-symbols:arrow-back" class="text-base" />
          {i18n(I18nKey.galleryBackToAlbums)}
        </a>
        <!-- 上传按钮 -->
        <button
          id="btn-upload-photo"
          class="absolute top-4 right-4 inline-flex items-center gap-1.5 text-sm text-white/90 hover:text-white bg-black/30 hover:bg-black/50 backdrop-blur-sm px-3 py-1.5 rounded-lg transition-colors cursor-pointer"
          title="上传照片"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          上传
        </button>
        <!-- 封面上的信息 -->
        <div class="absolute bottom-0 left-0 right-0 p-6">
          <div class="text-2xl sm:text-3xl font-bold text-white mb-2 drop-shadow-lg">
            {albumMeta.name}
          </div>
          {albumMeta.description && (
            <p class="text-sm text-white/75 leading-relaxed mb-2 max-w-2xl line-clamp-2">
              {albumMeta.description}
            </p>
          )}
          <div class="flex items-center gap-4 text-sm text-white/80 flex-wrap">
            {albumMeta.date && (
              <span class="inline-flex items-center gap-1">
                <Icon is:inline name="material-symbols:calendar-today" class="text-sm" />
                {albumMeta.date}
              </span>
            )}
            {albumMeta.location && (
              <span class="inline-flex items-center gap-1">
                <Icon is:inline name="material-symbols:location-on" class="text-sm" />
                {albumMeta.location}
              </span>
            )}
            <span class="inline-flex items-center gap-1">
              <Icon is:inline name="material-symbols:photo-library" class="text-sm" />
              {photos.length} {i18n(I18nKey.galleryPhotos)}
            </span>
          </div>
          {albumMeta.tags && albumMeta.tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5 mt-2.5">
              {albumMeta.tags.map((tag) => (
                <span class="text-xs px-2 py-0.5 rounded bg-white/20 text-white/90 backdrop-blur-sm">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </div>
      </div>
    ) : (
      <div class="card-base px-6 py-4">
        <div class="flex items-center justify-between mb-3">
          <a
            href={url("/gallery/")}
            class="inline-flex items-center gap-1 text-sm text-(--primary) hover:underline"
          >
            <Icon is:inline name="material-symbols:arrow-back" class="text-base" />
            {i18n(I18nKey.galleryBackToAlbums)}
          </a>
          <button
            id="btn-upload-photo"
            class="inline-flex items-center gap-1.5 text-sm text-(--primary) hover:underline cursor-pointer"
            title="上传照片"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            上传
          </button>
        </div>
        <div class="text-2xl sm:text-3xl font-bold text-neutral-900 dark:text-neutral-100">
          {albumMeta.name}
        </div>
        <div class="flex items-center gap-4 text-sm text-neutral-500 dark:text-neutral-400 mt-2 flex-wrap">
          {albumMeta.date && (
            <span class="inline-flex items-center gap-1">
              <Icon is:inline name="material-symbols:calendar-today" class="text-sm" />
              {albumMeta.date}
            </span>
          )}
          {albumMeta.location && (
            <span class="inline-flex items-center gap-1">
              <Icon is:inline name="material-symbols:location-on" class="text-sm" />
              {albumMeta.location}
            </span>
          )}
          <span>{photos.length} {i18n(I18nKey.galleryPhotos)}</span>
        </div>
      </div>
    )}
  </div>

  <!-- 瀑布流照片网格 -->
  <div class="w-full rounded-(--radius-large) overflow-hidden relative mt-4">
    <div class="card-base z-10 px-6 py-6 relative w-full">
      {photos.length > 0 ? (
        albumMeta.password ? (
          <EncryptedContent password={albumMeta.password} slug={albumMeta.id} hint={albumMeta.passwordHint}>
            <div
              class="gallery-masonry"
              style={`column-count: 2; column-gap: 0.75rem; --col-width: ${columnWidth}px;`}
            >
              {photos.map((photo) => (
                <PhotoCard src={photo} albumId={albumMeta.id} />
              ))}
            </div>
          </EncryptedContent>
        ) : (
          <div
            class="gallery-masonry"
            style={`column-count: 2; column-gap: 0.75rem; --col-width: ${columnWidth}px;`}
          >
            {photos.map((photo) => (
              <PhotoCard src={photo} albumId={albumMeta.id} />
            ))}
          </div>
        )
      ) : (
        <div class="flex flex-col items-center justify-center py-16 text-neutral-400 dark:text-neutral-500">
          <Icon is:inline name="material-symbols:photo-library" class="text-6xl mb-4 opacity-50" />
          <p class="text-lg">{i18n(I18nKey.galleryNoAlbums)}</p>
        </div>
      )}
    </div>
  </div>

</MainGridLayout>

<!-- 上传弹窗（必须在 MainGridLayout 外部，避免被 overflow-hidden 裁剪） -->
<div id="gallery-upload-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 hidden">
    <div class="rounded-2xl p-6 shadow-2xl bg-white dark:bg-neutral-900 border border-[var(--line-divider)]" style="width: 480px;">
      <h3 class="text-base font-bold text-black/90 dark:text-white/90 mb-4">📷 上传照片到「{albumMeta.name}」</h3>

      <!-- 拖拽区域 -->
      <div id="upload-dropzone" class="border-2 border-dashed border-[var(--line-divider)] rounded-xl p-8 text-center cursor-pointer hover:border-[var(--primary)]/50 hover:bg-[var(--primary)]/5 transition mb-4">
        <svg class="mx-auto mb-3 text-black/30 dark:text-white/30" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        <p class="text-sm text-black/50 dark:text-white/50">拖拽图片到此处，或点击选择</p>
        <p class="text-xs text-black/30 dark:text-white/30 mt-1">支持 jpg / png / webp / avif / gif</p>
        <input id="upload-file-input" type="file" accept="image/*" multiple class="hidden" />
      </div>

      <!-- 文件列表 -->
      <div id="upload-file-list" class="space-y-2 max-h-48 overflow-y-auto mb-4 hidden"></div>

      <!-- 状态 -->
      <div id="upload-status" class="text-sm mb-4 hidden"></div>

      <!-- 按钮 -->
      <div class="flex justify-end gap-2">
        <button id="upload-cancel" class="px-4 py-2 rounded-lg text-sm text-black/70 dark:text-white/70 hover:bg-black/5 dark:hover:bg-white/10 transition cursor-pointer">取消</button>
        <button id="upload-confirm" class="px-5 py-2 rounded-lg bg-[var(--primary)] text-white dark:text-black/80 text-sm font-medium hover:opacity-90 transition cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed" disabled>上传</button>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ albumId: albumMeta.id }}>
    (function() {
      const modal = document.getElementById('gallery-upload-modal');
      const dropzone = document.getElementById('upload-dropzone');
      const fileInput = document.getElementById('upload-file-input');
      const fileList = document.getElementById('upload-file-list');
      const statusEl = document.getElementById('upload-status');
      const btnConfirm = document.getElementById('upload-confirm');
      const btnCancel = document.getElementById('upload-cancel');
      let selectedFiles = [];

      // 打开弹窗
      document.getElementById('btn-upload-photo').addEventListener('click', () => {
        modal.classList.remove('hidden');
        selectedFiles = [];
        fileList.classList.add('hidden');
        fileList.innerHTML = '';
        statusEl.classList.add('hidden');
        btnConfirm.disabled = true;
        btnConfirm.textContent = '上传';
      });

      // 关闭
      btnCancel.addEventListener('click', () => modal.classList.add('hidden'));
      modal.addEventListener('click', (e) => { if (e.target === e.currentTarget) modal.classList.add('hidden'); });

      // 拖拽区域点击
      dropzone.addEventListener('click', () => fileInput.click());
      dropzone.addEventListener('dragover', (e) => { e.preventDefault(); dropzone.classList.add('border-[var(--primary)]'); });
      dropzone.addEventListener('dragleave', () => { dropzone.classList.remove('border-[var(--primary)]'); });
      dropzone.addEventListener('drop', (e) => {
        e.preventDefault();
        dropzone.classList.remove('border-[var(--primary)]');
        addFiles(e.dataTransfer.files);
      });
      fileInput.addEventListener('change', () => addFiles(fileInput.files));

      function addFiles(files) {
        for (const f of files) {
          if (!f.type.startsWith('image/')) continue;
          if (selectedFiles.some(s => s.name === f.name && s.size === f.size)) continue;
          selectedFiles.push(f);
        }
        renderFileList();
      }

      function renderFileList() {
        if (selectedFiles.length === 0) {
          fileList.classList.add('hidden');
          btnConfirm.disabled = true;
          return;
        }
        fileList.classList.remove('hidden');
        btnConfirm.disabled = false;
        fileList.innerHTML = selectedFiles.map((f, i) => `
          <div class="flex items-center gap-3 px-3 py-2 rounded-lg bg-black/5 dark:bg-white/5">
            <div class="w-10 h-10 rounded overflow-hidden flex-shrink-0 bg-black/10 dark:bg-white/10">
              <img src="${URL.createObjectURL(f)}" class="w-full h-full object-cover" />
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-sm truncate text-black/80 dark:text-white/80">${f.name}</div>
              <div class="text-xs text-black/40 dark:text-white/40">${(f.size / 1024).toFixed(1)} KB</div>
            </div>
            <button class="text-xs text-red-500 hover:text-red-700 cursor-pointer px-2 py-1 rounded hover:bg-red-50 dark:hover:bg-red-900/20" data-remove="${i}">移除</button>
          </div>
        `).join('');

        fileList.querySelectorAll('[data-remove]').forEach(btn => {
          btn.addEventListener('click', () => {
            selectedFiles.splice(parseInt(btn.dataset.remove), 1);
            renderFileList();
          });
        });
      }

      // 上传
      btnConfirm.addEventListener('click', async () => {
        if (selectedFiles.length === 0) return;

        const token = localStorage.getItem('gh-editor-token');
        const repo = localStorage.getItem('gh-editor-repo') || 'Ghost-Insititue/Fireflyblog';

        if (!token) {
          showStatus('❌ 请先在编辑器页面配置 GitHub Token（点击「发布到 GitHub」设置）', 'error');
          return;
        }

        btnConfirm.disabled = true;
        btnConfirm.textContent = '上传中...';
        let success = 0;
        let failed = 0;

        for (let i = 0; i < selectedFiles.length; i++) {
          const file = selectedFiles[i];
          btnConfirm.textContent = `上传中 (${i + 1}/${selectedFiles.length})...`;
          showStatus(`⏳ 正在上传 ${file.name} (${i + 1}/${selectedFiles.length})...`, 'uploading');

          try {
            const ext = file.name.split('.').pop() || 'jpg';
            const ts = Date.now();
            const rand = Math.random().toString(36).substring(2, 6);
            const safeName = file.name.replace(/[^a-zA-Z0-9._\-\u4e00-\u9fff]/g, '_');
            const filename = `${ts}-${rand}-${safeName}`;
            const filePath = `public/gallery/${albumId}/${filename}`;

            const arrayBuffer = await file.arrayBuffer();
            const bytes = new Uint8Array(arrayBuffer);
            let binary = '';
            for (let j = 0; j < bytes.length; j++) binary += String.fromCharCode(bytes[j]);
            const base64 = btoa(binary);

            const res = await fetch(`https://api.github.com/repos/${repo}/contents/${filePath}`, {
              method: 'PUT',
              headers: {
                'Authorization': `token ${token}`,
                'Accept': 'application/vnd.github.v3+json',
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({
                message: `gallery: upload ${filename} to ${albumId}`,
                content: base64,
                branch: 'main',
              }),
            });

            if (res.ok) success++;
            else {
              const err = await res.json();
              console.error(`Upload failed: ${file.name}`, err);
              failed++;
            }
          } catch (e) {
            console.error(`Upload error: ${file.name}`, e);
            failed++;
          }
        }

        btnConfirm.textContent = '完成';
        showStatus(`✅ 上传完成：${success} 成功，${failed} 失败`, success > 0 ? 'success' : 'error');

        if (success > 0) {
          setTimeout(() => { window.location.reload(); }, 1500);
        }
      });

      function showStatus(msg, type) {
        statusEl.classList.remove('hidden');
        statusEl.className = 'text-sm mb-4 ' +
          (type === 'error' ? 'text-red-500' :
           type === 'success' ? 'text-green-500' :
           'text-blue-500');
        statusEl.textContent = msg;
      }
    })();
  </script>
