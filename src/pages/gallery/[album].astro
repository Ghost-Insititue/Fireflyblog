---
import { Icon } from "astro-icon/components";
import EncryptedContent from "@/components/features/EncryptedContent.astro";
import PhotoCard from "@/components/pages/gallery/PhotoCard.astro";
import { galleryConfig, siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getAlbumCover, scanAlbumPhotos } from "@/utils/gallery-utils";
import { getLqipProps } from "@/utils/lqip-utils";
import { url } from "@/utils/url-utils";

// 检查页面是否启用
if (!siteConfig.pages.gallery) {
	return Astro.redirect("/404/");
}

export function getStaticPaths() {
	return galleryConfig.albums.map((album) => ({
		params: { album: album.id },
	}));
}

const { album: albumId } = Astro.params;
const albumMeta = galleryConfig.albums.find((a) => a.id === albumId);

if (!albumMeta) {
	return Astro.redirect("/404/");
}

const photos = scanAlbumPhotos(albumMeta.id);
const cover = getAlbumCover(albumMeta, photos);
const columnWidth = galleryConfig.columnWidth || 240;

// LQIP 渐变占位
const coverLqipProps = cover
	? getLqipProps(cover, undefined, true)
	: { style: "" };
---

<MainGridLayout title={albumMeta.name} description={albumMeta.description || ""}>
  <!-- 相册封面横幅 -->
  <div class="w-full rounded-(--radius-large) overflow-hidden relative">
    {cover ? (
      <div class="relative w-full aspect-[3/1] min-h-[200px] max-h-[360px] overflow-hidden">
        <div class="lqip-placeholder absolute inset-0 pointer-events-none" style={coverLqipProps.style} aria-hidden="true"></div>
        <img
          src={cover}
          alt={albumMeta.name}
          class="w-full h-full object-cover opacity-0 transition-opacity duration-500 ease-out"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent" />
        <!-- 返回按钮 -->
        <a
          href={url("/gallery/")}
          class="absolute top-4 left-4 inline-flex items-center gap-1.5 text-sm text-white/90 hover:text-white bg-black/30 hover:bg-black/50 backdrop-blur-sm px-3 py-1.5 rounded-lg transition-colors"
        >
          <Icon is:inline name="material-symbols:arrow-back" class="text-base" />
          {i18n(I18nKey.galleryBackToAlbums)}
        </a>
        <!-- 上传按钮 -->
        <div class="absolute top-4 right-4 flex items-center gap-2">
          <button
            id="btn-edit-album"
            data-album-name={albumMeta.name}
            data-album-id={albumMeta.id}
            data-album-desc={albumMeta.description || ''}
            data-album-date={albumMeta.date || ''}
            data-album-location={albumMeta.location || ''}
            data-album-tags={(albumMeta.tags || []).join(',')}
            data-album-has-password={albumMeta.password ? 'true' : ''}
            class="inline-flex items-center gap-1.5 text-sm text-white/90 hover:text-white bg-black/30 hover:bg-black/50 backdrop-blur-sm px-3 py-1.5 rounded-lg transition-colors cursor-pointer"
            title="编辑相册"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            编辑
          </button>
          <button
            id="btn-delete-album"
            class="inline-flex items-center gap-1.5 text-sm text-white/90 hover:text-white bg-red-500/50 hover:bg-red-500/70 backdrop-blur-sm px-3 py-1.5 rounded-lg transition-colors cursor-pointer"
            title="删除相册"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
            删除
          </button>
          <button
            id="btn-upload-photo"
            class="inline-flex items-center gap-1.5 text-sm text-white/90 hover:text-white bg-black/30 hover:bg-black/50 backdrop-blur-sm px-3 py-1.5 rounded-lg transition-colors cursor-pointer"
            title="上传照片"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            上传
          </button>
          <button
            id="btn-refresh-album"
            class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-black/30 hover:bg-black/50 backdrop-blur-sm text-white/90 hover:text-white transition-colors cursor-pointer"
            title="刷新页面"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
          </button>
        </div>
        <!-- 封面上的信息 -->
        <div class="absolute bottom-0 left-0 right-0 p-6">
          <div class="text-2xl sm:text-3xl font-bold text-white mb-2 drop-shadow-lg">
            {albumMeta.name}
          </div>
          {albumMeta.description && (
            <p class="text-sm text-white/75 leading-relaxed mb-2 max-w-2xl line-clamp-2">
              {albumMeta.description}
            </p>
          )}
          <div class="flex items-center gap-4 text-sm text-white/80 flex-wrap">
            {albumMeta.date && (
              <span class="inline-flex items-center gap-1">
                <Icon is:inline name="material-symbols:calendar-today" class="text-sm" />
                {albumMeta.date}
              </span>
            )}
            {albumMeta.location && (
              <span class="inline-flex items-center gap-1">
                <Icon is:inline name="material-symbols:location-on" class="text-sm" />
                {albumMeta.location}
              </span>
            )}
            <span class="inline-flex items-center gap-1">
              <Icon is:inline name="material-symbols:photo-library" class="text-sm" />
              {photos.length} {i18n(I18nKey.galleryPhotos)}
            </span>
          </div>
          {albumMeta.tags && albumMeta.tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5 mt-2.5">
              {albumMeta.tags.map((tag) => (
                <span class="text-xs px-2 py-0.5 rounded bg-white/20 text-white/90 backdrop-blur-sm">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </div>
      </div>
    ) : (
      <div class="card-base px-6 py-4">
        <div class="flex items-center justify-between mb-3">
          <a
            href={url("/gallery/")}
            class="inline-flex items-center gap-1 text-sm text-(--primary) hover:underline"
          >
            <Icon is:inline name="material-symbols:arrow-back" class="text-base" />
            {i18n(I18nKey.galleryBackToAlbums)}
          </a>
          <div class="flex items-center gap-2">
            <button
              id="btn-edit-album"
              data-album-name={albumMeta.name}
              data-album-id={albumMeta.id}
              data-album-desc={albumMeta.description || ''}
              data-album-date={albumMeta.date || ''}
              data-album-location={albumMeta.location || ''}
              data-album-tags={(albumMeta.tags || []).join(',')}
              data-album-has-password={albumMeta.password ? 'true' : ''}
              class="inline-flex items-center gap-1.5 text-sm text-(--primary) hover:underline cursor-pointer"
              title="编辑相册"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              编辑
            </button>
            <button
              id="btn-delete-album"
              class="inline-flex items-center gap-1.5 text-sm text-red-500 hover:underline cursor-pointer"
              title="删除相册"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
              删除
            </button>
            <button
              id="btn-upload-photo"
              class="inline-flex items-center gap-1.5 text-sm text-(--primary) hover:underline cursor-pointer"
              title="上传照片"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
              上传
            </button>
            <button
              id="btn-refresh-album"
              class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-(--line-divider) bg-transparent text-neutral-600 dark:text-neutral-400 hover:bg-black/5 dark:hover:bg-white/10 transition cursor-pointer"
              title="刷新页面"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
            </button>
          </div>
        </div>
        <div class="text-2xl sm:text-3xl font-bold text-neutral-900 dark:text-neutral-100">
          {albumMeta.name}
        </div>
        <div class="flex items-center gap-4 text-sm text-neutral-500 dark:text-neutral-400 mt-2 flex-wrap">
          {albumMeta.date && (
            <span class="inline-flex items-center gap-1">
              <Icon is:inline name="material-symbols:calendar-today" class="text-sm" />
              {albumMeta.date}
            </span>
          )}
          {albumMeta.location && (
            <span class="inline-flex items-center gap-1">
              <Icon is:inline name="material-symbols:location-on" class="text-sm" />
              {albumMeta.location}
            </span>
          )}
          <span>{photos.length} {i18n(I18nKey.galleryPhotos)}</span>
        </div>
      </div>
    )}
  </div>

  <!-- 瀑布流照片网格 -->
  <div class="w-full rounded-(--radius-large) overflow-hidden relative mt-4">
    <div class="card-base z-10 px-6 py-6 relative w-full">
      {photos.length > 0 ? (
        albumMeta.password ? (
          <EncryptedContent password={albumMeta.password} slug={albumMeta.id} hint={albumMeta.passwordHint}>
            <div
              class="gallery-masonry"
              style={`column-count: 2; column-gap: 0.75rem; --col-width: ${columnWidth}px;`}
            >
              {photos.map((photo) => (
                <PhotoCard src={photo} albumId={albumMeta.id} />
              ))}
            </div>
          </EncryptedContent>
        ) : (
          <div
            class="gallery-masonry"
            style={`column-count: 2; column-gap: 0.75rem; --col-width: ${columnWidth}px;`}
          >
            {photos.map((photo) => (
              <PhotoCard src={photo} albumId={albumMeta.id} />
            ))}
          </div>
        )
      ) : (
        <div class="flex flex-col items-center justify-center py-16 text-neutral-400 dark:text-neutral-500">
          <Icon is:inline name="material-symbols:photo-library" class="text-6xl mb-4 opacity-50" />
          <p class="text-lg">{i18n(I18nKey.galleryNoAlbums)}</p>
        </div>
      )}
    </div>
  </div>

  <!-- 弹窗（放在 #swup-container 内，确保 Swup 导航后仍在 DOM 中） -->
  <div id="gallery-upload-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 hidden">
    <div class="rounded-2xl p-6 shadow-2xl bg-white dark:bg-neutral-900 border border-[var(--line-divider)]" style="width: 480px;">
      <h3 class="text-base font-bold text-black/90 dark:text-white/90 mb-4">📷 上传照片到「{albumMeta.name}」</h3>

      <!-- 拖拽区域 -->
      <div id="upload-dropzone" class="border-2 border-dashed border-[var(--line-divider)] rounded-xl p-8 text-center cursor-pointer hover:border-[var(--primary)]/50 hover:bg-[var(--primary)]/5 transition mb-4">
        <svg class="mx-auto mb-3 text-black/30 dark:text-white/30" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        <p class="text-sm text-black/50 dark:text-white/50">拖拽图片到此处，或点击选择</p>
        <p class="text-xs text-black/30 dark:text-white/30 mt-1">支持 jpg / png / webp / avif / gif</p>
        <input id="upload-file-input" type="file" accept="image/*" multiple class="hidden" />
      </div>

      <!-- 文件列表 -->
      <div id="upload-file-list" class="space-y-2 max-h-48 overflow-y-auto mb-4 hidden"></div>

      <!-- 状态 -->
      <div id="upload-status" class="text-sm mb-4 hidden"></div>

      <!-- 按钮 -->
      <div class="flex justify-end gap-2">
        <button id="upload-cancel" class="px-4 py-2 rounded-lg text-sm text-black/70 dark:text-white/70 hover:bg-black/5 dark:hover:bg-white/10 transition cursor-pointer">取消</button>
        <button id="upload-confirm" class="px-5 py-2 rounded-lg bg-[var(--primary)] text-white dark:text-black/80 text-sm font-medium hover:opacity-90 transition cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed" disabled>上传</button>
      </div>
    </div>
  </div>

  <!-- 编辑相册弹窗 -->
  <div id="edit-album-modal" class="fixed inset-0 z-50 hidden bg-black/50">
    <div class="rounded-2xl p-6 shadow-2xl bg-white dark:bg-neutral-900 border border-[var(--line-divider)]" style="position: absolute; top: 5.5vh; left: 50%; transform: translateX(-50%); width: 480px; max-height: 90vh; overflow-y: auto;">
      <h3 class="text-base font-bold text-black/90 dark:text-white/90 mb-4">✏️ 编辑相册</h3>
      <div class="space-y-3">
        <div class="flex gap-3">
          <div class="flex-1">
            <label class="block text-xs font-medium text-black/60 dark:text-white/60 mb-1">相册名称 <span class="text-red-500">*</span></label>
            <input id="edit-album-name" type="text" placeholder="如：2026 旅行日记"
              class="w-full px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" />
          </div>
          <div style="width: 180px;">
            <label class="block text-xs font-medium text-black/60 dark:text-white/60 mb-1">相册 ID <span class="text-xs text-black/40 dark:text-white/40">（用于 URL 和目录名）</span></label>
            <input id="edit-album-id" type="text" placeholder="travel-2026"
              class="w-full px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" />
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium text-black/60 dark:text-white/60 mb-1">描述</label>
          <input id="edit-album-desc" type="text" placeholder="一句话描述相册内容"
            class="w-full px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" />
        </div>
        <div class="flex gap-3">
          <div class="flex-1">
            <label class="block text-xs font-medium text-black/60 dark:text-white/60 mb-1">拍摄地点</label>
            <input id="edit-album-location" type="text" placeholder="如：杭州"
              class="w-full px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" />
          </div>
          <div style="width: 180px;">
            <label class="block text-xs font-medium text-black/60 dark:text-white/60 mb-1">日期</label>
            <input id="edit-album-date" type="date"
              class="w-full px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" />
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium text-black/60 dark:text-white/60 mb-1">标签</label>
          <div class="grid grid-cols-4 gap-3">
            <input id="edit-album-tag1" type="text" placeholder="标签1"
              class="px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" />
            <input id="edit-album-tag2" type="text" placeholder="标签2"
              class="px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" />
            <input id="edit-album-tagcustom" type="text" placeholder="自定义标签"
              class="col-span-2 px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" />
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium text-black/60 dark:text-white/60 mb-1">访问密码 <span class="text-xs text-black/40 dark:text-white/40">（留空公开）</span></label>
          <div class="grid grid-cols-4 gap-3">
            <input id="edit-album-hint" type="text" placeholder="密码提示（可选）"
              class="col-span-2 px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" />
            <div class="col-span-2 relative">
              <input id="edit-album-password" type="password" placeholder="设置密码（留空不加密）"
                class="w-full px-3 py-2 pr-9 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" />
              <button id="toggle-edit-pwd" type="button" class="absolute right-2 top-1/2 -translate-y-1/2 text-black/40 dark:text-white/40 hover:text-black/70 dark:hover:text-white/70 cursor-pointer">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              </button>
            </div>
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium text-black/60 dark:text-white/60 mb-1">封面图 <span class="text-xs text-black/40 dark:text-white/40">（可选，支持 jpg/png/webp）</span></label>
          <div id="edit-album-cover-drop" class="relative border-2 border-dashed border-[var(--line-divider)] rounded-lg p-3 text-center cursor-pointer hover:border-[var(--primary)]/50 transition">
            <input id="edit-album-cover-input" type="file" accept="image/jpeg,image/png,image/webp" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" />
            <div id="edit-album-cover-preview" class="hidden">
              <img id="edit-album-cover-img" class="max-h-24 mx-auto rounded object-cover" />
              <p id="edit-album-cover-name" class="text-xs text-black/60 dark:text-white/60 mt-1 truncate"></p>
            </div>
            <div id="edit-album-cover-placeholder" class="text-black/40 dark:text-white/40">
              <svg class="w-6 h-6 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
              <p class="text-xs">点击或拖拽上传新封面图</p>
            </div>
          </div>
          <input id="edit-album-cover-file" type="hidden" value="" />
        </div>

        <div id="edit-status" class="text-sm hidden"></div>
      </div>
      <div class="flex justify-end gap-2 mt-5">
        <button id="edit-cancel" class="px-4 py-2 rounded-lg text-sm text-black/70 dark:text-white/70 hover:bg-black/5 dark:hover:bg-white/10 transition cursor-pointer">取消</button>
        <button id="edit-confirm" class="px-5 py-2 rounded-lg bg-(--primary) text-white dark:text-black/80 text-sm font-medium hover:opacity-90 transition cursor-pointer">保存</button>
      </div>
    </div>
  </div>

  <!-- 删除确认弹窗 -->
  <div id="delete-album-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 hidden">
    <div class="rounded-2xl p-6 shadow-2xl bg-white dark:bg-neutral-900 border border-[var(--line-divider)]" style="width: 400px;">
      <h3 class="text-base font-bold text-red-500 mb-2">⚠️ 删除相册</h3>
      <p class="text-sm text-black/70 dark:text-white/70 mb-1">确定要删除相册「<span id="delete-album-name"></span>」吗？</p>
      <p class="text-xs text-black/40 dark:text-white/40 mb-4">此操作会同时删除相册配置和服务器上的所有照片文件，操作不可恢复。</p>
      <div id="delete-status" class="text-sm mb-3 hidden"></div>
      <div class="flex justify-end gap-2">
        <button id="delete-cancel" class="px-4 py-2 rounded-lg text-sm text-black/70 dark:text-white/70 hover:bg-black/5 dark:hover:bg-white/10 transition cursor-pointer">取消</button>
        <button id="delete-confirm" class="px-5 py-2 rounded-lg bg-red-500 text-white text-sm font-medium hover:bg-red-600 transition cursor-pointer">确认删除</button>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ albumId: albumMeta.id }}>
    // ===== 事件委托：打开/关闭弹窗 =====
    // 不用 data-swup-reload-script（不可靠），改用 swup:content:replaced 事件
    function setupAlbumDelegate() {
      if (window.__albumBtnAC) window.__albumBtnAC.abort();
      window.__albumBtnAC = new AbortController();
