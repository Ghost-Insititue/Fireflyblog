          await modifyGalleryConfig(token, repo, 'edit', {
            oldId: document.getElementById('btn-edit-album').dataset.albumId, newId, name: newName, description: newDesc, location: newLocation, date: newDate, tags: newTags, password: newPwd, passwordHint: newHint, cover: coverPath
          });

