---
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { siteConfig } from "@/config";
---

<MainGridLayout title="写文章" description="在线 Markdown 编辑器">
  <div class="w-full mb-4">
    <!-- 编辑器主容器 -->
    <div id="editor-app" class="card-base overflow-hidden rounded-(--radius-large)">
      
      <!-- ========== 元数据表单 ========== -->
      <div id="meta-panel" class="border-b border-[var(--line-divider)] px-6 py-5 space-y-4 bg-transparent">
        <div class="flex items-center gap-3 mb-2">
          <div class="h-8 w-8 rounded-lg bg-[var(--primary)] flex items-center justify-center text-white dark:text-black/70">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04a1 1 0 0 0 0-1.41l-2.34-2.34a1 1 0 0 0-1.41 0l-1.83 1.83l3.75 3.75l1.83-1.83z"/></svg>
          </div>
          <h2 class="text-lg font-bold text-black/90 dark:text-white/90">文章信息</h2>
          <button id="toggle-meta" class="ml-auto text-sm text-[var(--primary)] hover:underline cursor-pointer">收起 ▲</button>
        </div>

        <div id="meta-fields" class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <!-- 标题 -->
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-black/70 dark:text-white/70 mb-1">标题 <span class="text-red-500">*</span></label>
            <div class="flex gap-2">
              <input id="post-title" type="text" placeholder="请输入文章标题"
                class="flex-1 px-4 py-2.5 rounded-lg border border-[var(--line-divider)] bg-transparent text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50 transition" />
              <button id="btn-pinned" type="button" class="toggle-btn" title="置顶">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 17v5"/><path d="M9 10.76a2 2 0 01-1.11 1.79l-1.78.9A2 2 0 005 15.24V16a1 1 0 001 1h12a1 1 0 001-1v-.76a2 2 0 00-1.11-1.79l-1.78-.9A2 2 0 0115 10.76V7a1 1 0 011-1 1 1 0 001-1V4a2 2 0 00-2-2H9a2 2 0 00-2 2v1a1 1 0 001 1 1 1 0 011 1z"/></svg>
                置顶
              </button>
              <button id="btn-comment" type="button" class="toggle-btn active" title="评论">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
                评论
              </button>
              <input id="post-pinned" type="hidden" value="false" />
              <input id="post-comment" type="hidden" value="true" />
            </div>
          </div>

          <!-- 描述 -->
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-black/70 dark:text-white/70 mb-1">描述</label>
            <input id="post-desc" type="text" placeholder="一句话描述文章内容（可选）"
              class="w-full px-4 py-2.5 rounded-lg border border-[var(--line-divider)] bg-transparent text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50 transition" />
          </div>

          <!-- 分类 -->
          <div>
            <label class="block text-sm font-medium text-black/70 dark:text-white/70 mb-1">分类</label>
            <input id="post-category" type="text" placeholder="如：技术笔记"
              class="w-full px-4 py-2.5 rounded-lg border border-[var(--line-divider)] bg-transparent text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50 transition" />
          </div>

          <!-- 标签 -->
          <div>
            <label class="block text-sm font-medium text-black/70 dark:text-white/70 mb-1">标签 <span class="text-xs text-black/40 dark:text-white/40">（逗号分隔）</span></label>
            <input id="post-tags" type="text" placeholder="如：JavaScript, Astro, 博客"
              class="w-full px-4 py-2.5 rounded-lg border border-[var(--line-divider)] bg-transparent text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50 transition" />
          </div>

          <!-- 封面图 -->
          <div>
            <label class="block text-sm font-medium text-black/70 dark:text-white/70 mb-1">封面图 URL</label>
            <div class="flex gap-2">
              <input id="post-cover" type="text" placeholder="https://... 或留空"
                class="flex-1 px-4 py-2.5 rounded-lg border border-[var(--line-divider)] bg-transparent text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50 transition" />
              <label class="px-3 py-2.5 rounded-lg border border-[var(--line-divider)] text-sm text-black/60 dark:text-white/60 hover:border-[var(--primary)]/40 hover:text-[var(--primary)]/70 transition cursor-pointer flex items-center gap-1.5 whitespace-nowrap" title="上传本地图片">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                上传
                <input id="cover-upload" type="file" accept="image/*" class="hidden" />
              </label>
            </div>
          </div>

          <!-- 文章密码 + 密码提示 -->
          <div>
            <label class="block text-sm font-medium text-black/70 dark:text-white/70 mb-1">文章密码 <span class="text-xs text-black/40 dark:text-white/40">（加密文章用）</span></label>
            <div class="flex gap-2">
              <input id="post-password-hint" type="text" placeholder="密码提示"
                class="w-1/3 px-4 py-2.5 rounded-lg border border-[var(--line-divider)] bg-transparent text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50 transition" />
              <input id="post-password" type="text" placeholder="输入密码，留空不加密"
                class="flex-1 px-4 py-2.5 rounded-lg border border-[var(--line-divider)] bg-transparent text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50 transition" />
            </div>
          </div>
        </div>
      </div>

      <!-- ========== 工具栏 ========== -->
      <div id="toolbar" class="flex flex-nowrap items-center gap-0.5 px-3 py-1.5 border-b border-[var(--line-divider)] bg-transparent sticky top-0 z-20 overflow-x-auto">
        <!-- 文本格式 -->
        <button data-action="bold" title="加粗 (Ctrl+B)" class="toolbar-btn">
          <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M13.5 4H7v16h7.5c2.5 0 4.5-2 4.5-4.5c0-1.57-.8-2.96-2.01-3.77C18.16 10.77 19 9.38 19 7.5C19 5.57 17.43 4 15.5 4zm0 2c.83 0 1.5.67 1.5 1.5S14.33 9 13.5 9H9V6h4.5zm0 6c.83 0 1.5.67 1.5 1.5s-.67 1.5-1.5 1.5H9v-3h4.5z"/></svg>
        </button>
        <button data-action="italic" title="斜体 (Ctrl+I)" class="toolbar-btn">
          <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M10 5v3h2.21l-3.42 8H6v3h8v-3h-2.21l3.42-8H18V5z"/></svg>
        </button>
        <button data-action="strikethrough" title="删除线" class="toolbar-btn">
          <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M10 19h4v-3h-4v3zM5 4v3h5v3h4V7h5V4H5zM3 14h18v-2H3v2z"/></svg>
        </button>

        <div class="w-px h-4 bg-[var(--line-divider)] mx-0.5"></div>

        <!-- 标题 -->
        <button data-action="h1" title="一级标题" class="toolbar-btn text-xs font-bold">H1</button>
        <button data-action="h2" title="二级标题" class="toolbar-btn text-xs font-bold">H2</button>
        <button data-action="h3" title="三级标题" class="toolbar-btn text-xs font-bold">H3</button>
        <button data-action="h4" title="四级标题" class="toolbar-btn text-xs font-bold">H4</button>

        <div class="w-px h-4 bg-[var(--line-divider)] mx-0.5"></div>

        <!-- 列表 -->
        <button data-action="ul" title="无序列表" class="toolbar-btn">
          <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M4 10.5c-.83 0-1.5.67-1.5 1.5s.67 1.5 1.5 1.5s1.5-.67 1.5-1.5s-.67-1.5-1.5-1.5zm0-6c-.83 0-1.5.67-1.5 1.5S3.17 7.5 4 7.5S5.5 6.83 5.5 6S4.83 4.5 4 4.5zm0 12c-.83 0-1.5.68-1.5 1.5s.68 1.5 1.5 1.5s1.5-.68 1.5-1.5s-.67-1.5-1.5-1.5zM7 19h14v-2H7v2zm0-6h14v-2H7v2zm0-8v2h14V5H7z"/></svg>
        </button>
        <button data-action="ol" title="有序列表" class="toolbar-btn">
          <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M2 17h2v.5H3v1h1v.5H2v1h3v-4H2v1zm1-9h1V4H2v1h1v3zm-1 3h1.8L2 13.1v.9h3v-1H3.2L5 10.9V10H2v1zm5-6v2h14V5H7zm0 14h14v-2H7v2zm0-6h14v-2H7v2z"/></svg>
        </button>
        <button data-action="checklist" title="任务列表" class="toolbar-btn">
          <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M3 5h2v14H3V5zm4 0v2h12V7H7zm0 4v2h12v-2H7zm0 4v2h12v-2H7zm-4 3l3-3l1.5 1.5L5 18.5L2.5 16L4 14.5z"/></svg>
        </button>

        <div class="w-px h-4 bg-[var(--line-divider)] mx-0.5"></div>

        <!-- 引用 & 代码 -->
        <button data-action="quote" title="引用" class="toolbar-btn">
          <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"/></svg>
        </button>
        <button data-action="code" title="行内代码" class="toolbar-btn">
          <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6l6 6l1.4-1.4zm5.2 0l4.6-4.6l-4.6-4.6L16 6l6 6l-6 6l-1.4-1.4z"/></svg>
        </button>
        <button data-action="codeblock" title="代码块" class="toolbar-btn">
          <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 14H4V8h16v12zm-8-2h4v-2h-4v2zm-6-6h2v2H6v-2zm0 4h2v2H6v-2zm0 4h12v2H6v-2z"/></svg>
        </button>

        <div class="w-px h-4 bg-[var(--line-divider)] mx-0.5"></div>

        <!-- 链接 & 媒体 -->
        <button data-action="link" title="链接 (Ctrl+K)" class="toolbar-btn">
          <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z"/></svg>
        </button>
        <button data-action="image" title="图片" class="toolbar-btn">
          <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
        </button>
        <button data-action="table" title="表格" class="toolbar-btn">
          <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M3 3v18h18V3H3zm8 16H5v-6h6v6zm0-8H5V5h6v6zm8 8h-6v-6h6v6zm0-8h-6V5h6v6z"/></svg>
        </button>
        <button data-action="hr" title="分割线" class="toolbar-btn">
          <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M2 11h20v2H2z"/></svg>
        </button>

        <div class="w-px h-4 bg-[var(--line-divider)] mx-0.5"></div>

        <!-- 撤销/重做 -->
        <button data-action="undo" title="撤销 (Ctrl+Z)" class="toolbar-btn">
          <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M12.5 8c-2.65 0-5.05.99-6.9 2.6L2 7v9h9l-3.62-3.62c1.39-1.16 3.16-1.88 5.12-1.88c3.54 0 6.55 2.31 7.6 5.5l2.37-.78C21.08 11.03 17.15 8 12.5 8z"/></svg>
        </button>
        <button data-action="redo" title="重做 (Ctrl+Y)" class="toolbar-btn">
          <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M18.4 10.6C16.55 8.99 14.15 8 11.5 8c-4.65 0-8.58 3.03-9.96 7.22L3.9 16c1.05-3.19 4.05-5.5 7.6-5.5c1.95 0 3.73.72 5.12 1.88L13 16h9V7l-3.6 3.6z"/></svg>
        </button>

        <div class="flex-1"></div>

        <button id="btn-download" title="下载 .md" class="toolbar-btn text-xs">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          下载
        </button>
        <button id="btn-github" title="发布到 GitHub" class="toolbar-btn text-xs text-[var(--primary)] font-medium">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          发布
        </button>
      </div>

      <!-- 第二行：视图切换 + 操作 -->
      <div class="flex flex-nowrap items-center gap-0.5 px-3 py-1 border-b border-[var(--line-divider)] bg-transparent overflow-x-auto">
        <button id="btn-view-editor" title="仅编辑" class="toolbar-btn text-xs">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          编辑
        </button>
        <button id="btn-view-split" title="分栏" class="toolbar-btn text-xs active">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="12" y1="3" x2="12" y2="21"/></svg>
          分栏
        </button>
        <button id="btn-view-preview" title="仅预览" class="toolbar-btn text-xs">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          预览
        </button>
        <button id="btn-preview-full" title="全屏预览" class="toolbar-btn text-xs">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>
          全屏
        </button>

        <div class="w-px h-4 bg-[var(--line-divider)] mx-0.5"></div>

        <button id="btn-sync-scroll" title="同步滚动" class="toolbar-btn text-xs active">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 4v16"/><path d="M17 4v16"/><path d="M4 8h16"/><path d="M4 16h16"/></svg>
          同步
        </button>

        <div class="flex-1"></div>

        <button id="btn-copy" title="复制内容" class="toolbar-btn text-xs">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
          复制
        </button>
        <button id="btn-quick-save" title="保存草稿 (Ctrl+Shift+S)" class="toolbar-btn text-xs">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
          保存
        </button>
        <button id="btn-drafts" title="草稿箱" class="toolbar-btn text-xs">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          草稿
        </button>
      </div>

      <!-- ========== 编辑器主体 ========== -->
      <div id="editor-body" class="flex" style="height: calc(100vh - 280px); min-height: 400px;">
        <!-- 左侧：Markdown 输入 -->
        <div id="editor-pane" class="flex-1 flex flex-col border-r border-[var(--line-divider)]">
          <textarea id="markdown-input" 
            class="flex-1 w-full resize-none p-5 text-sm font-mono bg-transparent text-black/90 dark:text-white/90 focus:outline-none placeholder:text-black/30 dark:placeholder:text-white/30"
            style="line-height: 1.75;"
            placeholder="开始写作吧...&#10;&#10;支持完整的 Markdown 语法：&#10;- **加粗** 和 *斜体*&#10;- # 标题&#10;- ```代码块```&#10;- > 引用&#10;- [链接](url)&#10;- ![图片](url)"
            spellcheck="false"
          ></textarea>
        </div>

        <!-- 右侧：预览 -->
        <div id="preview-pane" class="flex-1 flex flex-col overflow-hidden">
          <div id="preview-content" class="flex-1 overflow-y-auto p-5 markdown-content prose prose-sm dark:prose-invert max-w-none">
            <div class="text-black/30 dark:text-white/30 text-sm italic">预览区域 — 在左侧输入 Markdown 即可实时预览</div>
          </div>
        </div>
      </div>

      <!-- ========== 底部操作栏 ========== -->
      <div class="flex items-center px-6 py-3 border-t border-[var(--line-divider)] bg-transparent">
        <div class="flex items-center gap-4 text-sm text-black/50 dark:text-white/50">
          <span id="word-count">0 字</span>
          <span id="char-count">0 字符</span>
          <span id="line-count">0 行</span>
        </div>
      </div>
    </div>

    <!-- GitHub 发布弹窗 -->
    <div id="github-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 hidden">
      <div class="rounded-2xl p-6 shadow-2xl bg-white dark:bg-neutral-900 border border-[var(--line-divider)]" style="width: 420px;">
        <h3 class="text-base font-bold text-black/90 dark:text-white/90 mb-4">发布到 GitHub</h3>
        <div class="space-y-3">
          <div>
            <label class="block text-xs font-medium text-black/60 dark:text-white/60 mb-1.5">GitHub Token</label>
            <input id="gh-token" type="password" placeholder="ghp_xxxxx"
