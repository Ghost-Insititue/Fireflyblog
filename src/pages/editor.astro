  <!-- highlight.js 语法高亮主题 -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.9.0/build/styles/atom-one-dark.min.css">

  <!-- 样式 -->
  <style>
    @reference "../styles/main.css";

    .toolbar-btn {
      @apply px-2 py-1 rounded-md text-black/60 dark:text-white/60 hover:bg-black/5 dark:hover:bg-white/10 hover:text-black/90 dark:hover:text-white/90 transition cursor-pointer flex items-center justify-center text-sm;
    }
    .toolbar-btn svg {
      width: 18px;
      height: 18px;
    }
    .toolbar-btn.active {
      @apply bg-[var(--primary)]/15 text-[var(--primary)];
    }
    /* 切换按钮（置顶/评论） */
    .toggle-btn {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 10px 12px;
      border-radius: 0.5rem;
      border: 1px solid var(--line-divider);
      font-size: 0.875rem;
      color: color-mix(in srgb, currentColor 50%, transparent);
      cursor: pointer;
      transition: all 0.15s;
      white-space: nowrap;
      user-select: none;
      background: transparent;
    }
    .toggle-btn:hover {
      border-color: color-mix(in srgb, var(--primary) 40%, transparent);
      color: color-mix(in srgb, var(--primary) 70%, transparent);
    }
    .toggle-btn.active {
      border-color: var(--primary);
      background: color-mix(in srgb, var(--primary) 10%, transparent);
      color: var(--primary);
    }
    #markdown-input:focus {
      box-shadow: inset 0 0 0 2px var(--primary);
    }
    #markdown-input.drag-over {
      box-shadow: inset 0 0 0 3px var(--primary), inset 0 0 30px color-mix(in srgb, var(--primary) 10%, transparent);
      background: color-mix(in srgb, var(--primary) 3%, transparent);
    }
    /* 预览区代码样式 */
    #preview-content :where(code):not(:where([class~="not-prose"] *)) {
      @apply bg-black/5 dark:bg-white/10 px-1.5 py-0.5 rounded text-sm;
    }
    #preview-content :where(pre):not(:where([class~="not-prose"] *)) {
      @apply bg-black/5 dark:bg-white/10 p-4 rounded-lg overflow-x-auto;
    }
    #preview-content :where(pre code):not(:where([class~="not-prose"] *)) {
      @apply bg-transparent p-0;
    }
    #preview-content :where(blockquote):not(:where([class~="not-prose"] *)) {
      @apply border-l-4 border-[var(--primary)] pl-4 italic text-black/70 dark:text-white/70;
    }
    #preview-content :where(table):not(:where([class~="not-prose"] *)) {
      @apply w-full border-collapse;
    }
    #preview-content :where(th):not(:where([class~="not-prose"] *)) {
      @apply bg-black/5 dark:bg-white/10 px-3 py-2 text-left font-semibold border border-[var(--line-divider)];
    }
    #preview-content :where(td):not(:where([class~="not-prose"] *)) {
      @apply px-3 py-2 border border-[var(--line-divider)];
    }
    #preview-content :where(img):not(:where([class~="not-prose"] *)) {
      @apply rounded-lg max-w-full;
    }
    #preview-content :where(h1,h2,h3,h4,h5,h6):not(:where([class~="not-prose"] *)) {
      @apply font-bold mt-6 mb-3 text-black/90 dark:text-white/90;
    }
    #preview-content :where(h1):not(:where([class~="not-prose"] *)) { @apply text-3xl; }
    #preview-content :where(h2):not(:where([class~="not-prose"] *)) { @apply text-2xl; }
    #preview-content :where(h3):not(:where([class~="not-prose"] *)) { @apply text-xl; }
    #preview-content :where(ul):not(:where([class~="not-prose"] *)) { @apply list-disc pl-6 my-2; }
    #preview-content :where(ol):not(:where([class~="not-prose"] *)) { @apply list-decimal pl-6 my-2; }
    #preview-content :where(li):not(:where([class~="not-prose"] *)) { @apply my-1; }
    #preview-content :where(a):not(:where([class~="not-prose"] *)) { @apply text-[var(--primary)] underline; }
    #preview-content :where(hr):not(:where([class~="not-prose"] *)) { @apply border-t border-[var(--line-divider)] my-6; }
    #preview-content :where(.task-list-item):not(:where([class~="not-prose"] *)) { @apply list-none; }
    #preview-content :where(.task-list-item input):not(:where([class~="not-prose"] *)) { @apply mr-2; }

    /* #1 移动端响应式：小屏编辑器高度自适应，元数据默认收起 */
    @media (max-width: 768px) {
      #editor-body { height: calc(100vh - 140px) !important; min-height: 280px !important; }
      #meta-fields { display: none; }
    }
  </style>

  <!-- 脚本 -->
  <script is:inline>
    // ===== 加载 marked (CDN) =====
    (function loadScript(src) {
      return new Promise((resolve, reject) => {
        if (document.querySelector(`script[src="${src}"]`)) { resolve(); return; }
        const s = document.createElement('script');
        s.src = src;
        s.onload = resolve;
        s.onerror = reject;
        document.head.appendChild(s);
      });
    })('https://cdn.jsdelivr.net/npm/marked/marked.min.js').then(() => {
      // marked 加载完后再加载 highlight.js
      (function loadHljs(src) {
        return new Promise((resolve) => {
          if (document.querySelector(`script[src="${src}"]`)) { resolve(); return; }
          const s = document.createElement('script');
          s.src = src;
          s.onload = resolve;
          s.onerror = resolve;
          document.head.appendChild(s);
        });
      })('https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.9.0/build/highlight.min.js').then(() => initEditor());
    }).catch(() => {
      return loadScript('https://unpkg.com/marked/marked.min.js').then(() => initEditor());
    });

    function initEditor() {
      const textarea = document.getElementById('markdown-input');
      const preview = document.getElementById('preview-content');
      const fullscreenContent = document.getElementById('fullscreen-content');

      // ===== marked 配置 =====
      if (typeof marked !== 'undefined') {
        const renderer = new marked.Renderer();
        renderer.code = function(obj) {
          const code = typeof obj === 'object' ? obj.text : obj;
          const lang = typeof obj === 'object' ? obj.lang : arguments[1];
          let highlighted = code;
          if (typeof hljs !== 'undefined') {
            if (lang && hljs.getLanguage(lang)) {
              try { highlighted = hljs.highlight(code, { language: lang }).value; } catch(e) {}
            } else {
              try { highlighted = hljs.highlightAuto(code).value; } catch(e) {}
            }
          }
          const cls = lang ? ` class="hljs language-${lang}"` : ' class="hljs"';
          return `<pre><code${cls}>${highlighted}</code></pre>`;
        };
        marked.setOptions({
          breaks: true,
          gfm: true,
          renderer: renderer,
        });
      }

      // ===== 实时预览 =====
      let previewTimer = null;
      function updatePreview() {
        clearTimeout(previewTimer);
        previewTimer = setTimeout(() => {
          const md = textarea.value;
          let html = '';
          try {
            html = (typeof marked !== 'undefined') ? marked.parse(md) : md.replace(/\n/g, '<br>');
          } catch(e) {
            html = '<p style="color:red">渲染错误: ' + e.message + '</p>';
          }
          preview.innerHTML = html || '<div class="text-black/30 dark:text-white/30 text-sm italic">预览区域 — 在左侧输入 Markdown 即可实时预览</div>';
          updateCounts(md);
        }, 150);
      }

      function updateCounts(text) {
        const lines = text.split('\n').length;
        const chars = text.length;
        // 简单中文词数统计
        const cjk = (text.match(/[\u4e00-\u9fff\u3400-\u4dbf]/g) || []).length;
        const words = (text.match(/[a-zA-Z]+/g) || []).length;
        const total = cjk + words;
        document.getElementById('word-count').textContent = total + ' 词';
        document.getElementById('char-count').textContent = chars + ' 字符';
        document.getElementById('line-count').textContent = lines + ' 行';
      }

      textarea.addEventListener('input', updatePreview);

      // ===== #4 自动保存 (每30秒) =====
      const AUTOSAVE_KEY = 'editor-autosave-draft';
      function saveDraft() {
        const data = {
          content: textarea.value,
          title: document.getElementById('post-title').value,
          desc: document.getElementById('post-desc').value,
          category: document.getElementById('post-category').value,
          tags: document.getElementById('post-tags').value,
          cover: document.getElementById('post-cover').value,
          password: document.getElementById('post-password').value,
          passwordHint: document.getElementById('post-password-hint').value,
          pinned: document.getElementById('post-pinned').value === 'true',
          comment: document.getElementById('post-comment').value === 'true',
          savedAt: new Date().toISOString(),
        };
        try { localStorage.setItem(AUTOSAVE_KEY, JSON.stringify(data)); } catch(e) {}
      }
      function restoreDraftData(data) {
        textarea.value = data.content || '';
        document.getElementById('post-title').value = data.title || '';
        document.getElementById('post-desc').value = data.desc || '';
        document.getElementById('post-category').value = data.category || '';
        document.getElementById('post-tags').value = data.tags || '';
        document.getElementById('post-cover').value = data.cover || '';
        document.getElementById('post-password').value = data.password || '';
        document.getElementById('post-password-hint').value = data.passwordHint || '';
        setToggle('btn-pinned', 'post-pinned', data.pinned || false);
        setToggle('btn-comment', 'post-comment', data.comment !== false);
        updatePreview();
      }

      function loadDraft() {
        try {
          const raw = localStorage.getItem(AUTOSAVE_KEY);
          if (!raw) return;
          const data = JSON.parse(raw);
          if (!data.content && !data.title) return;
          // 用自定义提示条代替 confirm()，避免 Chrome 拦截后台弹窗
          const bar = document.createElement('div');
          bar.className = 'flex items-center justify-between px-4 py-2.5 border-b border-[var(--line-divider)] bg-[var(--primary)]/5 text-sm';
          bar.innerHTML = `<span>📋 发现自动保存的草稿（${new Date(data.savedAt).toLocaleString()}）</span>`;
          const btnGroup = document.createElement('div');
          btnGroup.className = 'flex gap-2';
          const btnYes = document.createElement('button');
          btnYes.textContent = '恢复';
          btnYes.className = 'px-3 py-1 rounded bg-[var(--primary)] text-white dark:text-black/80 text-sm cursor-pointer';
          const btnNo = document.createElement('button');
          btnNo.textContent = '忽略';
          btnNo.className = 'px-3 py-1 rounded text-sm text-black/60 dark:text-white/60 hover:bg-black/5 dark:hover:bg-white/10 cursor-pointer';
          btnYes.onclick = () => { restoreDraftData(data); bar.remove(); };
          btnNo.onclick = () => { bar.remove(); };
          btnGroup.appendChild(btnYes);
          btnGroup.appendChild(btnNo);
          bar.appendChild(btnGroup);
          document.getElementById('editor-app').prepend(bar);
        } catch(e) {}
      }
      setInterval(saveDraft, 30000);
      loadDraft();

      // ===== #3 图片拖拽/粘贴上传 =====
      function insertTextAtCursor(text) {
        const start = textarea.selectionStart;
        textarea.setRangeText(text, start, start, 'end');
        textarea.focus();
        updatePreview();
      }

      function showUploadStatus(msg, type) {
        // 在工具栏下方显示临时提示
        let bar = document.getElementById('upload-status-bar');
        if (!bar) {
          bar = document.createElement('div');
          bar.id = 'upload-status-bar';
          bar.className = 'text-sm px-4 py-2 border-b border-[var(--line-divider)]';
          document.getElementById('toolbar').after(bar);
        }
        bar.className = 'text-sm px-4 py-2 border-b border-[var(--line-divider)] ' +
          (type === 'error' ? 'text-red-500 bg-red-50 dark:bg-red-900/20' :
           type === 'success' ? 'text-green-500 bg-green-50 dark:bg-green-900/20' :
           'text-blue-500 bg-blue-50 dark:bg-blue-900/20');
        bar.textContent = msg;
        if (type !== 'uploading') {
          setTimeout(() => { bar.remove(); }, 3000);
        }
      }

      async function uploadImage(file) {
        showUploadStatus('⏳ 正在上传图片...', 'uploading');
        try {
          const url = await uploadToGitHub(file);
          if (url) {
            insertTextAtCursor(`![${file.name}](${url})`);
            showUploadStatus(`✓ 上传成功：${file.name}`, 'success');
          }
        } catch (e) {
          showUploadStatus(`❌ ${e.message}`, 'error');
        }
      }

      function handleImageFiles(files) {
        for (const file of files) {
          if (file.type.startsWith('image/')) {
            uploadImage(file);
          }
        }
      }

      // 粘贴事件
      textarea.addEventListener('paste', (e) => {
        const items = e.clipboardData?.items;
        if (!items) return;
        const imageFiles = [];
        for (const item of items) {
          if (item.type.startsWith('image/')) {
            const file = item.getAsFile();
            if (file) imageFiles.push(file);
          }
        }
        if (imageFiles.length > 0) {
          e.preventDefault();
          handleImageFiles(imageFiles);
        }
      });

      // 拖拽事件
      textarea.addEventListener('dragover', (e) => {
        e.preventDefault();
        textarea.classList.add('drag-over');
      });
      textarea.addEventListener('dragleave', () => {
        textarea.classList.remove('drag-over');
      });
      textarea.addEventListener('drop', (e) => {
        e.preventDefault();
        textarea.classList.remove('drag-over');
        if (e.dataTransfer?.files.length) {
          handleImageFiles(e.dataTransfer.files);
        }
      });

      // ===== 工具栏操作 =====
      function surroundSelection(before, after) {
        const start = textarea.selectionStart;
        const end = textarea.selectionEnd;
        const selected = textarea.value.substring(start, end);
        const replacement = before + (selected || '文本') + (after || before);
        textarea.setRangeText(replacement, start, end, 'select');
        textarea.focus();
        updatePreview();
      }

      function prefixLine(prefix) {
        const start = textarea.selectionStart;
        const lineStart = textarea.value.lastIndexOf('\n', start - 1) + 1;
        textarea.setRangeText(prefix, lineStart, lineStart, 'end');
        textarea.focus();
        updatePreview();
      }

      const actions = {
        bold: () => surroundSelection('**'),
        italic: () => surroundSelection('*'),
        strikethrough: () => surroundSelection('~~'),
        h1: () => prefixLine('# '),
        h2: () => prefixLine('## '),
        h3: () => prefixLine('### '),
        h4: () => prefixLine('#### '),
        ul: () => prefixLine('- '),
        ol: () => prefixLine('1. '),
        checklist: () => prefixLine('- [ ] '),
        quote: () => prefixLine('> '),
        code: () => surroundSelection('`'),
        codeblock: () => surroundSelection('```\n', '\n```'),
        link: () => {
          document.getElementById('link-modal').classList.remove('hidden');
          document.getElementById('link-text-input').value = textarea.value.substring(textarea.selectionStart, textarea.selectionEnd) || '';
          document.getElementById('link-url-input').value = '';
          document.getElementById('link-url-input').focus();
        },
        image: () => {
          document.getElementById('image-modal').classList.remove('hidden');
          document.getElementById('img-url-input').value = '';
          document.getElementById('img-file-input').value = '';
          document.getElementById('img-preview').classList.add('hidden');
          document.getElementById('img-status').className = 'text-sm hidden';
          document.getElementById('img-status').textContent = '';
          document.getElementById('img-url-input').focus();
        },
        table: () => {
          const table = '\n| 列1 | 列2 | 列3 |\n| --- | --- | --- |\n| 内容 | 内容 | 内容 |\n';
          const start = textarea.selectionStart;
          textarea.setRangeText(table, start, start, 'end');
          textarea.focus();
          updatePreview();
        },
        hr: () => {
          const start = textarea.selectionStart;
          textarea.setRangeText('\n---\n', start, start, 'end');
          textarea.focus();
          updatePreview();
        },
        undo: () => document.execCommand('undo'),
        redo: () => document.execCommand('redo'),
      };

      document.querySelectorAll('[data-action]').forEach(btn => {
        btn.addEventListener('click', () => {
          const action = actions[btn.dataset.action];
          if (action) action();
        });
      });

      // ===== 快捷键 =====
      textarea.addEventListener('keydown', (e) => {
        if (e.ctrlKey || e.metaKey) {
          switch(e.key.toLowerCase()) {
            case 'b': e.preventDefault(); actions.bold(); break;
            case 'i': e.preventDefault(); actions.italic(); break;
            case 'k': e.preventDefault(); actions.link(); break;
            case 'z': if (!e.shiftKey) {} break; // 默认行为
            case 's': if (e.shiftKey) { e.preventDefault(); document.getElementById('btn-quick-save').click(); } else { e.preventDefault(); document.getElementById('btn-download').click(); } break;
          }
        }
        // Tab 缩进
        if (e.key === 'Tab') {
          e.preventDefault();
          const start = textarea.selectionStart;
          textarea.setRangeText('  ', start, start, 'end');
          updatePreview();
        }
      });

      // ===== 置顶/评论切换按钮 =====
      function setupToggle(btnId, hiddenId, defaultActive) {
        const btn = document.getElementById(btnId);
        const hidden = document.getElementById(hiddenId);
        if (defaultActive) btn.classList.add('active');
        hidden.value = defaultActive ? 'true' : 'false';
        btn.addEventListener('click', () => {
          btn.classList.toggle('active');
          hidden.value = btn.classList.contains('active') ? 'true' : 'false';
        });
      }
      function setToggle(btnId, hiddenId, active) {
        const btn = document.getElementById(btnId);
        const hidden = document.getElementById(hiddenId);
        btn.classList.toggle('active', active);
        hidden.value = active ? 'true' : 'false';
      }
      setupToggle('btn-pinned', 'post-pinned', false);
      setupToggle('btn-comment', 'post-comment', true);

      // ===== 视图切换 =====
      const editorPane = document.getElementById('editor-pane');
      const previewPane = document.getElementById('preview-pane');
      const viewBtns = { editor: document.getElementById('btn-view-editor'), split: document.getElementById('btn-view-split'), preview: document.getElementById('btn-view-preview') };

      function setView(mode) {
        Object.values(viewBtns).forEach(b => b.classList.remove('active'));
        viewBtns[mode].classList.add('active');
        if (mode === 'editor') {
          editorPane.style.display = 'flex';
          previewPane.style.display = 'none';
        } else if (mode === 'preview') {
          editorPane.style.display = 'none';
          previewPane.style.display = 'flex';
        } else {
          editorPane.style.display = 'flex';
          previewPane.style.display = 'flex';
        }
      }

      viewBtns.editor.addEventListener('click', () => setView('editor'));
      viewBtns.split.addEventListener('click', () => setView('split'));
      viewBtns.preview.addEventListener('click', () => setView('preview'));

      // ===== 同步滚动 =====
      let syncScrollEnabled = true;
      let isSyncing = false;
      const btnSyncScroll = document.getElementById('btn-sync-scroll');
      const previewContent = document.getElementById('preview-content');

      function syncScroll(source, target) {
        if (!syncScrollEnabled || isSyncing) return;
        const maxScroll = source.scrollHeight - source.clientHeight;
        if (maxScroll <= 0) return;
        isSyncing = true;
        const ratio = source.scrollTop / maxScroll;
        const targetMax = target.scrollHeight - target.clientHeight;
        target.scrollTop = ratio * targetMax;
        requestAnimationFrame(() => { isSyncing = false; });
      }

      textarea.addEventListener('scroll', () => syncScroll(textarea, previewContent));
      previewContent.addEventListener('scroll', () => syncScroll(previewContent, textarea));

      btnSyncScroll.addEventListener('click', () => {
        syncScrollEnabled = !syncScrollEnabled;
        btnSyncScroll.classList.toggle('active', syncScrollEnabled);
      });

      // ===== 元数据面板折叠 =====
      const metaFields = document.getElementById('meta-fields');
      const toggleBtn = document.getElementById('toggle-meta');
      // 移动端初始状态：CSS 已隐藏，修正按钮文字
      if (getComputedStyle(metaFields).display === 'none') {
        toggleBtn.textContent = '展开 ▼';
      }
      toggleBtn.addEventListener('click', () => {
        if (getComputedStyle(metaFields).display === 'none') {
          metaFields.style.display = 'grid';
          toggleBtn.textContent = '收起 ▲';
        } else {
          metaFields.style.display = 'none';
          toggleBtn.textContent = '展开 ▼';
        }
      });

      // ===== 生成 frontmatter =====
      function generateFrontmatter() {
        const title = document.getElementById('post-title').value || '未命名文章';
        const desc = document.getElementById('post-desc').value;
        const category = document.getElementById('post-category').value;
        const tags = document.getElementById('post-tags').value;
        const cover = document.getElementById('post-cover').value;
        const password = document.getElementById('post-password').value;
        const passwordHint = document.getElementById('post-password-hint').value;
        const pinned = document.getElementById('post-pinned').value === 'true';
        const comment = document.getElementById('post-comment').value === 'true';
        const now = new Date().toISOString().split('T')[0];

        let fm = '---\n';
        fm += `title: "${title}"\n`;
        fm += `published: ${now}\n`;
        if (desc) fm += `description: "${desc}"\n`;
        if (tags) {
          const tagList = tags.split(/[,，]/).map(t => t.trim()).filter(Boolean);
          fm += `tags: [${tagList.map(t => `"${t}"`).join(', ')}]\n`;
        }
        if (category) fm += `category: "${category}"\n`;
        if (cover) fm += `image: "${cover}"\n`;
        if (password) fm += `password: "${password}"\n`;
        if (passwordHint) fm += `passwordHint: "${passwordHint}"\n`;
        if (pinned) fm += `pinned: true\n`;
        if (!comment) fm += `comment: false\n`;
        fm += 'draft: false\n';
        fm += '---\n\n';
        return fm;
      }

      function getFullMarkdown() {
        return generateFrontmatter() + textarea.value;
      }

      function getFilename() {
        const title = document.getElementById('post-title').value || 'untitled';
        const slug = title.toLowerCase()
          .replace(/[\u4e00-\u9fff]+/g, m => m) // 保留中文
          .replace(/[^\w\u4e00-\u9fff]+/g, '-')
          .replace(/^-|-$/g, '');
        return slug + '.md';
      }

      // ===== 下载 =====
      document.getElementById('btn-download').addEventListener('click', () => {
        const blob = new Blob([getFullMarkdown()], { type: 'text/markdown' });
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = getFilename();
        a.click();
        URL.revokeObjectURL(a.href);
      });

      // ===== 复制 =====
      document.getElementById('btn-copy').addEventListener('click', async () => {
        const btn = document.getElementById('btn-copy');
        const orig = btn.innerHTML;
        try {
          await navigator.clipboard.writeText(getFullMarkdown());
          btn.innerHTML = '✓ 已复制';
          setTimeout(() => btn.innerHTML = orig, 2000);
        } catch {
          btn.innerHTML = orig;
          alert('复制失败，请手动复制');
        }
      });

      // ===== 全屏预览 =====
      document.getElementById('btn-preview-full').addEventListener('click', () => {
        const fs = document.getElementById('fullscreen-preview');
        fs.classList.remove('hidden');
        fullscreenContent.innerHTML = preview.innerHTML;
      });
      document.getElementById('close-preview').addEventListener('click', () => {
        document.getElementById('fullscreen-preview').classList.add('hidden');
      });

      // ===== GitHub 发布 =====
      document.getElementById('btn-github').addEventListener('click', () => {
        const modal = document.getElementById('github-modal');
        modal.classList.remove('hidden');
        // 清空上次状态
        const status = document.getElementById('gh-status');
        status.className = 'text-sm hidden';
        status.textContent = '';
        // 尝试从 localStorage 恢复
        const saved = localStorage.getItem('gh-editor-token');
        if (saved) document.getElementById('gh-token').value = saved;
        const savedRepo = localStorage.getItem('gh-editor-repo');
        if (savedRepo) document.getElementById('gh-repo').value = savedRepo;
      });

      document.getElementById('gh-cancel').addEventListener('click', () => {
        document.getElementById('github-modal').classList.add('hidden');
      });

      document.getElementById('gh-confirm').addEventListener('click', async () => {
        const token = document.getElementById('gh-token').value.trim();
        const repo = document.getElementById('gh-repo').value.trim();
        const branch = document.getElementById('gh-branch').value.trim() || 'main';
        const status = document.getElementById('gh-status');

        if (!token) { status.className = 'text-sm text-red-500'; status.textContent = '请输入 GitHub Token'; status.classList.remove('hidden'); return; }
        if (!repo) { status.className = 'text-sm text-red-500'; status.textContent = '请输入仓库名'; status.classList.remove('hidden'); return; }

        const filename = getFilename();
        const filePath = `src/content/posts/${filename}`;
        const content = getFullMarkdown();
        const encodedContent = btoa(unescape(encodeURIComponent(content)));

        status.className = 'text-sm text-blue-500'; status.textContent = '正在发布...'; status.classList.remove('hidden');

        // 保存到 localStorage
        localStorage.setItem('gh-editor-token', token);
        localStorage.setItem('gh-editor-repo', repo);

        try {
          // 检查文件是否已存在
          const checkRes = await fetch(`https://api.github.com/repos/${repo}/contents/${filePath}?ref=${branch}`, {
            headers: { 'Authorization': `token ${token}`, 'Accept': 'application/vnd.github.v3+json' }
          });

          let body = {
            message: `post: add "${document.getElementById('post-title').value || 'untitled'}"`,
            content: encodedContent,
            branch: branch,
          };

          if (checkRes.ok) {
            const existing = await checkRes.json();
            body.sha = existing.sha;
            body.message = `post: update "${document.getElementById('post-title').value || 'untitled'}"`;
          }

          const res = await fetch(`https://api.github.com/repos/${repo}/contents/${filePath}`, {
            method: 'PUT',
            headers: {
              'Authorization': `token ${token}`,
              'Accept': 'application/vnd.github.v3+json',
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(body),
          });

          if (res.ok) {
            const data = await res.json();
            status.className = 'text-sm text-green-500';
            status.innerHTML = `✓ 发布成功！<a href="${data.content.html_url}" target="_blank" class="underline text-[var(--primary)]">查看文件</a>`;
            // 发布成功，清空自动保存
            try { localStorage.removeItem(AUTOSAVE_KEY); } catch(e) {}
            setTimeout(() => {
              document.getElementById('github-modal').classList.add('hidden');
            }, 3000);
          } else {
            const err = await res.json();
            status.className = 'text-sm text-red-500';
            status.textContent = '发布失败: ' + (err.message || JSON.stringify(err));
          }
        } catch (e) {
          status.className = 'text-sm text-red-500';
          status.textContent = '网络错误: ' + e.message;
        }
      });

      // ===== 点击遮罩关闭 =====
      document.getElementById('github-modal').addEventListener('click', (e) => {
        if (e.target === e.currentTarget) e.currentTarget.classList.add('hidden');
      });
      document.getElementById('image-modal').addEventListener('click', (e) => {
        if (e.target === e.currentTarget) e.currentTarget.classList.add('hidden');
      });

      // ===== 图片弹窗逻辑 =====
      let imgSelectedFile = null;
      document.getElementById('img-file-input').addEventListener('change', (e) => {
        const file = e.target.files[0];
        if (!file) return;
        imgSelectedFile = file;
        // 预览
        const reader = new FileReader();
        reader.onload = (ev) => {
          document.getElementById('img-preview-thumb').src = ev.target.result;
          document.getElementById('img-preview').classList.remove('hidden');
        };
        reader.readAsDataURL(file);
      });

      document.getElementById('img-cancel').addEventListener('click', () => {
        document.getElementById('image-modal').classList.add('hidden');
      });

      document.getElementById('img-confirm').addEventListener('click', async () => {
        const urlInput = document.getElementById('img-url-input');
        const status = document.getElementById('img-status');
        const url = urlInput.value.trim();

        // 有 URL 直接插入
        if (url && !imgSelectedFile) {
          insertTextAtCursor(`![图片](${url})`);
          document.getElementById('image-modal').classList.add('hidden');
          return;
        }

        // 有本地文件，上传
        if (imgSelectedFile) {
          status.className = 'text-sm text-blue-500';
          status.textContent = '⏳ 正在上传...';
          status.classList.remove('hidden');
          try {
            const uploadedUrl = await uploadToGitHub(imgSelectedFile);
            if (uploadedUrl) {
              const altText = url || imgSelectedFile.name.replace(/\.[^.]+$/, '');
              insertTextAtCursor(`![${altText}](${uploadedUrl})`);
              document.getElementById('image-modal').classList.add('hidden');
            }
          } catch (e) {
            status.className = 'text-sm text-red-500';
            status.textContent = '❌ ' + e.message;
          }
          imgSelectedFile = null;
          return;
        }

        status.className = 'text-sm text-red-500';
        status.textContent = '请输入 URL 或选择本地图片';
        status.classList.remove('hidden');
      });

      // ===== 链接弹窗 =====
      document.getElementById('link-cancel').addEventListener('click', () => {
        document.getElementById('link-modal').classList.add('hidden');
      });
      document.getElementById('link-modal').addEventListener('click', (e) => {
        if (e.target === e.currentTarget) e.currentTarget.classList.add('hidden');
      });
      document.getElementById('link-confirm').addEventListener('click', () => {
        const text = document.getElementById('link-text-input').value.trim() || '链接';
        const url = document.getElementById('link-url-input').value.trim();
        if (!url) { document.getElementById('link-url-input').focus(); return; }
        const start = textarea.selectionStart;
        const end = textarea.selectionEnd;
        textarea.setRangeText(`[${text}](${url})`, start, end, 'end');
        textarea.focus();
        updatePreview();
        document.getElementById('link-modal').classList.add('hidden');
      });

      // ===== 封面图上传 =====
      document.getElementById('cover-upload').addEventListener('change', async (e) => {
        const file = e.target.files[0];
        if (!file) return;
        showUploadStatus('⏳ 正在上传封面图...', 'uploading');
        try {
          const url = await uploadToGitHub(file);
          if (url) {
            document.getElementById('post-cover').value = url;
            showUploadStatus('✓ 封面图上传成功', 'success');
          }
        } catch (e) {
          showUploadStatus('❌ ' + e.message, 'error');
        }
      });

      // ===== #6 草稿管理 =====
      const DRAFTS_KEY = 'editor-drafts';

      function getDrafts() {
        try {
          return JSON.parse(localStorage.getItem(DRAFTS_KEY) || '[]');
        } catch(e) { return []; }
      }

      function saveDrafts(list) {
        try { localStorage.setItem(DRAFTS_KEY, JSON.stringify(list)); } catch(e) {}
      }

      function getCurrentData() {
        return {
          content: textarea.value,
          title: document.getElementById('post-title').value,
          desc: document.getElementById('post-desc').value,
          category: document.getElementById('post-category').value,
          tags: document.getElementById('post-tags').value,
          cover: document.getElementById('post-cover').value,
          password: document.getElementById('post-password').value,
          passwordHint: document.getElementById('post-password-hint').value,
          pinned: document.getElementById('post-pinned').value === 'true',
          comment: document.getElementById('post-comment').value === 'true',
        };
      }

      function loadDraftData(data) {
        textarea.value = data.content || '';
        document.getElementById('post-title').value = data.title || '';
        document.getElementById('post-desc').value = data.desc || '';
        document.getElementById('post-category').value = data.category || '';
        document.getElementById('post-tags').value = data.tags || '';
        document.getElementById('post-cover').value = data.cover || '';
        document.getElementById('post-password').value = data.password || '';
        document.getElementById('post-password-hint').value = data.passwordHint || '';
        setToggle('btn-pinned', 'post-pinned', data.pinned || false);
        setToggle('btn-comment', 'post-comment', data.comment !== false);
        updatePreview();
      }

      function renderDraftList() {
        const list = getDrafts();
        const container = document.getElementById('draft-list');
        const toolbar = document.getElementById('draft-toolbar');
        const selectAll = document.getElementById('draft-select-all');

        if (list.length === 0) {
          container.innerHTML = '<div class="text-sm text-black/40 dark:text-white/40 text-center py-8">暂无保存的草稿</div>';
          toolbar.classList.add('hidden');
          return;
        }

        toolbar.classList.remove('hidden');
        selectAll.checked = false;

        container.innerHTML = list.map((d, i) => `
          <div class="draft-item flex items-center gap-2 px-3 py-2.5 rounded-lg hover:bg-black/5 dark:hover:bg-white/10 transition">
            <input type="checkbox" class="draft-check w-3.5 h-3.5 rounded accent-[var(--primary)]" data-index="${i}" />
            <div class="flex-1 min-w-0 cursor-pointer" data-action="load" data-index="${i}">
              <div class="text-sm font-medium text-black/80 dark:text-white/80 truncate">${d.name || '未命名草稿'}</div>
              <div class="text-xs text-black/40 dark:text-white/40">${d.title ? '标题: ' + d.title : '无标题'} · ${new Date(d.savedAt).toLocaleString()}</div>
            </div>
            <button class="text-xs text-red-500 hover:text-red-700 cursor-pointer px-2 py-1 rounded hover:bg-red-50 dark:hover:bg-red-900/20 transition" data-action="delete" data-index="${i}">删除</button>
          </div>
        `).join('');

        // 全选
        selectAll.onchange = () => {
          container.querySelectorAll('.draft-check').forEach(cb => cb.checked = selectAll.checked);
        };

        // 批量删除
        document.getElementById('btn-batch-delete').onclick = () => {
          const checked = [...container.querySelectorAll('.draft-check:checked')].map(cb => parseInt(cb.dataset.index));
          if (checked.length === 0) return;
          if (!confirm(`删除选中的 ${checked.length} 篇草稿？`)) return;
          const drafts = getDrafts();
          checked.sort((a, b) => b - a).forEach(idx => drafts.splice(idx, 1));
          saveDrafts(drafts);
          renderDraftList();
        };

        // 加载草稿
        container.querySelectorAll('[data-action="load"]').forEach(el => {
          el.addEventListener('click', () => {
            const idx = parseInt(el.dataset.index);
            const drafts = getDrafts();
            if (drafts[idx] && confirm(`加载草稿「${drafts[idx].name}」？当前内容会被覆盖。`)) {
              loadDraftData(drafts[idx]);
              document.getElementById('draft-modal').classList.add('hidden');
            }
          });
        });

        // 单个删除
        container.querySelectorAll('[data-action="delete"]').forEach(el => {
          el.addEventListener('click', (e) => {
            e.stopPropagation();
            const idx = parseInt(el.dataset.index);
            const drafts = getDrafts();
            if (confirm(`删除草稿「${drafts[idx].name}」？`)) {
              drafts.splice(idx, 1);
              saveDrafts(drafts);
              renderDraftList();
            }
          });
        });
      }

      // 打开草稿弹窗
      document.getElementById('btn-drafts').addEventListener('click', () => {
        document.getElementById('draft-modal').classList.remove('hidden');
        document.getElementById('draft-name-input').value = '';
        renderDraftList();
      });

      // 关闭
      document.getElementById('draft-close').addEventListener('click', () => {
        document.getElementById('draft-modal').classList.add('hidden');
      });
      document.getElementById('draft-modal').addEventListener('click', (e) => {
        if (e.target === e.currentTarget) e.currentTarget.classList.add('hidden');
      });

      // 保存草稿
      document.getElementById('btn-save-draft').addEventListener('click', () => {
        const name = document.getElementById('draft-name-input').value.trim();
        if (!name) {
          document.getElementById('draft-name-input').focus();
          return;
        }
        const drafts = getDrafts();
        drafts.unshift({
          name: name,
          ...getCurrentData(),
          savedAt: new Date().toISOString(),
        });
        saveDrafts(drafts);
        document.getElementById('draft-name-input').value = '';
        renderDraftList();
      });

      // # 快捷保存草稿
      document.getElementById('btn-quick-save').addEventListener('click', () => {
        const title = document.getElementById('post-title').value.trim();
        const name = title || '未命名草稿 ' + new Date().toLocaleTimeString();
        const drafts = getDrafts();
        drafts.unshift({
          name: name,
          ...getCurrentData(),
          savedAt: new Date().toISOString(),
        });
        saveDrafts(drafts);
        // 按钮反馈
        const btn = document.getElementById('btn-quick-save');
        const orig = btn.innerHTML;
        btn.innerHTML = '✓ 已保存';
        btn.classList.add('text-green-600');
        setTimeout(() => {
          btn.innerHTML = orig;
          btn.classList.remove('text-green-600');
        }, 1500);
      });

      // 上传到 GitHub 的通用函数
      async function uploadToGitHub(file) {
        const token = localStorage.getItem('gh-editor-token');
        const repo = localStorage.getItem('gh-editor-repo') || 'Ghost-Insititue/Fireflyblog';
        if (!token) throw new Error('请先配置 GitHub Token（点击「发布到 GitHub」设置）');

        const ext = file.name.split('.').pop() || 'png';
        const ts = Date.now();
        const rand = Math.random().toString(36).substring(2, 8);
        const filename = `${ts}-${rand}.${ext}`;
        const filePath = `public/uploads/${filename}`;

        const arrayBuffer = await file.arrayBuffer();
        const bytes = new Uint8Array(arrayBuffer);
        let binary = '';
        for (let i = 0; i < bytes.length; i++) binary += String.fromCharCode(bytes[i]);
        const base64 = btoa(binary);

        const res = await fetch(`https://api.github.com/repos/${repo}/contents/${filePath}`, {
          method: 'PUT',
          headers: {
            'Authorization': `token ${token}`,
            'Accept': 'application/vnd.github.v3+json',
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            message: `upload: ${filename}`,
            content: base64,
            branch: 'main',
          }),
        });

        if (!res.ok) {
          const err = await res.json();
          throw new Error(err.message || '上传失败');
        }
        return `/uploads/${filename}`;
      }

      // 初始化
      updatePreview();
    }
  </script>
</MainGridLayout>
