    fm += 'published: ' + new Date().toISOString().split('T')[0] + '\n';
    fm += 'draft: false\n';
    if (desc) fm += 'description: "' + desc + '"\n';
    if (category) fm += 'category: "' + category + '"\n';
    if (tags) {
      var tagArr = tags.split(',').map(function(t) { return t.trim(); }).filter(Boolean);
      if (tagArr.length > 0) fm += 'tags: [' + tagArr.join(', ') + ']\n';
    }
    // [Editor] 跳过 base64 数据 URL（太长不适合 frontmatter，博客不支持）
    if (cover && cover.indexOf('data:') !== 0) fm += 'image: "' + cover + '"\n';
    if (password) fm += 'password: "' + password + '"\n';
    if (passwordHint) fm += 'passwordHint: "' + passwordHint + '"\n';
    if (pinned) fm += 'pinned: true\n';
    if (comment === false) fm += 'comment: false\n';
    fm += '---\n\n';

    // [Editor] 上传文章内图片到 src/content/posts/images/
    function uploadDataUrlImages(text, token, repo, branch) {
      var imageMap = window.__editorImageMap || {};
      var imageRegex = /!\[[^\]]*\]\(\.\/images\/([^)]+)\)/g;
      var matches = [];
      var match;
      while ((match = imageRegex.exec(text)) !== null) {
        matches.push({ full: match[0], filename: match[1], index: match.index });
      }
      if (matches.length === 0) return Promise.resolve([]);

      var uploaded = new Set();
      var failed = [];
      var chain = Promise.resolve();
      matches.forEach(function(m) {
        chain = chain.then(function() {
          if (uploaded.has(m.filename)) return;
          var dataUrl = imageMap[m.filename];
          if (!dataUrl) return;
          var rawBase64 = dataUrl.replace(/^data:image\/[^;]+;base64,/, '');
          if (!rawBase64) return;
          var imagePath = 'src/content/posts/images/' + m.filename;

          return fetch('https://api.github.com/repos/' + repo + '/contents/' + imagePath, {
            method: 'PUT',
            headers: {
              'Authorization': 'token ' + token,
              'Accept': 'application/vnd.github.v3+json',
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              message: 'upload image: ' + m.filename,
              content: rawBase64,
              branch: branch,
            }),
          }).then(function(res) {
            if (!res.ok) return res.json().then(function(e) { throw new Error(e.message || '图片上传失败'); });
            uploaded.add(m.filename);
            return res.json();
          }).catch(function(err) {
            failed.push(m.filename + ': ' + err.message);
            window.__editorShowToast('⚠️ 图片上传失败: ' + m.filename);
          });
        });
      });
      return chain.then(function() { return failed; });
    }

    // 先上传图片，最后发布文章（确保 Vercel 构建时所有文件已存在）
    var base64 = btoa(unescape(encodeURIComponent(fm + content)));
    var apiUrl = 'https://api.github.com/repos/' + repo + '/contents/' + filename;

    // 第一步：上传封面图（如果有）
    var coverDataUrl = window.__editorCoverDataUrl;
    var coverFilename = window.__editorCoverFilename;
    var uploadCover = Promise.resolve();
    if (coverDataUrl && coverFilename) {
      var coverBase64 = coverDataUrl.replace(/^data:image\/[^;]+;base64,/, '');
      if (coverBase64) {
        status.textContent = '⏳ 上传封面图...';
        uploadCover = fetch('https://api.github.com/repos/' + repo + '/contents/src/content/posts/images/' + coverFilename, {
          method: 'PUT',
          headers: {
            'Authorization': 'token ' + token,
            'Accept': 'application/vnd.github.v3+json',
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            message: 'upload cover: ' + coverFilename,
            content: coverBase64,
            branch: branch,
          }),
        }).then(function(res) {
          if (!res.ok) return res.json().then(function(e) { throw new Error(e.message || '封面图上传失败'); });
          return res.json();
        });
      }
    }

    // 第二步：上传文章内图片
    var imageUploadFailed = [];
    uploadCover.then(function() {
      status.textContent = '⏳ 上传文章图片...';
      return uploadDataUrlImages(content, token, repo, branch);
    }).then(function(failed) {
      imageUploadFailed = failed || [];
      if (imageUploadFailed.length > 0) {
        throw new Error('以下图片上传失败，文章已取消发布：\n' + imageUploadFailed.join('\n'));
      }
      // 第三步：最后发布文章（此时所有图片已在 GitHub 上）
      status.textContent = '⏳ 发布文章...';
      return fetch(apiUrl + '?ref=' + branch, {
        headers: { 'Authorization': 'token ' + token, 'Accept': 'application/vnd.github.v3+json' },
      });
    }).then(function(res) {
      if (res.status === 404) return null;
      if (!res.ok) return res.json().then(function(e) { throw new Error(e.message); });
      return res.json();
    }).then(function(existing) {
      var body = {
        message: (existing ? 'update' : 'post') + ': "' + title + '"',
        content: base64,
        branch: branch,
      };
      if (existing && existing.sha) body.sha = existing.sha;
      return fetch(apiUrl, {
        method: 'PUT',
        headers: {
          'Authorization': 'token ' + token,
          'Accept': 'application/vnd.github.v3+json',
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(body),
      });
    }).then(function(res) {
      if (!res.ok) return res.json().then(function(e) { throw new Error(e.message || '发布失败'); });
      return res.json();
    }).then(function() {
      status.textContent = '✅ 发布完成！';
      status.className = 'text-sm text-green-500';
    }).catch(function(e) {
      status.textContent = '❌ ' + e.message;
      status.className = 'text-sm text-red-500';
    });
  });

  // 图片弹窗
  var imgModal = document.getElementById('image-modal');
  var imgCancel = document.getElementById('img-cancel');
  var imgConfirm = document.getElementById('img-confirm');
  var imgUrlInput = document.getElementById('img-url-input');
  var imgFileInput = document.getElementById('img-file-input');
  var imgPreview = document.getElementById('img-preview');
  var imgPreviewGrid = document.getElementById('img-preview-grid');
  var imgPreviewThumb = document.getElementById('img-preview-thumb');
  var imgStatus = document.getElementById('img-status');
  var imgAltInput = document.getElementById('img-alt-input');
  var pendingImgUrls = [];

  // 打开图片弹窗
  var imgToolBtn = document.querySelector('[data-action="image"]');
  if (imgToolBtn && imgModal) imgToolBtn.addEventListener('click', function() {
    imgModal.classList.remove('hidden');
    if (imgUrlInput) imgUrlInput.value = '';
    if (imgAltInput) imgAltInput.value = '';
    if (imgPreview) imgPreview.classList.add('hidden');
    if (imgPreviewGrid) imgPreviewGrid.innerHTML = '';
    if (imgPreviewThumb) { imgPreviewThumb.src = ''; imgPreviewThumb.classList.add('hidden'); }
    if (imgStatus) { imgStatus.classList.add('hidden'); imgStatus.textContent = ''; }
    pendingImgUrls = [];
    if (imgFileInput) imgFileInput.value = '';
    setTimeout(function() { if (imgUrlInput) imgUrlInput.focus(); }, 100);
  });

  // 取消
  if (imgCancel && imgModal) imgCancel.addEventListener('click', function() {
    imgModal.classList.add('hidden');
  });

  // 本地文件选择 → 存入 __editorImageMap（和粘贴/拖拽一致）
  if (imgFileInput) imgFileInput.addEventListener('change', function(e) {
    var files = e.target.files;
    if (!files || files.length === 0) return;
    var imageFiles = [];
    for (var i = 0; i < files.length; i++) {
      if (files[i].type.indexOf('image') !== -1) imageFiles.push(files[i]);
    }
    if (imageFiles.length === 0) return;

    pendingImgUrls = [];
    var loaded = 0;

    if (imgPreviewGrid) imgPreviewGrid.innerHTML = '';
    if (imgPreviewThumb) { imgPreviewThumb.src = ''; imgPreviewThumb.classList.add('hidden'); }

    if (imgStatus) { imgStatus.textContent = '⏳ 处理中...'; imgStatus.className = 'text-sm text-blue-500'; imgStatus.classList.remove('hidden'); }

    imageFiles.forEach(function(file) {
      compressImage(file).then(function(dataUrl) {
        var ext = file.type.split('/')[1] || 'png';
        var filename = Date.now() + '-' + Math.random().toString(36).slice(2, 8) + '.' + ext;
        window.__editorImageMap[filename] = dataUrl;
        var mdPath = './images/' + filename;
        pendingImgUrls.push(mdPath);

        if (imgPreviewGrid) {
          var thumb = document.createElement('img');
          thumb.src = dataUrl;
          thumb.className = 'w-full h-20 object-cover rounded-lg';
          imgPreviewGrid.appendChild(thumb);
        }

        loaded++;
        if (loaded === imageFiles.length) {
          if (imgPreview) imgPreview.classList.remove('hidden');
          if (imageFiles.length > 1) {
            if (imgPreviewGrid) imgPreviewGrid.classList.remove('hidden');
            if (imgPreviewThumb) imgPreviewThumb.classList.add('hidden');
          } else {
            if (imgPreviewGrid) imgPreviewGrid.classList.add('hidden');
            if (imgPreviewThumb) {
              imgPreviewThumb.src = dataUrl;
              imgPreviewThumb.classList.remove('hidden');
            }
          }
          if (imgStatus) { imgStatus.textContent = '✅ ' + imageFiles.length + ' 张图片已就绪'; imgStatus.className = 'text-sm text-green-500'; }
        }
      });
    });
  });

  // 确认插入
  if (imgConfirm && imgModal) imgConfirm.addEventListener('click', function() {
    var textarea = document.getElementById('markdown-input');
    if (!textarea) return;

    var altText = (imgAltInput ? imgAltInput.value.trim() : '') || '图片';
    var insertText = '';

    // 优先处理云端选中图片
    var isCloudActive = imgPanelCloud && imgPanelCloud.style.display !== 'none' && typeof cloudSelectedUrls !== 'undefined' && cloudSelectedUrls.length > 0;
    if (isCloudActive) {
      // 确保所有选中的图片都已缓存到 __editorImageMap
      var needFetch = cloudSelectedPaths.filter(function(p) {
        var fn = p.split('/').pop();
        return !window.__editorImageMap[fn];
      });
      var fetchChain = Promise.resolve();
      needFetch.forEach(function(filePath) {
        fetchChain = fetchChain.then(function() {
          return cloudFetchFileBase64(filePath).then(function(dataUrl) {
            var fn = filePath.split('/').pop();
            window.__editorImageMap[fn] = dataUrl;
          }).catch(function() {});
        });
      });
      fetchChain.then(function() {
        if (cloudSelectedUrls.length === 1) {
          insertText = '![' + altText + '](' + cloudSelectedUrls[0] + ')\n';
        } else {
          var cloudLines = cloudSelectedUrls.map(function(url) { return '![' + altText + '](' + url + ')'; });
          insertText = '[grid]\n' + cloudLines.join('\n') + '\n[/grid]\n';
        }
        textarea.focus();
        document.execCommand('insertText', false, insertText);
        var insertedCount = cloudSelectedUrls.length;
        cloudSelectedUrls = [];
        cloudSelectedPaths = [];
        cloudUpdateCount();
        if (imgAltInput) imgAltInput.value = '';
        imgModal.classList.add('hidden');
        window.__editorShowToast(insertedCount > 1 ? insertedCount + ' 张图片已插入（网格）' : '图片已插入');
      });
      return; // 异步处理，提前返回
    } else if (pendingImgUrls.length > 0) {
      if (pendingImgUrls.length === 1) {
        insertText = '![' + altText + '](' + pendingImgUrls[0] + ')\n';
      } else {
        var lines = pendingImgUrls.map(function(url) { return '![' + altText + '](' + url + ')'; });
        insertText = '[grid]\n' + lines.join('\n') + '\n[/grid]\n';
      }
    } else {
      var url = imgUrlInput ? imgUrlInput.value.trim() : '';
      if (!url) { imgUrlInput.focus(); return; }
      insertText = '![' + altText + '](' + url + ')\n';
    }

    textarea.focus();
    document.execCommand('insertText', false, insertText);

    var insertedCount = pendingImgUrls.length || (insertText.indexOf('![') !== -1 ? 1 : 0);

    if (imgUrlInput) imgUrlInput.value = '';
    if (imgAltInput) imgAltInput.value = '';
    if (imgPreview) imgPreview.classList.add('hidden');
    if (imgPreviewGrid) imgPreviewGrid.innerHTML = '';
    if (imgPreviewThumb) { imgPreviewThumb.src = ''; imgPreviewThumb.classList.add('hidden'); }
    if (imgStatus) { imgStatus.classList.add('hidden'); imgStatus.textContent = ''; }
    pendingImgUrls = [];
    if (imgFileInput) imgFileInput.value = '';
    imgModal.classList.add('hidden');

    window.__editorShowToast(insertedCount > 1 ? insertedCount + ' 张图片已插入（网格）' : '图片已插入');
  });

  // 回车确认
  if (imgUrlInput) imgUrlInput.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') { e.preventDefault(); if (imgConfirm) imgConfirm.click(); }
  });

  // ========== 云端图片功能 ==========
  var imgTabLocal = document.getElementById('img-tab-local');
  var imgTabCloud = document.getElementById('img-tab-cloud');
  var imgPanelLocal = document.getElementById('img-panel-local');
  var imgPanelCloud = document.getElementById('img-panel-cloud');
  var cloudNoToken = document.getElementById('cloud-no-token');
  var cloudSourceBar = document.getElementById('cloud-source-bar');
  var cloudAlbumSelector = document.getElementById('cloud-album-selector');
  var cloudAlbumSelect = document.getElementById('cloud-album-select');
  var cloudImagesContainer = document.getElementById('cloud-images-container');
  var cloudImagesLoading = document.getElementById('cloud-images-loading');
  var cloudImagesEmpty = document.getElementById('cloud-images-empty');
  var cloudImagesGrid = document.getElementById('cloud-images-grid');
  var cloudImagesCount = document.getElementById('cloud-images-count');
  var cloudSrcAlbum = document.getElementById('cloud-src-album');
  var cloudSrcPost = document.getElementById('cloud-src-post');
  var cloudSelectedUrls = [];    // 插入 Markdown 的 URL
  var cloudSelectedPaths = [];   // GitHub 仓库文件路径（用于 API 读取）

  function cloudGetGithubConfig() {
    var token = localStorage.getItem('gh-token') || '';
    var repo = localStorage.getItem('gh-repo') || 'Ghost-Insititue/Fireflyblog';
    var branch = localStorage.getItem('gh-branch') || 'main';
    return { token: token, repo: repo, branch: branch };
  }

  function cloudFetchDir(path) {
    var cfg = cloudGetGithubConfig();
    if (!cfg.token) return Promise.reject('no_token');
    var url = 'https://api.github.com/repos/' + cfg.repo + '/contents/' + path + '?ref=' + cfg.branch;
    return fetch(url, { headers: { 'Authorization': 'token ' + cfg.token, 'Accept': 'application/vnd.github.v3+json' } })
      .then(function(res) { if (!res.ok) throw new Error('请求失败: ' + res.status); return res.json(); });
  }

  // 构建 Markdown 插入 URL（同仓库内用相对路径，无需代理）
  function cloudBuildInsertUrl(filePath) {
    // public/gallery/{albumId}/{filename} → /gallery/{albumId}/{filename}
    if (filePath.startsWith('public/gallery/')) {
      return '/' + filePath.substring('public/'.length);
    }
    // src/content/posts/images/{filename} → ./images/{filename}
    if (filePath.startsWith('src/content/posts/images/')) {
      return './images/' + filePath.substring('src/content/posts/images/'.length);
    }
    // 兜底：用代理 URL
    var cfg = cloudGetGithubConfig();
    var rawUrl = 'https://raw.githubusercontent.com/' + cfg.repo + '/' + cfg.branch + '/' + filePath;
    return 'https://ghproxy.com/' + rawUrl;
  }

  // 通过 GitHub API 获取文件 base64 内容（用于预览）
  function cloudFetchFileBase64(filePath) {
    var cfg = cloudGetGithubConfig();
    var url = 'https://api.github.com/repos/' + cfg.repo + '/contents/' + filePath + '?ref=' + cfg.branch;
    return fetch(url, { headers: { 'Authorization': 'token ' + cfg.token, 'Accept': 'application/vnd.github.v3+json' } })
      .then(function(res) { if (!res.ok) throw new Error('API请求失败: ' + res.status); return res.json(); })
      .then(function(data) {
        // GitHub API 返回的 content 是 base64 编码的
        var mimeMap = { '.jpg': 'image/jpeg', '.jpeg': 'image/jpeg', '.png': 'image/png', '.gif': 'image/gif', '.webp': 'image/webp', '.avif': 'image/avif' };
        var ext = filePath.match(/\.(\w+)$/);
        var mime = ext ? (mimeMap['.' + ext[1].toLowerCase()] || 'image/png') : 'image/png';
        return 'data:' + mime + ';base64,' + data.content;
      });
  }

  // 标签切换
  function switchImgTab(tab) {
    if (tab === 'local') {
      imgTabLocal.className = 'img-tab flex-1 px-3 py-1.5 rounded-md text-sm font-medium bg-white dark:bg-neutral-800 text-black/90 dark:text-white/90 shadow-sm transition cursor-pointer';
      imgTabCloud.className = 'img-tab flex-1 px-3 py-1.5 rounded-md text-sm font-medium text-black/50 dark:text-white/50 hover:text-black/70 dark:hover:text-white/70 transition cursor-pointer';
      imgPanelLocal.style.display = '';
      imgPanelCloud.classList.add('hidden');
      imgPanelCloud.style.display = 'none';
    } else {
      imgTabCloud.className = 'img-tab flex-1 px-3 py-1.5 rounded-md text-sm font-medium bg-white dark:bg-neutral-800 text-black/90 dark:text-white/90 shadow-sm transition cursor-pointer';
      imgTabLocal.className = 'img-tab flex-1 px-3 py-1.5 rounded-md text-sm font-medium text-black/50 dark:text-white/50 hover:text-black/70 dark:hover:text-white/70 transition cursor-pointer';
      imgPanelLocal.style.display = 'none';
      imgPanelCloud.classList.remove('hidden');
      imgPanelCloud.style.display = 'flex';
      // 检查 token
      var cfg = cloudGetGithubConfig();
      if (!cfg.token) {
        cloudNoToken.classList.remove('hidden');
        cloudSourceBar.classList.add('hidden');
        cloudAlbumSelector.classList.add('hidden');
        cloudImagesGrid.innerHTML = '';
        cloudImagesEmpty.classList.add('hidden');
      } else {
        cloudNoToken.classList.add('hidden');
        cloudSourceBar.classList.remove('hidden');
        // 自动加载相簿列表
        cloudLoadAlbums();
      }
    }
  }

  if (imgTabLocal) imgTabLocal.addEventListener('click', function() { switchImgTab('local'); });
  if (imgTabCloud) imgTabCloud.addEventListener('click', function() { switchImgTab('cloud'); });

  // 来源切换
  function switchCloudSource(src) {
    cloudCurrentSource = src;
    cloudSelectedUrls = [];
    cloudSelectedPaths = [];
    cloudUpdateCount();
    // 清除旧图片网格
    cloudImagesGrid.innerHTML = '';
    cloudImagesEmpty.classList.remove('hidden');
    cloudImagesEmpty.querySelector('span').textContent = '请选择一个相簿或切换到文章图片';
    cloudImagesLoading.classList.add('hidden');
    if (src === 'album') {
      cloudSrcAlbum.className = 'cloud-src-btn px-3 py-1.5 rounded-lg text-xs font-medium bg-[var(--primary)] text-white dark:text-black/80 transition cursor-pointer whitespace-nowrap';
      cloudSrcPost.className = 'cloud-src-btn px-3 py-1.5 rounded-lg text-xs font-medium border border-[var(--line-divider)] text-black/60 dark:text-white/60 hover:border-[var(--primary)]/40 transition cursor-pointer whitespace-nowrap';
      cloudAlbumSelector.classList.remove('hidden');
      cloudAlbumSelect.value = '';
      cloudLoadAlbums();
    } else {
      cloudSrcPost.className = 'cloud-src-btn px-3 py-1.5 rounded-lg text-xs font-medium bg-[var(--primary)] text-white dark:text-black/80 transition cursor-pointer whitespace-nowrap';
      cloudSrcAlbum.className = 'cloud-src-btn px-3 py-1.5 rounded-lg text-xs font-medium border border-[var(--line-divider)] text-black/60 dark:text-white/60 hover:border-[var(--primary)]/40 transition cursor-pointer whitespace-nowrap';
      cloudAlbumSelector.classList.add('hidden');
      cloudLoadPostImages();
    }
  }

  if (cloudSrcAlbum) cloudSrcAlbum.addEventListener('click', function() { switchCloudSource('album'); });
  if (cloudSrcPost) cloudSrcPost.addEventListener('click', function() { switchCloudSource('post'); });

  // 加载相簿列表
  function cloudLoadAlbums() {
    cloudFetchDir('public/gallery').then(function(items) {
      var dirs = items.filter(function(i) { return i.type === 'dir'; });
      cloudAlbumSelect.innerHTML = '<option value="">选择相簿 (' + dirs.length + ' 个)...</option>';
      dirs.forEach(function(d) {
        var opt = document.createElement('option');
        opt.value = d.name;
        opt.textContent = d.name;
        cloudAlbumSelect.appendChild(opt);
      });
    }).catch(function() {
      cloudAlbumSelect.innerHTML = '<option value="">加载失败</option>';
    });
  }

  // 相簿选择 → 加载图片
  if (cloudAlbumSelect) cloudAlbumSelect.addEventListener('change', function() {
    var albumId = this.value;
    cloudSelectedUrls = [];
    cloudSelectedPaths = [];
    cloudUpdateCount();
    if (!albumId) {
      cloudImagesGrid.innerHTML = '';
      cloudImagesEmpty.classList.remove('hidden');
      cloudImagesEmpty.querySelector('span').textContent = '请选择一个相簿';
      return;
    }
    cloudLoadAlbumPhotos(albumId);
  });

  function cloudLoadAlbumPhotos(albumId) {
    cloudImagesLoading.classList.remove('hidden');
    cloudImagesEmpty.classList.add('hidden');
    cloudImagesGrid.innerHTML = '';
    cloudFetchDir('public/gallery/' + albumId).then(function(items) {
      cloudImagesLoading.classList.add('hidden');
      var imageExts = /\.(jpe?g|png|webp|avif|gif)$/i;
      var images = items.filter(function(i) { return i.type === 'file' && imageExts.test(i.name) && !/^cover\./i.test(i.name); });
      if (images.length === 0) {
        cloudImagesEmpty.classList.remove('hidden');
        cloudImagesEmpty.querySelector('span').textContent = '该相簿暂无图片';
        return;
      }
      cloudRenderImages(images.map(function(img) {
        var filePath = 'public/gallery/' + albumId + '/' + img.name;
        return { name: img.name, path: filePath, insertUrl: cloudBuildInsertUrl(filePath) };
      }));
    }).catch(function(e) {
      cloudImagesLoading.classList.add('hidden');
      cloudImagesEmpty.classList.remove('hidden');
      cloudImagesEmpty.querySelector('span').textContent = '加载失败: ' + (e.message || e);
    });
  }

  // 加载文章图片
  function cloudLoadPostImages() {
    cloudImagesLoading.classList.remove('hidden');
    cloudImagesEmpty.classList.add('hidden');
    cloudImagesGrid.innerHTML = '';
    cloudFetchDir('src/content/posts/images').then(function(items) {
      cloudImagesLoading.classList.add('hidden');
      var imageExts = /\.(jpe?g|png|webp|avif|gif)$/i;
      var images = items.filter(function(i) { return i.type === 'file' && imageExts.test(i.name); });
      if (images.length === 0) {
        cloudImagesEmpty.classList.remove('hidden');
        cloudImagesEmpty.querySelector('span').textContent = '文章图片目录为空';
        return;
      }
      cloudRenderImages(images.map(function(img) {
        var filePath = 'src/content/posts/images/' + img.name;
        return { name: img.name, path: filePath, insertUrl: cloudBuildInsertUrl(filePath) };
      }));
    }).catch(function(e) {
      cloudImagesLoading.classList.add('hidden');
      cloudImagesEmpty.classList.remove('hidden');
      cloudImagesEmpty.querySelector('span').textContent = '加载失败: ' + (e.message || e);
    });
  }

  // 渲染图片网格（预览用 base64，存储代理 URL 用于插入）
  function cloudRenderImages(imgList) {
    cloudImagesGrid.innerHTML = '';
    imgList.forEach(function(img) {
      var item = document.createElement('div');
      item.className = 'relative rounded-lg overflow-hidden cursor-pointer border-2 border-transparent hover:border-[var(--primary)]/50 transition group';
      item.setAttribute('data-insert-url', img.insertUrl);
      item.setAttribute('data-file-path', img.path);
      // 占位 loading
      item.innerHTML = '<div class="w-full h-20 bg-black/5 dark:bg-white/5 animate-pulse rounded-lg"></div>' +
        '<div class="absolute bottom-0 left-0 right-0 bg-black/50 text-white text-[10px] px-1 py-0.5 truncate opacity-0 group-hover:opacity-100 transition">' + img.name + '</div>';
      // 通过 API 加载 base64 预览
      cloudFetchFileBase64(img.path).then(function(dataUrl) {
        var imgEl = document.createElement('img');
        imgEl.src = dataUrl;
        imgEl.className = 'w-full h-20 object-cover rounded-lg';
        imgEl.loading = 'lazy';
        item.innerHTML = '';
        item.appendChild(imgEl);
        var label = document.createElement('div');
        label.className = 'absolute bottom-0 left-0 right-0 bg-black/50 text-white text-[10px] px-1 py-0.5 truncate opacity-0 group-hover:opacity-100 transition';
        label.textContent = img.name;
        item.appendChild(label);
        // 缓存 data URL 到 __editorImageMap，供预览使用
        var filename = img.path.split('/').pop();
        if (!window.__editorImageMap[filename]) {
          window.__editorImageMap[filename] = dataUrl;
        }
      }).catch(function() {
        // 加载失败时显示错误提示
        item.innerHTML = '<div class="w-full h-20 flex items-center justify-center bg-black/5 dark:bg-white/5 rounded-lg"><span class="text-xs text-black/30 dark:text-white/30">加载失败</span></div>';
      });
      item.addEventListener('click', function() {
        var insertUrl = this.getAttribute('data-insert-url');
        var filePath = this.getAttribute('data-file-path');
        var idx = cloudSelectedUrls.indexOf(insertUrl);
        if (idx >= 0) {
          cloudSelectedUrls.splice(idx, 1);
          cloudSelectedPaths.splice(idx, 1);
          this.style.borderColor = 'transparent';
        } else {
          cloudSelectedUrls.push(insertUrl);
          cloudSelectedPaths.push(filePath);
          this.style.borderColor = 'var(--primary)';
        }
        cloudUpdateCount();
      });
      cloudImagesGrid.appendChild(item);
    });
  }

  function cloudUpdateCount() {
    if (cloudImagesCount) {
      cloudImagesCount.textContent = cloudSelectedUrls.length > 0 ? '已选 ' + cloudSelectedUrls.length + ' 张' : '';
    }
  }

  // 打开图片弹窗时重置云端状态
  if (imgToolBtn && imgModal) {
    imgToolBtn.addEventListener('click', function() {
      setTimeout(function() {
        cloudSelectedUrls = [];
        cloudSelectedPaths = [];
        cloudUpdateCount();
        if (cloudImagesGrid) cloudImagesGrid.innerHTML = '';
        if (cloudImagesEmpty) { cloudImagesEmpty.classList.remove('hidden'); cloudImagesEmpty.querySelector('span').textContent = '请选择一个相簿或切换到文章图片'; }
        if (cloudImagesLoading) cloudImagesLoading.classList.add('hidden');
        if (cloudAlbumSelect) cloudAlbumSelect.value = '';
        switchImgTab('local');
      }, 0);
    });
  }

  // ========== 链接弹窗 ==========
  var linkModal = document.getElementById('link-modal');
  var linkCancel = document.getElementById('link-cancel');
  var linkConfirm = document.getElementById('link-confirm');
  var linkToolBtn = document.querySelector('[data-action="link"]');

  if (linkToolBtn && linkModal) linkToolBtn.addEventListener('click', function() {
    linkModal.classList.remove('hidden');
    var linkTextInput = document.getElementById('link-text-input');
    var linkUrlInput = document.getElementById('link-url-input');
    if (linkTextInput) linkTextInput.value = '';
    if (linkUrlInput) linkUrlInput.value = '';
    setTimeout(function() { if (linkTextInput) linkTextInput.focus(); }, 100);
  });
  if (linkCancel && linkModal) linkCancel.addEventListener('click', function() { linkModal.classList.add('hidden'); });
  if (linkConfirm && linkModal) linkConfirm.addEventListener('click', function() {
    var text = document.getElementById('link-text-input').value;
    var url = document.getElementById('link-url-input').value;
    if (url) {
      var textarea = document.getElementById('markdown-input');
      var start = textarea.selectionStart;
      textarea.setRangeText('[' + (text || '链接') + '](' + url + ')\n', start, start, 'end');
      textarea.focus();
      textarea.dispatchEvent(new Event('input'));
      linkModal.classList.add('hidden');
    }
  });

  // 初始化隐藏
  slidePanel.style.width = '0px';

  // ========== TOC 和语法面板（复用 slide-panel）==========
  var currentSyntaxCat = '标题';

  var syntaxData = {
    '标题': [
      { syntax: '# 一级标题', desc: '一级标题', select: '一级标题' },
      { syntax: '## 二级标题', desc: '二级标题', select: '二级标题' },
      { syntax: '### 三级标题', desc: '三级标题', select: '三级标题' },
      { syntax: '#### 四级标题', desc: '四级标题', select: '四级标题' },
    ],
    '文本样式': [
      { syntax: '**加粗文本**', desc: '加粗', select: '加粗文本' },
      { syntax: '*斜体文本*', desc: '斜体', select: '斜体文本' },
      { syntax: '~~删除线~~', desc: '删除线', select: '删除线' },
      { syntax: '`行内代码`', desc: '行内代码', select: '行内代码' },
      { syntax: '==高亮文本==', desc: '高亮', select: '高亮文本' },
    ],
    '列表': [
      { syntax: '- 无序列表项', desc: '无序列表', select: '无序列表项' },
      { syntax: '1. 有序列表项', desc: '有序列表', select: '有序列表项' },
      { syntax: '- [ ] 任务列表项', desc: '任务列表', select: '任务列表项' },
    ],
    '图片': [
      { syntax: '![图片描述](图片URL)', desc: '图片', select: '图片描述' },
      { syntax: '[grid]\n![图片1](URL1)\n![图片2](URL2)\n[/grid]', desc: '图片网格', select: '图片1' },
    ],
    '链接': [
      { syntax: '[链接文字](https://example.com)', desc: '链接', select: '链接文字' },
      { syntax: '[锚点链接](#标题)', desc: '锚点链接', select: '锚点链接' },
    ],
    '代码块': [
      { syntax: '```javascript\n// 代码\n```', desc: '代码块', select: '// 代码' },
      { syntax: '```diff\n+ 新增行\n- 删除行\n```', desc: 'diff 代码块', select: '+ 新增行' },
    ],
    '表格': [
      { syntax: '| 列1 | 列2 | 列3 |\n| --- | --- | --- |\n| 内容 | 内容 | 内容 |', desc: '表格', select: '内容' },
    ],
    '引用': [
      { syntax: '> 引用内容', desc: '引用', select: '引用内容' },
    ],
    '分隔线': [
      { syntax: '\n---\n', desc: '分隔线', select: null },
    ],
    'LaTeX': [
      { syntax: '$公式$', desc: '行内公式', select: '公式' },
      { syntax: '$$\n公式\n$$', desc: '块级公式', select: '公式' },
    ],
    'Mermaid': [
      { syntax: '```mermaid\ngraph TD\n    A[开始] --> B[结束]\n```', desc: '流程图', select: 'A[开始]' },
    ],
    '快捷键': [
      { syntax: '', desc: 'Ctrl+B 加粗', select: null },
      { syntax: '', desc: 'Ctrl+I 斜体', select: null },
      { syntax: '', desc: 'Ctrl+K 链接', select: null },
      { syntax: '', desc: 'Ctrl+Z 撤销', select: null },
      { syntax: '', desc: 'Ctrl+Shift+S 保存', select: null },
    ],
  };

  // 缓存上次 TOC 数据，避免全量重建
  var _tocCache = '';

  // 渲染 TOC 内容到 panelContent
  function renderTocContent() {
    var textarea = document.getElementById('markdown-input');
    if (!textarea) return;
    var lines = textarea.value.split('\n');
    var headings = [];
    lines.forEach(function(line, idx) {
      var m = line.match(/^(#{1,4})\s+(.+)/);
      if (m) headings.push({ level: m[1].length, text: m[2], line: idx });
    });
    if (headings.length === 0) {
      var emptyHtml = '<div style="text-align:center;color:var(--font-color-light);font-size:13px;padding:24px 0;">暂无标题</div>';
      if (_tocCache !== emptyHtml) {
        panelContent.innerHTML = emptyHtml;
        _tocCache = emptyHtml;
      }
      return;
    }
    var html = '';
    headings.forEach(function(h) {
      var indent = (h.level - 1) * 12;
      html += '<div class="toc-item" data-line="' + h.line + '" title="' + h.text + '" style="padding:6px 12px 6px ' + (12 + indent) + 'px;cursor:pointer;font-size:13px;color:var(--font-color);transition:background 0.12s;border-radius:6px;margin:1px 4px;"><span style="display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + h.text + '</span></div>';
    });
    if (html === _tocCache) return;
    _tocCache = html;
    panelContent.innerHTML = html;
    panelContent.querySelectorAll('.toc-item').forEach(function(item) {
      item.addEventListener('mouseenter', function() { item.style.background = 'color-mix(in srgb, var(--primary) 8%, transparent)'; });
      item.addEventListener('mouseleave', function() { item.style.background = ''; });
      item.addEventListener('click', function() {
        var line = parseInt(item.getAttribute('data-line'));
        var textarea = document.getElementById('markdown-input');
        if (!textarea) return;
        var lines = textarea.value.split('\n');
        var pos = 0;
        for (var i = 0; i < line; i++) pos += lines[i].length + 1;
        textarea.focus();
        textarea.selectionStart = textarea.selectionEnd = pos;
        textarea.setSelectionRange(pos, pos);
        textarea.scrollTop = line * 24 - textarea.clientHeight / 2;
      });
    });
  }

  // 渲染语法内容到 panelContent
  function renderSyntaxContent() {
    var items = syntaxData[currentSyntaxCat] || [];
    // 标签栏
    var tagsHtml = '<div style="display:flex;flex-wrap:wrap;gap:6px;padding-bottom:12px;border-bottom:1px solid var(--line-divider);margin-bottom:8px;">';
    Object.keys(syntaxData).forEach(function(cat) {
      var active = cat === currentSyntaxCat;
      var style = active
        ? 'background:color-mix(in srgb, var(--primary) 12%, transparent);color:var(--primary);border-color:var(--primary);'
        : '';
      tagsHtml += '<span class="syntax-tag" data-cat="' + cat + '" style="padding:3px 10px;border-radius:12px;font-size:12px;cursor:pointer;border:1px solid var(--line-divider);color:var(--font-color-light);transition:all 0.15s;user-select:none;' + style + '">' + cat + '</span>';
    });
    tagsHtml += '</div>';

    // 快捷键分类只显示说明
    if (currentSyntaxCat === '快捷键') {
      var listHtml = '';
      items.forEach(function(item) {
        listHtml += '<div style="padding:8px 0;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid color-mix(in srgb, var(--font-color) 5%, transparent);"><span style="font-size:13px;color:var(--font-color);">' + item.desc + '</span></div>';
      });
      panelContent.innerHTML = tagsHtml + listHtml;
      bindSyntaxTagEvents();
      return;
    }

    var listHtml = '';
    items.forEach(function(item, idx) {
      var codeDisplay = item.syntax ? item.syntax.replace(/</g, '&lt;').replace(/\n/g, '<br>') : '';
      listHtml += '<div class="syntax-item" data-idx="' + idx + '" style="margin:4px 0;padding:6px 8px;cursor:pointer;transition:all 0.15s;border:1px solid var(--line-divider);border-radius:6px;"><div style="font-size:12px;font-weight:600;color:color-mix(in srgb, currentColor 80%, transparent);margin-bottom:3px;">' + item.desc + '</div><code style="font-size:11px;color:color-mix(in srgb, currentColor 55%, transparent);background:color-mix(in srgb, currentColor 8%, transparent);padding:4px 6px;border-radius:4px;white-space:pre-wrap;display:block;line-height:1.4;border:1px solid color-mix(in srgb, currentColor 8%, transparent);">' + codeDisplay + '</code></div>';
    });
    panelContent.innerHTML = tagsHtml + listHtml;
    bindSyntaxTagEvents();
    bindSyntaxItemEvents();
  }

  function bindSyntaxTagEvents() {
    panelContent.querySelectorAll('.syntax-tag').forEach(function(tag) {
      tag.addEventListener('click', function() {
        currentSyntaxCat = tag.getAttribute('data-cat');
        renderSyntaxContent();
      });
    });
  }

  function bindSyntaxItemEvents() {
    panelContent.querySelectorAll('.syntax-item').forEach(function(el) {
      el.addEventListener('mouseenter', function() {
        el.style.borderColor = 'var(--primary)';
        el.style.background = 'color-mix(in srgb, var(--primary) 5%, transparent)';
      });
      el.addEventListener('mouseleave', function() {
        el.style.borderColor = 'var(--line-divider)';
        el.style.background = '';
      });
      el.addEventListener('click', function() {
        var idx = parseInt(el.getAttribute('data-idx'));
        var item = syntaxData[currentSyntaxCat][idx];
        if (!item || !item.syntax) return;
        var textarea = document.getElementById('markdown-input');
        if (!textarea) return;
        var start = textarea.selectionStart;
        var end = textarea.selectionEnd;
        var selected = textarea.value.substring(start, end);
        if (selected && item.select) {
          var prefix = item.syntax.substring(0, item.syntax.indexOf(item.select));
          var suffix = item.syntax.substring(item.syntax.indexOf(item.select) + item.select.length);
          // 检测选区前后是否已有 prefix/suffix → 取消包裹
          if (suffix && start >= prefix.length && end <= textarea.value.length - suffix.length) {
            var beforePrefix = textarea.value.substring(start - prefix.length, start);
            var afterSuffix = textarea.value.substring(end, end + suffix.length);
            if (beforePrefix === prefix && afterSuffix === suffix) {
              textarea.setRangeText(selected, start - prefix.length, end + suffix.length, 'select');
              textarea.focus();
              textarea.dispatchEvent(new Event('input'));
              return;
            }
          }
          textarea.setRangeText(prefix + selected + suffix, start, end, 'end');
          textarea.selectionStart = start + prefix.length;
          textarea.selectionEnd = start + prefix.length + selected.length;
        } else {
          // 无选中文本时：插入语法并选中占位符
          textarea.setRangeText(item.syntax, start, start, 'end');
          if (item.select) {
            var NewStart = textarea.value.indexOf(item.select, start);
            if (NewStart !== -1) {
              textarea.selectionStart = NewStart;
              textarea.selectionEnd = NewStart + item.select.length;
            }
          }
        }
        textarea.focus();
        textarea.dispatchEvent(new Event('input'));
      });
    });
  }


  // 编辑时实时更新 TOC
  var tocRaf = null;
  var textareaEl = document.getElementById('markdown-input');
  if (textareaEl) {
    textareaEl.addEventListener('input', function() {
      if (currentPanel === 'toc') {
        if (tocRaf) return;
        tocRaf = requestAnimationFrame(function() {
          tocRaf = null;
          renderTocContent();
        });
      }
    });
  }

  // ESC 键关闭弹窗和面板（优先关闭弹窗，再关闭面板）
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      var modals = [
        document.getElementById('fullscreen-preview'),
        document.getElementById('image-modal'),
        document.getElementById('github-modal'),
        document.getElementById('draft-modal'),
        document.getElementById('link-modal')
      ];
      // 优先关闭最上层的弹窗，每次只关闭一个
      for (var i = 0; i < modals.length; i++) {
        if (modals[i] && !modals[i].classList.contains('hidden')) {
          modals[i].classList.add('hidden');
          return;
        }
      }
      // 没有弹窗打开时，关闭侧面板
      if (currentPanel && slidePanel.style.width === '288px') {
        closePanel();
      }
    }
  });
})();
</script>

</MainGridLayout>
