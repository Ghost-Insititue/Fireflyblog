---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
---

<MainGridLayout title="写文章" description="在线 Markdown 编辑器">

<!-- 编辑器页面管理：class、CSS注入、Swup hooks -->
<script is:inline>
(function() {
  var editorStyleEl = null;
  var editorResizeHandler = null;

  function isEditorPage() {
    var p = window.location.pathname;
    return p === '/editor/' || p === '/editor';
  }

  // [Editor] 导航栏偏移补偿：overflow:hidden 移除滚动条→页面宽度变化→92vw 导航栏右移
  // 服务端已在 MainGridLayout 渲染 inline style，此处为 Swup 导航时的备用补偿
  var navbarTransitionTimer = null;
  function applyNavbarOffset() {
    var row = document.getElementById('top-row');
    if (row) row.style.transform = 'translateX(-8px)';
  }
  // 清除偏移时先禁用过渡，避免 transform 变化被动画化（700ms 滑动）
  function clearNavbarOffset() {
    var row = document.getElementById('top-row');
    if (row) {
      // 清除前一次的恢复定时器（防止快速切换时竞态）
      if (navbarTransitionTimer) { cancelAnimationFrame(navbarTransitionTimer); navbarTransitionTimer = null; }
      row.style.transition = 'none';
      row.style.transform = '';
      // 下一帧恢复过渡（确保后续 sticky navbar 等动画正常）
      navbarTransitionTimer = requestAnimationFrame(function() {
        row.style.transition = '';
        navbarTransitionTimer = null;
      });
    }
  }

  function measureScrollbarWidth() {
    var scrollDiv = document.createElement('div');
    scrollDiv.style.cssText = 'overflow:scroll;visibility:hidden;position:absolute;width:100px;height:100px;';
    document.body.appendChild(scrollDiv);
    var w = scrollDiv.offsetWidth - scrollDiv.clientWidth;
    document.body.removeChild(scrollDiv);
    return w;
  }

  function applyEditorMode() {
    if (editorStyleEl) return;
    var scrollbarWidth = measureScrollbarWidth();
    document.body.classList.add('editor-page');
    document.documentElement.classList.add('editor-page');
    editorStyleEl = document.createElement('style');
    editorStyleEl.id = 'editor-dynamic-style';
    editorStyleEl.textContent = [
      'body.editor-page #left-sidebar-wrapper,',
      'body.editor-page #left-sidebar-dynamic,',
      'body.editor-page #right-sidebar-static,',
      'body.editor-page #right-sidebar-dynamic,',
      'body.editor-page #category-bar-wrapper,',
      'body.editor-page .footer,',
      'body.editor-page #sidebar-sticky,',
      'body.editor-page .sidebar-container { display: none !important; }',
      'body.editor-page #main-grid { display: flex !important; flex-direction: column !important; grid-template-columns: none !important; width: 100% !important; }',
      'body.editor-page #swup-container { max-width: 100% !important; width: 100% !important; padding: 0 !important; margin: 0 !important; flex: 1 !important; }',
      'body.editor-page #main-grid > div:first-child { max-width: 100% !important; width: 100% !important; padding: 0 !important; }',
      'body.editor-page #main-grid { padding: 0 !important; }',
      'body.editor-page #main-grid ~ div,',
      'body.editor-page .pointer-events-auto { max-width: 100% !important; width: 100% !important; padding: 0 !important; }',
      'body.editor-page #main-grid > div { max-width: 100% !important; }',
      'body.editor-page #wallpaper-wrapper { width: calc(100% - ' + scrollbarWidth + 'px) !important; max-width: calc(100% - ' + scrollbarWidth + 'px) !important; }',
      'body.editor-page::after { content: ""; position: fixed; right: 0; top: 0; width: ' + scrollbarWidth + 'px; height: 100%; background: linear-gradient(to right, transparent, var(--page-bg)); z-index: 15; pointer-events: none; opacity: 0.5; }',
      'body.editor-page { overflow: hidden !important; }',
      /* 编辑器页面：隐藏原生滚动条 */
      'body.editor-page #markdown-input { overflow-y: scroll !important; scrollbar-width: none; -ms-overflow-style: none; }',
      'body.editor-page #markdown-input::-webkit-scrollbar { display: none; }',
      'body.editor-page #preview-content { scrollbar-width: none; -ms-overflow-style: none; }',
      'body.editor-page #preview-content::-webkit-scrollbar { display: none; }',
      'body.editor-page { scrollbar-width: none; -ms-overflow-style: none; }',
      'body.editor-page::-webkit-scrollbar { display: none; }',
      'html.editor-page { scrollbar-width: none; -ms-overflow-style: none; }',
      'html.editor-page::-webkit-scrollbar { display: none; }',
      /* [Editor] 导航栏偏移 + 禁用过渡动画（避免 transform 变化产生 700ms 滑动） */
      'body.editor-page.sticky-navbar #top-row { transform: translateX(-8px) !important; transition: none !important; }'
    ].join('\n');
    document.head.appendChild(editorStyleEl);
    editorResizeHandler = function() {
      var newSW = measureScrollbarWidth();
      if (editorStyleEl) {
        var rules = editorStyleEl.textContent;
        rules = rules.replace(/calc\(100% - \d+px\)/g, 'calc(100% - ' + newSW + 'px)');
        rules = rules.replace(/body\.editor-page::after \{ content: ""; position: fixed; right: 0; top: 0; width: \d+px;/, 'body.editor-page::after { content: ""; position: fixed; right: 0; top: 0; width: ' + newSW + 'px;');
        rules = rules.replace(/translateX\(-\d+px\)/, 'translateX(-' + newSW + 'px)');
        editorStyleEl.textContent = rules;
      }
    };
    window.addEventListener('resize', editorResizeHandler);
  }

  function removeEditorMode() {
    document.body.classList.remove('editor-page');
    document.documentElement.classList.remove('editor-page');
    if (editorStyleEl) { editorStyleEl.remove(); editorStyleEl = null; }
    if (editorResizeHandler) { window.removeEventListener('resize', editorResizeHandler); editorResizeHandler = null; }
    clearNavbarOffset();
  }

  // [Editor] Swup hooks：进入编辑器时应用样式，离开时清理
  function registerSwupHooks() {
    // 离开编辑器时清理所有样式和 class
    window.swup.hooks.on('visit:start', function(visit) {
      var targetPath = '';
      try { targetPath = new URL(visit.to.url, window.location.origin).pathname; } catch(e) { targetPath = visit.to.url; }
      if (targetPath !== '/editor/' && targetPath !== '/editor') {
        removeEditorMode();
      }
    });
    // 进入编辑器时：先清理旧状态 → 立即补偿导航栏偏移 → 下一帧注入完整 CSS
    window.swup.hooks.on('page:view', function() {
      if (isEditorPage()) {
        removeEditorMode();
        applyNavbarOffset();
        requestAnimationFrame(applyEditorMode);
      }
    });
  }

  if (window.swup && window.swup.hooks) {
    registerSwupHooks();
  } else {
    document.addEventListener('swup:enable', registerSwupHooks);
  }

  // 首次加载：立即应用 offset 避免弹动，再注入 CSS
  if (isEditorPage()) {
    applyNavbarOffset();
    applyEditorMode();
  }
})();
</script>

<style>
.toolbar-btn { padding: 5px 7px; border-radius: 6px; color: color-mix(in srgb, currentColor 55%, transparent); display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.15s ease; position: relative; }
.toolbar-btn svg { width: 18px; height: 18px; flex-shrink: 0; }
.toolbar-btn:hover { background: color-mix(in srgb, currentColor 8%, transparent); color: color-mix(in srgb, currentColor 100%, transparent); }
.toolbar-btn:active { transform: scale(0.92); }
.toolbar-btn.active { background: color-mix(in srgb, var(--primary) 12%, transparent); color: var(--primary); }
.toolbar-btn.active:hover { background: color-mix(in srgb, var(--primary) 18%, transparent); }
.toggle-btn { display: flex; align-items: center; gap: 6px; padding: 8px 12px; border-radius: 0.5rem; border: 1px solid var(--line-divider); font-size: 0.8rem; color: color-mix(in srgb, currentColor 50%, transparent); cursor: pointer; transition: all 0.15s; white-space: nowrap; user-select: none; background: transparent; }
.toggle-btn:hover { border-color: color-mix(in srgb, var(--primary) 40%, transparent); color: color-mix(in srgb, var(--primary) 70%, transparent); }
.toggle-btn.active { border-color: var(--primary); background: color-mix(in srgb, var(--primary) 10%, transparent); color: var(--primary); }
#markdown-input:focus { box-shadow: inset 0 0 0 2px var(--primary); }
#markdown-input.drag-over { box-shadow: inset 0 0 0 3px var(--primary), inset 0 0 30px color-mix(in srgb, var(--primary) 10%, transparent); background: color-mix(in srgb, var(--primary) 3%, transparent); }
.icon-bar-btn { width: 36px; height: 36px; border-radius: 0.5rem; display: flex; align-items: center; justify-content: center; color: color-mix(in srgb, currentColor 50%, transparent); cursor: pointer; transition: all 0.15s; pointer-events: auto; }
.icon-bar-btn:hover { background: color-mix(in srgb, currentColor 5%, transparent); color: color-mix(in srgb, currentColor 80%, transparent); }
.icon-bar-btn.active { background: color-mix(in srgb, var(--primary) 10%, transparent); color: var(--primary); }
@media (max-width: 768px) { #right-icon-bar { display: none; } }

/* 自定义滚动条 */
.custom-scrollbar { position: absolute; right: 2px; top: 0; bottom: 0; width: 6px; z-index: 10; opacity: 1; pointer-events: auto; }
.custom-scrollbar-thumb { width: 100%; border-radius: 3px; background: rgba(128, 128, 128, 0.35); cursor: pointer; position: absolute; top: 0; min-height: 20px; transition: background 0.15s; }
.custom-scrollbar-thumb:hover { background: rgba(128, 128, 128, 0.55); }
</style>

<div class="flex flex-col w-full overflow-hidden" style="height: calc(100vh - var(--navbar-height, 72px)); box-sizing: border-box;">


<!-- 编辑器主体（导航栏下方） -->
<div class="flex flex-1 overflow-hidden">
  <!-- 中间编辑区 -->
  <div class="flex-1 flex flex-col overflow-hidden">
    <!-- 标题输入 -->
    <div class="px-6 py-3 border-b border-[var(--line-divider)]">
      <input id="post-title" type="text" placeholder="输入文章标题..."
        class="w-full text-2xl font-bold bg-transparent text-black/90 dark:text-white/90 focus:outline-none placeholder:text-black/20 dark:placeholder:text-white/20" />
    </div>

    <!-- 工具栏 -->
    <div id="toolbar" class="flex flex-nowrap items-center gap-0.5 px-3 py-1.5 border-b border-[var(--line-divider)] bg-transparent overflow-x-auto">
      <button data-action="bold" title="加粗 (Ctrl+B)" class="toolbar-btn">
        <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M13.5 4H7v16h7.5c2.5 0 4.5-2 4.5-4.5c0-1.57-.8-2.96-2.01-3.77C18.16 10.77 19 9.38 19 7.5C19 5.57 17.43 4 15.5 4zm0 2c.83 0 1.5.67 1.5 1.5S14.33 9 13.5 9H9V6h4.5zm0 6c.83 0 1.5.67 1.5 1.5s-.67 1.5-1.5 1.5H9v-3h4.5z"/></svg>
      </button>
      <button data-action="italic" title="斜体 (Ctrl+I)" class="toolbar-btn">
        <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M10 5v3h2.21l-3.42 8H6v3h8v-3h-2.21l3.42-8H18V5z"/></svg>
      </button>
      <button data-action="strikethrough" title="删除线" class="toolbar-btn">
        <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M10 19h4v-3h-4v3zM5 4v3h5v3h4V7h5V4H5zM3 14h18v-2H3v2z"/></svg>
      </button>
      <div class="w-px h-4 bg-[var(--line-divider)] mx-0.5"></div>
      <button data-action="h1" title="一级标题" class="toolbar-btn text-xs font-bold">H1</button>
      <button data-action="h2" title="二级标题" class="toolbar-btn text-xs font-bold">H2</button>
      <button data-action="h3" title="三级标题" class="toolbar-btn text-xs font-bold">H3</button>
      <button data-action="h4" title="四级标题" class="toolbar-btn text-xs font-bold">H4</button>
      <div class="w-px h-4 bg-[var(--line-divider)] mx-0.5"></div>
      <button data-action="ul" title="无序列表" class="toolbar-btn">
        <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M4 10.5c-.83 0-1.5.67-1.5 1.5s.67 1.5 1.5 1.5s1.5-.67 1.5-1.5s-.67-1.5-1.5-1.5zm0-6c-.83 0-1.5.67-1.5 1.5S3.17 7.5 4 7.5S5.5 6.83 5.5 6S4.83 4.5 4 4.5zm0 12c-.83 0-1.5.68-1.5 1.5s.68 1.5 1.5 1.5s1.5-.68 1.5-1.5s-.67-1.5-1.5-1.5zM7 19h14v-2H7v2zm0-6h14v-2H7v2zm0-8v2h14V5H7z"/></svg>
      </button>
      <button data-action="ol" title="有序列表" class="toolbar-btn">
        <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M2 17h2v.5H3v1h1v.5H2v1h3v-4H2v1zm1-9h1V4H2v1h1v3zm-1 3h1.8L2 13.1v.9h3v-1H3.2L5 10.9V10H2v1zm5-6v2h14V5H7zm0 14h14v-2H7v2zm0-6h14v-2H7v2z"/></svg>
      </button>
      <button data-action="checklist" title="任务列表" class="toolbar-btn">
        <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M3 5h2v14H3V5zm4 0v2h12V7H7zm0 4v2h12v-2H7zm0 4v2h12v-2H7zm-4 3l3-3l1.5 1.5L5 18.5L2.5 16L4 14.5z"/></svg>
      </button>
      <div class="w-px h-4 bg-[var(--line-divider)] mx-0.5"></div>
      <button data-action="quote" title="引用" class="toolbar-btn">
        <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"/></svg>
      </button>
      <button data-action="code" title="行内代码" class="toolbar-btn">
        <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6l6 6l1.4-1.4zm5.2 0l4.6-4.6l-4.6-4.6L16 6l6 6l-6 6l-1.4-1.4z"/></svg>
      </button>
      <button data-action="codeblock" title="代码块" class="toolbar-btn">
        <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 14H4V8h16v12zm-8-2h4v-2h-4v2zm-6-6h2v2H6v-2zm0 4h2v2H6v-2zm0 4h12v2H6v-2z"/></svg>
      </button>
      <div class="w-px h-4 bg-[var(--line-divider)] mx-0.5"></div>
      <button data-action="link" title="链接 (Ctrl+K)" class="toolbar-btn">
        <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z"/></svg>
      </button>
      <button data-action="image" title="图片" class="toolbar-btn">
        <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
      </button>
      <button data-action="table" title="表格" class="toolbar-btn">
        <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M3 3v18h18V3H3zm8 16H5v-6h6v6zm0-8H5V5h6v6zm8 8h-6v-6h6v6zm0-8h-6V5h6v6z"/></svg>
      </button>
      <button data-action="hr" title="分割线" class="toolbar-btn">
        <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M2 11h20v2H2z"/></svg>
      </button>
      <div class="w-px h-4 bg-[var(--line-divider)] mx-0.5"></div>
      <button data-action="undo" title="撤销 (Ctrl+Z)" class="toolbar-btn">
        <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M12.5 8c-2.65 0-5.05.99-6.9 2.6L2 7v9h9l-3.62-3.62c1.39-1.16 3.16-1.88 5.12-1.88c3.54 0 6.55 2.31 7.6 5.5l2.37-.78C21.08 11.03 17.15 8 12.5 8z"/></svg>
      </button>
      <button data-action="redo" title="重做 (Ctrl+Y)" class="toolbar-btn">
        <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M18.4 10.6C16.55 8.99 14.15 8 11.5 8c-4.65 0-8.58 3.03-9.96 7.22L3.9 16c1.05-3.19 4.05-5.5 7.6-5.5c1.95 0 3.73.72 5.12 1.88L13 16h9V7l-3.6 3.6z"/></svg>
      </button>
      <div class="w-px h-4 bg-[var(--line-divider)] mx-0.5"></div>
      <!-- 功能开关 -->
      <button id="btn-sync-scroll" title="同步滚动" class="toolbar-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3l-4 4m0 0l4 4"/><path d="M4 7h12"/><path d="M16 21l4-4m0 0l-4-4"/><path d="M20 17H8"/></svg>
      </button>
      <button id="btn-typewriter" title="打字机模式" class="toolbar-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4m0 12v4M2 12h4m12 0h4"/><path d="M12 8v8M8 12h8"/></svg>
      </button>
      <div class="flex-1"></div>
      <!-- 视图切换 -->
      <button id="btn-view-editor" title="仅编辑" class="toolbar-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
      </button>
      <button id="btn-view-split" title="分栏" class="toolbar-btn active">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="12" y1="3" x2="12" y2="21"/></svg>
      </button>
      <button id="btn-view-preview" title="仅预览" class="toolbar-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
      </button>
    </div>

    <!-- 编辑器主体 -->
    <div id="editor-body" class="flex flex-1 overflow-hidden">
      <!-- 左侧：Markdown 输入 -->
      <div id="editor-pane" class="flex-1 flex flex-col border-r border-[var(--line-divider)] relative">
        <textarea id="markdown-input" 
          class="flex-1 w-full resize-none p-5 text-sm font-mono bg-transparent text-black/90 dark:text-white/90 focus:outline-none placeholder:text-black/30 dark:placeholder:text-white/30"
          style="line-height: 1.75;"
          placeholder="开始写作吧...&#10;&#10;支持完整的 Markdown 语法：&#10;- **加粗** 和 *斜体*&#10;- # 标题&#10;- ```代码块```&#10;- > 引用&#10;- [链接](url)&#10;- ![图片](url)"
          spellcheck="false"
        ></textarea>
        <div class="custom-scrollbar" data-target="markdown-input"><div class="custom-scrollbar-thumb"></div></div>
      </div>
      <!-- 右侧：预览 -->
      <div id="preview-pane" class="flex-1 flex flex-col overflow-hidden relative">
        <div id="preview-content" class="flex-1 overflow-y-auto p-5 markdown-content prose prose-sm dark:prose-invert max-w-none">
          <div class="text-black/30 dark:text-white/30 text-sm italic">预览区域</div>
        </div>
        <div class="custom-scrollbar" data-target="preview-content"><div class="custom-scrollbar-thumb"></div></div>
      </div>
    </div>

    <!-- 底部状态栏 -->
    <div class="flex items-center justify-between px-4 py-2 border-t border-[var(--line-divider)] text-xs text-black/50 dark:text-white/50">
      <div class="flex items-center gap-4">
        <span id="word-count">0 词</span>
        <span id="char-count">0 字符</span>
        <span id="line-count">0 行</span>
      </div>
      <div class="flex items-center gap-2">
        <button id="btn-quick-save" title="Ctrl+Shift+S" class="px-3 py-1.5 rounded-lg bg-[var(--primary)]/10 text-[var(--primary)] hover:bg-[var(--primary)]/20 transition cursor-pointer text-xs font-medium">保存草稿</button>
        <button data-panel="drafts" title="草稿箱" class="px-3 py-1.5 rounded-lg border border-[var(--line-divider)] text-black/60 dark:text-white/60 hover:bg-black/5 dark:hover:bg-white/5 transition cursor-pointer text-xs">草稿箱</button>
        <button data-panel="publish" title="发布" class="px-3 py-1.5 rounded-lg bg-[var(--primary)] text-white dark:text-black/80 hover:opacity-90 transition cursor-pointer text-xs font-medium">发布文章</button>
      </div>
    </div>
  </div>

  <!-- [Editor] 隐藏的文章信息表单 — 始终存在于 DOM 中，保存草稿时可读取 -->
  <div id="meta-fields" class="hidden">
    <input id="post-desc" type="text" />
    <input id="post-category" type="text" />
    <input id="post-tags" type="text" />
    <input id="post-cover" type="text" />
    <input id="post-slug" type="text" />
    <input id="post-password" type="text" />
    <input id="post-password-hint" type="text" />
    <input id="chk-pinned" type="checkbox" />
    <input id="chk-comment" type="checkbox" checked />
  </div>

