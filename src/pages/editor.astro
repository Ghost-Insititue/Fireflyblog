    <!-- 全屏预览弹窗 -->
    <div id="fullscreen-preview" class="fixed inset-0 z-50 flex flex-col bg-white dark:bg-neutral-900 hidden">
      <div class="flex items-center justify-between px-6 py-3 border-b border-[var(--line-divider)] bg-white dark:bg-neutral-900">
