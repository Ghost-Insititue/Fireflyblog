<script is:inline>
(function loadScript(src) {
  return new Promise((resolve, reject) => {
    if (document.querySelector('script[src="' + src + '"]')) { resolve(); return; }
    const s = document.createElement('script');
    s.src = src;
    s.onload = resolve;
    s.onerror = reject;
    document.head.appendChild(s);
  });
})('https://cdn.jsdelivr.net/npm/marked/marked.min.js').then(() => {
  return new Promise((resolve) => {
    const src = 'https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.9.0/build/highlight.min.js';
    if (document.querySelector('script[src="' + src + '"]')) { resolve(); return; }
    const s = document.createElement('script');
    s.src = src;
 s.onload = resolve;
    s.onerror = resolve;
    document.head.appendChild(s);
  });
}).then(() => initEditor());

function initEditor() {
  const textarea = document.getElementById('markdown-input');
  const preview = document.getElementById('preview-content');
  const fullscreenContent = document.getElementById('fullscreen-content');

  // marked 配置
  if (typeof marked !== 'undefined') {
    const renderer = new marked.Renderer();
    // 任务列表：隐藏圆点，用内联样式强制覆盖
    renderer.listitem = function(obj) {
      const token = typeof obj === 'object' ? obj : { text: arguments[0], task: arguments[1], checked: arguments[2] };
      let text = token.tokens ? this.parser.parse(token.tokens, token.loose) : token.text;
      if (token.task) {
        const checkbox = '<input ' + (token.checked ? 'checked="" ' : '') + 'disabled="" type="checkbox">';
        text = checkbox + ' ' + text;
        return '<li style="list-style:none !important;">' + text + '</li>\n';
      }
      return '<li>' + text + '</li>\n';
    };
    renderer.code = function(obj) {
      const code = typeof obj === 'object' ? obj.text : obj;
      const lang = typeof obj === 'object' ? obj.lang : arguments[1];
      let highlighted = code;
      if (typeof hljs !== 'undefined') {
        if (lang && hljs.getLanguage(lang)) {
          try { highlighted = hljs.highlight(code, { language: lang }).value; } catch(e) {}
        } else {
          try { highlighted = hljs.highlightAuto(code).value; } catch(e) {}
        }
      }
      const cls = lang ? ' class="hljs language-' + lang + '"' : ' class="hljs"';
      return '<pre><code' + cls + '>' + highlighted + '</code></pre>';
    };
    marked.setOptions({ breaks: true, gfm: true, renderer: renderer });
  }

  // 实时预览
  let previewRaf = null;
  function updatePreview() {
    if (previewRaf) return;
    previewRaf = requestAnimationFrame(function() {
      previewRaf = null;
      var md = textarea.value;
      // [Editor] 替换 ./images/ 路径为 Base64 Data URL 用于预览
      var imageMap = window.__editorImageMap || {};
      md = md.replace(/!\[([^\]]*)\]\(\.\/images\/([^)]+)\)/g, function(match, alt, filename) {
        return imageMap[filename] ? '![' + alt + '](' + imageMap[filename] + ')' : match;
      });
      // [Editor] 将 [grid]...[/grid] 转换为 HTML grid 布局（包含 img 标签）
      md = md.replace(/\[grid\]\n([\s\S]*?)\n\[\/grid\]/g, function(match, content) {
        var images = [];
        var imgRegex = /!\[([^\]]*)\]\(([^)]+)\)/g;
        var imgMatch;
        while ((imgMatch = imgRegex.exec(content)) !== null) {
          images.push({ alt: imgMatch[1], src: imgMatch[2] });
        }
        var count = images.length;
        var cols = count === 1 ? 1 : count === 2 ? 2 : count === 3 ? 3 : 4;
        var html = '<div style="display:grid;grid-template-columns:repeat(' + cols + ',1fr);gap:8px;margin:16px 0;">';
        images.forEach(function(img) {
          html += '<div style="text-align:center;">';
          html += '<img src="' + img.src + '" alt="' + img.alt + '" style="width:100%;height:auto;border-radius:8px;" />';
          if (img.alt) {
            html += '<p style="font-size:12px;color:#999;margin:4px 0 0;">' + img.alt + '</p>';
          }
          html += '</div>';
        });
        html += '</div>';
        return html;
      });
      // 单张图片转为 HTML img 标签（grid 内的图片已在上方处理，不会匹配此正则）
      // 不依赖 marked 渲染，避免 data URL 过长导致渲染失败
      md = md.replace(/!\[([^\]]*)\]\(([^)]+)\)/g, function(match, alt, src) {
        var imgHtml = '<img src="' + src + '" alt="' + alt + '" style="max-width:100%;border-radius:8px;" />';
        if (alt) {
          imgHtml += '\n<p style="font-size:12px;color:var(--font-color, #999);opacity:0.6;margin:4px 0 0;text-align:center;">' + alt + '</p>';
        }
        return imgHtml;
      });
      var html = '';
      try { html = (typeof marked !== 'undefined') ? marked.parse(md) : md.replace(/\n/g, '<br>'); }
      catch(e) { html = '<p style="color:red">渲染错误: ' + e.message + '</p>'; }
      preview.innerHTML = html || '<div class="text-black/30 dark:text-white/30 text-sm italic">预览区域</div>';
      if (fullscreenContent) fullscreenContent.innerHTML = preview.innerHTML;
      updateCounts(md);
    });
  }

  function updateCounts(text) {
    const lines = text.split('\n').length;
    const chars = text.length;
    const cjk = (text.match(/[\u4e00-\u9fff\u3400-\u4dbf]/g) || []).length;
    const words = (text.match(/[a-zA-Z]+/g) || []).length;
    document.getElementById('word-count').textContent = (cjk + words) + ' 词';
    document.getElementById('char-count').textContent = chars + ' 字符';
    document.getElementById('line-count').textContent = lines + ' 行';
  }

  textarea.addEventListener('input', updatePreview);

  // 自动保存
  const AUTOSAVE_KEY = 'editor-autosave-draft';
  function saveDraft() {
    const getVal = (id) => { const el = document.getElementById(id); return el ? el.value : ''; };
    const data = {
      content: textarea.value,
      title: getVal('post-title'),
      desc: getVal('post-desc'),
      category: getVal('post-category'),
      tags: getVal('post-tags'),
      cover: window.__editorCoverValue || getVal('post-cover'),
      slug: getVal('post-slug'),
      password: getVal('post-password'),
      passwordHint: getVal('post-password-hint'),
      pinned: window.__editorMetaCheckbox ? window.__editorMetaCheckbox.pinned : false,
      comment: window.__editorMetaCheckbox ? window.__editorMetaCheckbox.comment : true,
      savedAt: new Date().toISOString(),
    };
    try { localStorage.setItem(AUTOSAVE_KEY, JSON.stringify(data)); } catch(e) {}
  }
  setInterval(saveDraft, 30000);

  // 工具栏按钮
  const toolbarConfig = {
    bold:          { prefix: '**',        suffix: '**',     placeholder: '粗体文本' },
    italic:        { prefix: '*',         suffix: '*',      placeholder: '斜体文本' },
    strikethrough: { prefix: '~~',        suffix: '~~',     placeholder: '删除线' },
    h1:            { prefix: '# ',        suffix: '',       placeholder: '标题' },
    h2:            { prefix: '## ',       suffix: '',       placeholder: '标题' },
    h3:            { prefix: '### ',      suffix: '',       placeholder: '标题' },
    h4:            { prefix: '#### ',     suffix: '',       placeholder: '标题' },
    ul:            { prefix: '- ',        suffix: '',       placeholder: '列表项' },
    ol:            { prefix: '1. ',       suffix: '',       placeholder: '列表项' },
    checklist:     { prefix: '- [ ] ',    suffix: '',       placeholder: '任务' },
    quote:         { prefix: '> ',        suffix: '',       placeholder: '引用' },
    code:          { prefix: '`',         suffix: '`',      placeholder: '代码' },
    codeblock:     { prefix: '```javascript\n', suffix: '\n```', placeholder: '代码' },
    table:         { prefix: '| 列1 | 列2 | 列3 |\n| --- | --- | --- |\n| 内容 | 内容 | 内容 |', suffix: '', placeholder: null },
    hr:            { prefix: '\n---\n',   suffix: '',       placeholder: null },
  };
  function toolbarInsert(insert, selectStart, selectEnd) {
    const start = textarea.selectionStart;
    const end = textarea.selectionEnd;
    textarea.focus();
    textarea.selectionStart = start;
    textarea.selectionEnd = end;
    document.execCommand('insertText', false, insert);
    textarea.selectionStart = selectStart;
    textarea.selectionEnd = selectEnd;
    updatePreview();
  }
  document.querySelectorAll('#toolbar [data-action]').forEach(btn => {
    btn.addEventListener('click', () => {
      const action = btn.dataset.action;
      if (action === 'link' || action === 'image') return;
      if (action === 'undo' || action === 'redo') {
        textarea.focus();
        document.execCommand(action);
        return;
      }
      const config = toolbarConfig[action];
      if (!config) return;
      const start = textarea.selectionStart;
      const end = textarea.selectionEnd;
      const selected = textarea.value.substring(start, end);
      const val = textarea.value;
      let insert, selectStart, selectEnd;
      if (selected) {
        // 检测选区前后是否已有 prefix/suffix → 取消包裹
        const hasPrefix = start >= config.prefix.length && val.substring(start - config.prefix.length, start) === config.prefix;
        const hasSuffix = val.substring(end, end + config.suffix.length) === config.suffix;
        if (config.suffix && hasPrefix && hasSuffix) {
          // 取消：移除前后的 prefix/suffix
          insert = selected;
          selectStart = start - config.prefix.length;
          selectEnd = end - config.prefix.length;
          textarea.setRangeText(insert, selectStart, end + config.suffix.length, 'select');
          textarea.selectionStart = selectStart;
          textarea.selectionEnd = selectStart + selected.length;
          textarea.focus();
          textarea.dispatchEvent(new Event('input'));
          updatePreview();
          return;
        }
        insert = config.prefix + selected + config.suffix;
        selectStart = start + config.prefix.length;
        selectEnd = selectStart + selected.length;
      } else if (config.placeholder) {
        insert = config.prefix + config.placeholder + config.suffix;
        selectStart = start + config.prefix.length;
        selectEnd = selectStart + config.placeholder.length;
      } else {
        insert = config.prefix;
        selectStart = selectEnd = start + insert.length;
      }
      toolbarInsert(insert, selectStart, selectEnd);
    });
  });

  // Enter 键自动延续列表（有序/无序/任务/引用）
  textarea.addEventListener('keydown', (e) => {
    if (e.key !== 'Enter') return;
    const start = textarea.selectionStart;
    const val = textarea.value;
    const lineStart = val.lastIndexOf('\n', start - 1) + 1;
    const line = val.substring(lineStart, start);
    const olMatch = line.match(/^(\d+)\.\s/);
    const clMatch = line.match(/^[-*]\s\[[ x]\]\s/);
    const ulMatch = line.match(/^[-*]\s/);
    const qtMatch = line.match(/^>\s/);
    let insert = '\n';
    if (olMatch) {
      const num = parseInt(olMatch[1]);
      const lineContent = line.slice(olMatch[0].length);
      insert = lineContent.trim() ? '\n' + (num + 1) + '. ' : '\n';
    } else if (clMatch) {
      const lineContent = line.slice(clMatch[0].length);
      insert = lineContent.trim() ? '\n- [ ] ' : '\n';
    } else if (ulMatch) {
      const lineContent = line.slice(ulMatch[0].length);
      insert = lineContent.trim() ? '\n' + line.slice(0, ulMatch[0].length) : '\n';
    } else if (qtMatch) {
      const lineContent = line.slice(qtMatch[0].length);
      insert = lineContent.trim() ? '\n> ' : '\n';
    }
    e.preventDefault();
    textarea.focus();
    document.execCommand('insertText', false, insert);
    updatePreview();
  });

  // 视图切换
  const editorPane = document.getElementById('editor-pane');
  const previewPane = document.getElementById('preview-pane');
  const btnEditor = document.getElementById('btn-view-editor');
  const btnSplit = document.getElementById('btn-view-split');
  const btnPreview = document.getElementById('btn-view-preview');

  var editorBody = document.getElementById('editor-body');
  function setView(view) {
    [btnEditor, btnSplit, btnPreview].forEach(b => b && b.classList.remove('active'));
    if (view === 'editor') {
      editorPane.style.display = 'flex';
      previewPane.style.display = 'none';
      btnEditor && btnEditor.classList.add('active');
      editorBody && editorBody.classList.add('single-view');
    } else if (view === 'preview') {
      editorPane.style.display = 'none';
      previewPane.style.display = 'flex';
      btnPreview && btnPreview.classList.add('active');
      editorBody && editorBody.classList.add('single-view');
    } else {
      editorPane.style.display = 'flex';
      previewPane.style.display = 'flex';
      btnSplit && btnSplit.classList.add('active');
      editorBody && editorBody.classList.remove('single-view');
    }
  }

  btnEditor && btnEditor.addEventListener('click', () => setView('editor'));
  btnSplit && btnSplit.addEventListener('click', () => setView('split'));
  btnPreview && btnPreview.addEventListener('click', () => setView('preview'));

  // [Editor] 同步滚动 + 打字机模式
  var syncScrollEnabled = false;
  var typewriterEnabled = false;
  var isSyncingScroll = false;
  var syncScrollTimer = null;
  var previewContent = document.getElementById('preview-content');
  var btnSyncScroll = document.getElementById('btn-sync-scroll');
  var btnTypewriter = document.getElementById('btn-typewriter');

  // 从 localStorage 恢复状态
  if (localStorage.getItem('editor-sync-scroll') === 'true') {
    syncScrollEnabled = true;
    btnSyncScroll && btnSyncScroll.classList.add('active');
  }
  if (localStorage.getItem('editor-typewriter') === 'true') {
    typewriterEnabled = true;
    btnTypewriter && btnTypewriter.classList.add('active');
  }

  btnSyncScroll && btnSyncScroll.addEventListener('click', function() {
    syncScrollEnabled = !syncScrollEnabled;
    this.classList.toggle('active', syncScrollEnabled);
    localStorage.setItem('editor-sync-scroll', syncScrollEnabled);
    textarea.focus();
  });

  btnTypewriter && btnTypewriter.addEventListener('click', function() {
    typewriterEnabled = !typewriterEnabled;
    this.classList.toggle('active', typewriterEnabled);
    localStorage.setItem('editor-typewriter', typewriterEnabled);
    textarea.focus();
  });

  // 同步滚动：编辑器 → 预览
  textarea.addEventListener('scroll', function() {
    if (!syncScrollEnabled || isSyncingScroll || !previewContent) return;
    var editorMax = textarea.scrollHeight - textarea.clientHeight;
    if (editorMax <= 0) return;
    var ratio = textarea.scrollTop / editorMax;
    isSyncingScroll = true;
    previewContent.scrollTop = ratio * (previewContent.scrollHeight - previewContent.clientHeight);
    cancelAnimationFrame(syncScrollTimer);
    syncScrollTimer = requestAnimationFrame(function() { isSyncingScroll = false; });
  });

  // 同步滚动：预览 → 编辑器
  if (previewContent) {
    previewContent.addEventListener('scroll', function() {
      if (!syncScrollEnabled || isSyncingScroll) return;
      var previewMax = previewContent.scrollHeight - previewContent.clientHeight;
      if (previewMax <= 0) return;
      var ratio = previewContent.scrollTop / previewMax;
      isSyncingScroll = true;
      textarea.scrollTop = ratio * (textarea.scrollHeight - textarea.clientHeight);
      cancelAnimationFrame(syncScrollTimer);
      syncScrollTimer = requestAnimationFrame(function() { isSyncingScroll = false; });
    });
  }

  // 打字机模式：光标所在行垂直居中
  function scrollCursorToCenter() {
    if (!typewriterEnabled) return;
    var pos = textarea.selectionStart;
    var text = textarea.value;
    // 全选时跳过（selectionStart=0 会滚到顶部）
    if (pos === 0 && textarea.selectionEnd === text.length) return;
    var lines = text.substring(0, pos).split('\n');
    var lineNum = lines.length - 1;
    var style = getComputedStyle(textarea);
    var lineHeight = parseFloat(style.lineHeight) || 28;
    var paddingTop = parseFloat(style.paddingTop) || 0;
    var cursorY = paddingTop + lineNum * lineHeight;
    var textareaHeight = textarea.clientHeight;
    var target = cursorY - textareaHeight / 2 + lineHeight / 2;
    textarea.scrollTop = target;
  }

  textarea.addEventListener('input', function() { scrollCursorToCenter(); });
  textarea.addEventListener('keyup', function() { scrollCursorToCenter(); });

  // 初始加载时如果打字机模式开启，自动居中光标
  if (typewriterEnabled) {
    requestAnimationFrame(function() { scrollCursorToCenter(); });
  }

  // [Editor] 粘贴图片：剪贴板图片 → Base64 存内存 → 插入 Markdown 图片语法（多张自动包裹 [grid]）
  textarea.addEventListener('paste', function(e) {
    var items = (e.clipboardData || window.clipboardData).items;
    if (!items) return;
    var imageFiles = [];
    for (var i = 0; i < items.length; i++) {
      if (items[i].type.indexOf('image') !== -1) {
        var file = items[i].getAsFile();
        if (file) imageFiles.push(file);
      }
    }
    if (imageFiles.length === 0) return;
    e.preventDefault();

    var imageLines = [];
    var loaded = 0;
    imageFiles.forEach(function(file) {
      compressImage(file).then(function(dataUrl) {
        var ext = file.type.split('/')[1] || 'png';
        var filename = Date.now() + '-' + Math.random().toString(36).slice(2, 8) + '.' + ext;
        window.__editorImageMap[filename] = dataUrl;
        imageLines.push('![图片](./images/' + filename + ')');
        loaded++;
        if (loaded === imageFiles.length) {
          var insertText;
          if (imageLines.length > 1) {
            insertText = '[grid]\n' + imageLines.join('\n') + '\n[/grid]\n';
          } else {
            insertText = imageLines[0] + '\n';
          }
          textarea.focus();
          document.execCommand('insertText', false, insertText);
          window.__editorShowToast(imageFiles.length > 1 ? imageFiles.length + '张图片已粘贴' : '图片已粘贴');
        }
      });
    });
  });

  // [Editor] 拖拽图片：拖入图片文件 → Base64 存内存 → 插入 Markdown 图片语法（多张自动包裹 [grid]）
  textarea.addEventListener('dragover', function(e) {
    e.preventDefault();
    e.dataTransfer.dropEffect = 'copy';
    textarea.classList.add('drag-over');
  });
  textarea.addEventListener('dragleave', function(e) {
    textarea.classList.remove('drag-over');
  });
  textarea.addEventListener('drop', function(e) {
    e.preventDefault();
    textarea.classList.remove('drag-over');
    var files = e.dataTransfer.files;
    if (!files || files.length === 0) return;
    var imageFiles = [];
    for (var i = 0; i < files.length; i++) {
      if (files[i].type.indexOf('image') !== -1) imageFiles.push(files[i]);
    }
    if (imageFiles.length === 0) return;

    var imageLines = [];
    var loaded = 0;
    imageFiles.forEach(function(file) {
      compressImage(file).then(function(dataUrl) {
        var ext = file.type.split('/')[1] || 'png';
        var filename = Date.now() + '-' + Math.random().toString(36).slice(2, 8) + '.' + ext;
        window.__editorImageMap[filename] = dataUrl;
        imageLines.push('![图片](./images/' + filename + ')');
        loaded++;
        if (loaded === imageFiles.length) {
          var insertText;
          if (imageLines.length > 1) {
            insertText = '[grid]\n' + imageLines.join('\n') + '\n[/grid]\n';
          } else {
            insertText = imageLines[0] + '\n';
          }
          textarea.focus();
          document.execCommand('insertText', false, insertText);
          window.__editorShowToast(imageFiles.length > 1 ? imageFiles.length + '张图片已插入' : '图片已插入');
        }
      });
    });
  });

  // [Editor] 自定义滚动条
  function initCustomScrollbars() {
    document.querySelectorAll('.custom-scrollbar').forEach(function(bar) {
      var targetId = bar.getAttribute('data-target');
      var target = document.getElementById(targetId);
      if (!target) return;
      var thumb = bar.querySelector('.custom-scrollbar-thumb');
      var isDragging = false;
      var startY = 0;
      var startScrollTop = 0;

      function updateThumb() {
        var scrollH = target.scrollHeight;
        var clientH = target.clientHeight;
        if (scrollH <= clientH) { bar.style.display = 'none'; return; }
        bar.style.display = '';
        var ratio = clientH / scrollH;
        var thumbH = Math.max(ratio * clientH, 20);
        var maxTop = clientH - thumbH;
        var scrollRatio = target.scrollTop / (scrollH - clientH);
        thumb.style.height = thumbH + 'px';
        thumb.style.top = (scrollRatio * maxTop) + 'px';
      }

      target.addEventListener('scroll', updateThumb);
      updateThumb();

      // 点击轨道跳转
      bar.addEventListener('click', function(e) {
        if (e.target === thumb) return;
        var rect = bar.getBoundingClientRect();
        var clickY = e.clientY - rect.top;
        var scrollH = target.scrollHeight;
        var clientH = target.clientHeight;
        var ratio = clickY / clientH;
        target.scrollTop = ratio * (scrollH - clientH);
      });

      // 拖拽 thumb
      thumb.addEventListener('mousedown', function(e) {
        e.preventDefault();
        isDragging = true;
        startY = e.clientY;
        startScrollTop = target.scrollTop;
        bar.classList.add('active');
        document.addEventListener('mousemove', onDrag);
        document.addEventListener('mouseup', onDragEnd);
      });

      function onDrag(e) {
        if (!isDragging) return;
        var dy = e.clientY - startY;
        var scrollH = target.scrollHeight;
        var clientH = target.clientHeight;
        var thumbH = parseFloat(thumb.style.height) || 20;
        var maxTop = clientH - thumbH;
        var scrollRange = scrollH - clientH;
        var deltaScroll = (dy / maxTop) * scrollRange;
        target.scrollTop = startScrollTop + deltaScroll;
      }

      function onDragEnd() {
        isDragging = false;
        bar.classList.remove('active');
        document.removeEventListener('mousemove', onDrag);
        document.removeEventListener('mouseup', onDragEnd);
      }
    });
  }
  initCustomScrollbars();

  // 置顶/评论切换
  function setToggle(btnId, inputId, value) {
    const btn = document.getElementById(btnId);
    const input = document.getElementById(inputId);
    if (value) { btn.classList.add('active'); input.value = 'true'; }
    else { btn.classList.remove('active'); input.value = 'false'; }
  }

  // 置顶/评论由 IIFE 事件委托处理，此处不再重复绑定

  // [Editor] 封面图上传由右侧面板 IIFE 的事件委托处理（此处跳过）

  // GitHub 弹窗由 IIFE 处理，此处不再重复绑定

  // 图片/链接/草稿弹窗由 IIFE 处理，此处不再重复绑定

  // 快捷键保存（快捷键保留，按钮由 IIFE 处理）
  document.addEventListener('keydown', (e) => {
    if (e.ctrlKey && e.shiftKey && e.key === 'S') { e.preventDefault(); document.getElementById('btn-quick-save').click(); }
  });

  // 初始化
  updatePreview();
}
</script>

<!-- 右侧面板逻辑（独立，不依赖外部脚本） -->
<script is:inline>
(function() {
  var slidePanel = document.getElementById('slide-panel');
  var panelInner = document.getElementById('panel-inner');
  var panelTitle = document.getElementById('panel-title');
  var panelContent = document.getElementById('panel-content');
  var panelClose = document.getElementById('panel-close');

  if (!slidePanel) { console.error('slide-panel not found'); return; }

  // [Editor] 追踪文章信息 checkbox 状态（面板关闭后 DOM 元素消失，用变量保存）
  // 挂到 window 上供其他 IIFE（自动保存等）访问
  if (!window.__editorMetaCheckbox) window.__editorMetaCheckbox = { pinned: false, comment: true };
  var metaCheckboxState = window.__editorMetaCheckbox;

  // [Editor] 追踪封面图 URL（面板关闭后 DOM 元素消失，用变量保存）
  if (!window.__editorCoverValue) window.__editorCoverValue = '';
  // [Editor] 封面图 data URL（用于本地预览和发布时上传）
  if (!window.__editorCoverDataUrl) window.__editorCoverDataUrl = '';
  // [Editor] 封面图文件名（用于发布时上传到 GitHub）
  if (!window.__editorCoverFilename) window.__editorCoverFilename = '';
  // 封面图数据不持久化到 localStorage（刷新后需重新上传），草稿加载时从 editor-draft-cover-{savedAt} 恢复

  var templates = {
    publish: { title: '发布', html: '<div class="space-y-3"><button id="btn-github" class="w-full py-2.5 rounded-lg bg-[var(--primary)] text-white dark:text-black/80 text-sm font-medium hover:opacity-90 transition cursor-pointer">发布到 GitHub</button><button id="btn-download" class="w-full py-2 rounded-lg border border-[var(--line-divider)] text-sm text-black/60 dark:text-white/60 hover:bg-black/5 dark:hover:bg-white/5 transition cursor-pointer">下载 .md 文件</button></div>' },
    meta: { title: '文章信息', html: '<div class="space-y-3"><div><label class="block text-xs font-medium text-black/60 dark:text-white/60 mb-1">标题 <span class="text-red-500">*</span></label><div class="flex gap-2"><input id="post-title-input" type="text" placeholder="请输入文章标题" class="flex-1 px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" /><label class="px-2 py-1.5 rounded-lg border border-[var(--line-divider)] text-xs cursor-pointer select-none flex items-center gap-1 hover:border-[var(--primary)]/40 transition" id="lbl-pinned"> 置顶 <input type="checkbox" id="chk-pinned-panel" class="hidden" /> </label> <label class="px-2 py-1.5 rounded-lg border border-[var(--line-divider)] text-xs cursor-pointer select-none flex items-center gap-1 hover:border-[var(--primary)]/40 transition" id="lbl-comment"> 评论 <input type="checkbox" id="chk-comment-panel" class="hidden" checked /> </label></div></div><div><label class="block text-xs font-medium text-black/60 dark:text-white/60 mb-1">描述</label><textarea id="post-desc" rows="2" placeholder="一句话描述文章内容" class="w-full px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50 resize-none"></textarea></div><div><label class="block text-xs font-medium text-black/60 dark:text-white/60 mb-1">分类</label><input id="post-category" type="text" placeholder="如：技术笔记" class="w-full px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" /></div><div><label class="block text-xs font-medium text-black/60 dark:text-white/60 mb-1">标签 <span class="text-xs text-black/40 dark:text-white/40">（自定义用,隔开）</span></label><div class="flex gap-2"><input id="post-tag-1" type="text" placeholder="标签1" class="w-1/4 min-w-0 px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" /><input id="post-tag-3" type="text" placeholder="自定义标签" class="w-3/4 min-w-0 px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" /></div></div><div><label class="block text-xs font-medium text-black/60 dark:text-white/60 mb-1">封面图</label><div class="flex gap-2 flex-nowrap"><input id="post-cover" type="text" placeholder="图片 URL" class="flex-1 min-w-0 px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" /><label class="flex items-center px-2 py-2 rounded-lg border border-[var(--line-divider)] text-xs text-black/60 dark:text-white/60 hover:border-[var(--primary)]/40 cursor-pointer whitespace-nowrap shrink-0">上传<input id="cover-upload" type="file" accept="image/*" class="hidden" /></label><button id="btn-remove-cover" type="button" class="flex items-center px-2 py-2 rounded-lg border border-[var(--line-divider)] text-xs text-red-400 hover:text-red-600 hover:border-red-400 cursor-pointer whitespace-nowrap shrink-0">删除</button></div><div id="cover-preview" class="mt-2 hidden"><img id="cover-preview-img" class="w-full h-24 object-cover rounded-lg" /></div></div><div><label class="block text-xs font-medium text-black/60 dark:text-white/60 mb-1">密码</label><div class="flex gap-2"><input id="post-password-hint" type="text" placeholder="密码提示" class="w-1/3 min-w-0 px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" /><input id="post-password" type="text" placeholder="输入密码（留空不加密）" class="flex-1 min-w-0 px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" /></div></div></div>' },
    tags: { title: '标签', html: '<div class="space-y-3"><div><label class="block text-xs font-medium text-black/60 dark:text-white/60 mb-1">标签（逗号分隔）</label><input id="post-tags" type="text" placeholder="JavaScript, Astro" class="w-full px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" /></div></div>' },
    cover: { title: '封面图', html: '<div class="space-y-3"><div><label class="block text-xs font-medium text-black/60 dark:text-white/60 mb-1">封面图 URL</label><input id="post-cover" type="text" placeholder="https://..." class="w-full px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" /></div></div>' },
    settings: { title: '设置', html: '<div class="text-sm text-black/50 dark:text-white/50">更多设置开发中...</div>' },
    github: { title: 'GitHub 设置', html: '<div class="space-y-4"><div><label class="block text-xs font-medium text-black/60 dark:text-white/60 mb-1.5">GitHub Token</label><div class="flex gap-2"><input id="gh-token-panel" type="password" placeholder="ghp_xxxxx" class="flex-1 px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" /><button id="btn-save-token" class="px-3 py-2 rounded-lg bg-[var(--primary)] text-white dark:text-black/80 text-xs font-medium hover:opacity-90 transition cursor-pointer whitespace-nowrap">保存</button><button id="btn-clear-gh" class="px-3 py-2 rounded-lg border border-[var(--line-divider)] text-black/60 dark:text-white/60 text-xs hover:bg-black/5 dark:hover:bg-white/5 transition cursor-pointer whitespace-nowrap">清空</button></div><p class="text-xs text-black/40 dark:text-white/40 mt-1">🔒 仅保存在本浏览器，刷新不丢失</p></div><div><label class="block text-xs font-medium text-black/60 dark:text-white/60 mb-1.5">仓库</label><input id="gh-repo-panel" type="text" class="w-full px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" /></div><div><label class="block text-xs font-medium text-black/60 dark:text-white/60 mb-1.5">分支</label><input id="gh-branch-panel" type="text" class="w-full px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" /></div></div>' },
    drafts: { title: '草稿箱', html: '<div style="padding:0 16px;"><div class="space-y-1"><div class="flex gap-2"><input id="draft-name-input" type="text" placeholder="草稿名称" class="flex-1 px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none" /><button id="btn-save-draft" class="px-4 py-2 rounded-lg bg-[var(--primary)] text-white text-sm cursor-pointer">保存</button></div><div id="draft-toolbar" class="flex items-center justify-between" style="padding:4px 0;"><label class="flex items-center gap-1 text-xs text-black/50 dark:text-white/50 cursor-pointer select-none" style="opacity:0;pointer-events:none;"><input type="checkbox" id="draft-select-all" class="rounded" /> 全选</label><button id="btn-delete-selected" class="text-xs text-red-400 hover:text-red-600 cursor-pointer" style="opacity:0;pointer-events:none;">删除选中</button></div></div></div><div id="draft-list" class="text-sm text-black/40 dark:text-white/40" style="max-height:calc(100vh - 200px);overflow-y:auto;padding:0 14px 0 14px;scrollbar-width:none;-ms-overflow-style:none;"></div>' }
  };

  var currentPanel = '';


  function openPanel(name) {
    if (currentPanel === name && slidePanel.style.width === '288px') {
      closePanel();
      return;
    }
    _tocCache = '';
    currentPanel = name;
    document.querySelectorAll('[data-panel]').forEach(function(b) { b.classList.remove('active'); });
    document.querySelectorAll('[data-panel="' + name + '"]').forEach(function(b) { b.classList.add('active'); });
    panelContent.classList.remove('overflow-hidden');
    if (name === 'drafts') {
      panelContent.classList.remove('overflow-y-auto');
      panelContent.classList.add('overflow-hidden');
      panelContent.style.padding = '0';
    } else {
      panelContent.classList.add('overflow-y-auto', 'overflow-x-hidden');
      panelContent.style.padding = '';
    }
    panelContent.classList.add('overflow-x-hidden');
    if (name === 'toc') {
      panelTitle.textContent = '目录';
      renderTocContent();
    } else if (name === 'syntax') {
      panelTitle.textContent = '语法参考';
      renderSyntaxContent();
    } else {
      var t = templates[name];
      if (!t) return;
      panelTitle.textContent = t.title;
      panelContent.innerHTML = t.html;
      if (name === 'meta') {
        var titleInput = document.getElementById('post-title-input');
        var mainTitle = document.getElementById('post-title');
        if (titleInput && mainTitle) titleInput.value = mainTitle.value;
        var syncFields = ['post-desc', 'post-category', 'post-cover', 'post-slug', 'post-password', 'post-password-hint'];
        syncFields.forEach(function(id) {
          var hidden = document.getElementById(id);
          var panel = panelContent.querySelector('#' + id);
          if (hidden && panel && hidden !== panel) panel.value = hidden.value;
        });
        // 同步封面图：data URL 仅在当前会话中有效（不持久化），刷新后需重新上传
        var coverDataUrl = window.__editorCoverDataUrl;
        var coverPath = window.__editorCoverValue || (document.getElementById('post-cover') || {}).value || '';
        var coverPanelInput = panelContent.querySelector('#post-cover');
        if (coverPanelInput) coverPanelInput.value = coverPath;
        var coverPreview = panelContent.querySelector('#cover-preview');
        var coverImg = panelContent.querySelector('#cover-preview-img');
        // 优先用 data URL 预览（本地可用），否则用绝对 URL；相对路径无法在浏览器中解析，不显示预览
        var coverDisplayUrl = coverDataUrl || coverPath;
        var isDisplayable = coverDisplayUrl && (coverDisplayUrl.startsWith('data:') || coverDisplayUrl.startsWith('http://') || coverDisplayUrl.startsWith('https://'));
        if (isDisplayable) {
          if (coverImg) coverImg.src = coverDisplayUrl;
          if (coverPreview) coverPreview.classList.remove('hidden');
        } else {
          if (coverPreview) coverPreview.classList.add('hidden');
        }
        var hiddenTags = document.getElementById('post-tags');
        if (hiddenTags) {
          var tagArr = hiddenTags.value.split(',').map(function(t) { return t.trim(); }).filter(Boolean);
          var tag1 = panelContent.querySelector('#post-tag-1');
          var tag3 = panelContent.querySelector('#post-tag-3');
          if (tag1) tag1.value = tagArr[0] || '';
          if (tag3) tag3.value = tagArr.slice(1).join(', ');
        }
        [['chk-pinned', 'chk-pinned-panel', 'pinned'], ['chk-comment', 'chk-comment-panel', 'comment']].forEach(function(pair) {
          var hidden = document.getElementById(pair[0]);
          var panel = panelContent.querySelector('#' + pair[1]);
          if (hidden && panel) {
            panel.checked = hidden.checked;
            metaCheckboxState[pair[2]] = hidden.checked;
            syncCheckboxStyle(panel);
          }
        });
      }
      if (name === 'drafts') renderDraftList();
      if (name === 'github') {
        // 从 localStorage 恢复 GitHub 设置
        var ghTokenPanel = document.getElementById('gh-token-panel');
        var ghRepoPanel = document.getElementById('gh-repo-panel');
        var ghBranchPanel = document.getElementById('gh-branch-panel');
        if (ghTokenPanel) ghTokenPanel.value = localStorage.getItem('gh-token') || '';
        if (ghRepoPanel) ghRepoPanel.value = localStorage.getItem('gh-repo') || '';
        if (ghBranchPanel) ghBranchPanel.value = localStorage.getItem('gh-branch') || '';
      }
    }
    slidePanel.style.width = '288px';
    panelInner.style.transform = 'translateX(0)';
  }

  function closePanel() {
    slidePanel.style.width = '0px';
    panelInner.style.transform = 'translateX(-100%)';
    currentPanel = '';
    _tocCache = '';
    document.querySelectorAll('[data-panel]').forEach(function(b) { b.classList.remove('active'); });
    panelContent.classList.remove('overflow-y-auto');
    panelContent.classList.add('overflow-hidden');
    // 移除焦点，避免按钮残留 focus 样式
    if (document.activeElement && document.activeElement !== document.body) {
      document.activeElement.blur();
    }
  }

  // [Editor] GitHub 设置保存/清空按钮
  panelContent.addEventListener('click', function(e) {
    if (e.target.id === 'btn-save-token' || e.target.closest('#btn-save-token')) {
      var tokenInput = document.getElementById('gh-token-panel');
      var repoInput = document.getElementById('gh-repo-panel');
      var branchInput = document.getElementById('gh-branch-panel');
      var token = tokenInput ? tokenInput.value.trim() : '';
      var repo = repoInput ? repoInput.value.trim() : '';
      var branch = branchInput ? branchInput.value.trim() : '';
      if (token) localStorage.setItem('gh-token', token); else localStorage.removeItem('gh-token');
      if (repo) localStorage.setItem('gh-repo', repo); else localStorage.removeItem('gh-repo');
      if (branch) localStorage.setItem('gh-branch', branch); else localStorage.removeItem('gh-branch');
      window.__editorShowToast('GitHub 设置已保存');
    }
    if (e.target.id === 'btn-clear-gh' || e.target.closest('#btn-clear-gh')) {
      var tokenInput = document.getElementById('gh-token-panel');
      var repoInput = document.getElementById('gh-repo-panel');
      var branchInput = document.getElementById('gh-branch-panel');
      if (tokenInput) tokenInput.value = '';
      if (repoInput) repoInput.value = '';
      if (branchInput) branchInput.value = '';
      localStorage.removeItem('gh-token');
      localStorage.removeItem('gh-repo');
      localStorage.removeItem('gh-branch');
      window.__editorShowToast('GitHub 设置已清空');
    }
  });

  // [Editor] 格式化时间为 YYYY-MM-DD HH:mm
  function formatDraftTime(isoStr) {
    if (!isoStr) return '';
    var d = new Date(isoStr);
    var pad = function(n) { return n < 10 ? '0' + n : n; };
    return d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate()) + ' ' + pad(d.getHours()) + ':' + pad(d.getMinutes());
  }

  // 草稿列表渲染
  function renderDraftList() {
    var list = document.getElementById('draft-list');
    if (!list) return;
    var drafts = JSON.parse(localStorage.getItem('editor-drafts') || '[]');
    drafts.sort(function(a, b) { return (b.savedAt || '').localeCompare(a.savedAt || ''); });
    var toolbar = document.getElementById('draft-toolbar');
    if (drafts.length === 0) {
      list.innerHTML = '<div class="text-sm text-black/40 dark:text-white/40 text-center py-8">暂无草稿</div>';
      if (toolbar) toolbar.classList.add('hidden');
      return;
    }
    if (toolbar) toolbar.classList.remove('hidden');
    list.innerHTML = drafts.map(function(d) {
      var sid = d.savedAt || '';
      return '<div class="draft-item rounded-lg border border-[var(--line-divider)] hover:border-[var(--primary)]/30 hover:bg-black/5 dark:hover:bg-white/5 transition-colors" data-savedat="' + sid + '" style="padding:4px 12px;margin-bottom:4px;">' +
        '<div class="flex items-center gap-2">' +
          '<input type="checkbox" class="draft-checkbox shrink-0 rounded" data-savedat="' + sid + '" />' +
          '<div class="flex-1 min-w-0 cursor-pointer draft-load" data-savedat="' + sid + '">' +
            '<div class="flex items-center justify-between">' +
              '<div class="text-xs font-bold text-black/80 dark:text-white/80 truncate">' + (d.name || '未命名草稿') + '</div>' +
              '<button class="text-xs text-red-400 hover:text-red-600 shrink-0 draft-delete" data-savedat="' + sid + '">删除</button>' +
            '</div>' +
            '<div class="text-xs text-black/50 dark:text-white/50 mt-1.5" style="background:color-mix(in srgb, currentColor 8%, transparent);padding:8px 12px;border-radius:6px;">' +
              '<div>' + (d.title ? '标题：' + d.title : '无标题') + '</div>' +
              '<div class="mt-1">' + formatDraftTime(d.savedAt) + '</div>' +
            '</div>' +
          '</div>' +
        '</div>' +
      '</div>';
    }).join('');
  }

  // checkbox 切换样式 + 初始化
  function syncCheckboxStyle(chk) {
    var lbl = chk.closest('label');
    if (!lbl) return;
    if (chk.checked) {
      lbl.style.borderColor = 'var(--primary)';
      lbl.style.background = 'color-mix(in srgb, var(--primary) 10%, transparent)';
      lbl.style.color = 'var(--primary)';
    } else {
      lbl.style.borderColor = '';
      lbl.style.background = '';
      lbl.style.color = '';
    }
  }
  panelContent.addEventListener('change', function(e) {
    if (e.target.id === 'chk-pinned-panel' || e.target.id === 'chk-comment-panel') {
      syncCheckboxStyle(e.target);
      // [Editor] 同步到追踪变量和隐藏 checkbox
      var key = e.target.id === 'chk-pinned-panel' ? 'pinned' : 'comment';
      metaCheckboxState[key] = e.target.checked;
      var hiddenId = e.target.id.replace('-panel', '');
      var hidden = document.getElementById(hiddenId);
      if (hidden) hidden.checked = e.target.checked;
    }
    // 草稿复选框变化时更新工具栏可见性
    if (e.target.classList.contains('draft-checkbox')) {
      var checkedCount = panelContent.querySelectorAll('.draft-checkbox:checked').length;
      var toolbar = document.getElementById('draft-toolbar');
      if (toolbar) {
        var label = toolbar.querySelector('label');
        var btn = toolbar.querySelector('button');
        var show = checkedCount > 0;
        if (label) { label.style.opacity = show ? '1' : '0'; label.style.pointerEvents = show ? 'auto' : 'none'; }
        if (btn) { btn.style.opacity = show ? '1' : '0'; btn.style.pointerEvents = show ? 'auto' : 'none'; }
      }
    }
  });
  // [Editor] 面板输入时同步回隐藏字段（确保保存时可读取）
  panelContent.addEventListener('input', function(e) {
    // GitHub 设置面板：仓库和分支输入时自动保存，Token 需手动点保存按钮
    if (e.target.id === 'gh-repo-panel') localStorage.setItem('gh-repo', e.target.value);
    if (e.target.id === 'gh-branch-panel') localStorage.setItem('gh-branch', e.target.value);
    var metaFields = ['post-desc', 'post-category', 'post-cover', 'post-slug', 'post-password', 'post-password-hint'];
    if (metaFields.indexOf(e.target.id) !== -1) {
      var hidden = document.getElementById(e.target.id);
      if (hidden && hidden !== e.target) hidden.value = e.target.value;
    }
    // [Editor] 标签：输入框合并到隐藏字段（第二个框支持逗号分隔多个标签）
    if (e.target.id === 'post-tag-1' || e.target.id === 'post-tag-3') {
      var tags = [];
      var tag1 = panelContent.querySelector('#post-tag-1');
      var tag3 = panelContent.querySelector('#post-tag-3');
      if (tag1 && tag1.value.trim()) tags.push(tag1.value.trim());
      if (tag3 && tag3.value.trim()) {
        tag3.value.split(',').forEach(function(t) {
          var trimmed = t.trim();
          if (trimmed) tags.push(trimmed);
        });
      }
      var hiddenTags = document.getElementById('post-tags');
      if (hiddenTags) hiddenTags.value = tags.join(', ');
    }
  });
  // 打开面板时初始化已有 checkbox 的样式
  var origOpenPanel = openPanel;
  openPanel = function(name) {
    origOpenPanel(name);
    setTimeout(function() {
      var chks = panelContent.querySelectorAll('#chk-pinned-panel, #chk-comment-panel');
      chks.forEach(function(c) { syncCheckboxStyle(c); });
    }, 0);
  };

  // 事件委托 - 面板内所有按钮
  panelContent.addEventListener('click', function(e) {
    var target = e.target;

    // 置顶
    if (target.id === 'btn-pinned' || target.closest('#btn-pinned')) {
      var btn = target.id === 'btn-pinned' ? target : target.closest('#btn-pinned');
      btn.classList.toggle('active');
      return;
    }
    // 评论
    if (target.id === 'btn-comment' || target.closest('#btn-comment')) {
      var btn = target.id === 'btn-comment' ? target : target.closest('#btn-comment');
      btn.classList.toggle('active');
      return;
    }
    // 发布到 GitHub
    if (target.id === 'btn-github' || target.closest('#btn-github')) {
      document.getElementById('github-modal').classList.remove('hidden');
      closePanel();
      return;
    }
    // 下载 MD
    if (target.id === 'btn-download' || target.closest('#btn-download')) {
      var title = document.getElementById('post-title').value || 'untitled';
      var getVal = function(id) { var el = document.getElementById(id); return el ? el.value : ''; };
      var desc = getVal('post-desc');
      var category = getVal('post-category');
      var tags = getVal('post-tags');
      var cover = window.__editorCoverValue || getVal('post-cover');
      var password = getVal('post-password');
      var passwordHint = getVal('post-password-hint');
      var pinned = (metaCheckboxState && metaCheckboxState.pinned) || false;
      var comment = (metaCheckboxState && metaCheckboxState.comment !== undefined) ? metaCheckboxState.comment : true;
      // 构建 frontmatter
      var fm = '---\n';
      fm += 'title: "' + title + '"\n';
      fm += 'published: ' + new Date().toISOString().split('T')[0] + '\n';
      fm += 'draft: false\n';
      if (desc) fm += 'description: "' + desc + '"\n';
      if (category) fm += 'category: "' + category + '"\n';
      if (tags) {
        var tagArr = tags.split(',').map(function(t) { return t.trim(); }).filter(Boolean);
        if (tagArr.length > 0) fm += 'tags: [' + tagArr.join(', ') + ']\n';
      }
      if (cover && cover.indexOf('data:') !== 0) fm += 'image: "' + cover + '"\n';
      if (password) fm += 'password: "' + password + '"\n';
      if (passwordHint) fm += 'passwordHint: "' + passwordHint + '"\n';
      if (pinned) fm += 'pinned: true\n';
      if (comment === false) fm += 'comment: false\n';
      fm += '---\n\n';
      var textarea = document.getElementById('markdown-input');
      var blob = new Blob([fm + textarea.value], { type: 'text/markdown' });
      var a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = title + '.md';
