<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.9.0/build/styles/atom-one-dark.min.css">



<script is:inline>
(function loadScript(src) {
  return new Promise((resolve, reject) => {
    if (document.querySelector('script[src="' + src + '"]')) { resolve(); return; }
    const s = document.createElement('script');
    s.src = src;
    s.onload = resolve;
    s.onerror = reject;
    document.head.appendChild(s);
  });
})('https://cdn.jsdelivr.net/npm/marked/marked.min.js').then(() => {
  return new Promise((resolve) => {
    const src = 'https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.9.0/build/highlight.min.js';
    if (document.querySelector('script[src="' + src + '"]')) { resolve(); return; }
    const s = document.createElement('script');
    s.src = src;
 s.onload = resolve;
    s.onerror = resolve;
    document.head.appendChild(s);
  });
}).then(() => initEditor());

function initEditor() {
  const textarea = document.getElementById('markdown-input');
  const preview = document.getElementById('preview-content');
  const fullscreenContent = document.getElementById('fullscreen-content');

  // marked 配置
  if (typeof marked !== 'undefined') {
    const renderer = new marked.Renderer();
    renderer.code = function(obj) {
      const code = typeof obj === 'object' ? obj.text : obj;
      const lang = typeof obj === 'object' ? obj.lang : arguments[1];
      let highlighted = code;
      if (typeof hljs !== 'undefined') {
        if (lang && hljs.getLanguage(lang)) {
          try { highlighted = hljs.highlight(code, { language: lang }).value; } catch(e) {}
        } else {
          try { highlighted = hljs.highlightAuto(code).value; } catch(e) {}
        }
      }
      const cls = lang ? ' class="hljs language-' + lang + '"' : ' class="hljs"';
      return '<pre><code' + cls + '>' + highlighted + '</code></pre>';
    };
    marked.setOptions({ breaks: true, gfm: true, renderer: renderer });
  }

  // 实时预览
  let previewTimer = null;
  let previewRaf = null;
  function updatePreview() {
    if (previewRaf) return;
    previewRaf = requestAnimationFrame(function() {
      previewRaf = null;
      clearTimeout(previewTimer);
      previewTimer = setTimeout(() => {
        const md = textarea.value;
        let html = '';
        try { html = (typeof marked !== 'undefined') ? marked.parse(md) : md.replace(/\n/g, '<br>'); }
 catch(e) { html = '<p style="color:red">渲染错误: ' + e.message + '</p>'; }
        preview.innerHTML = html || '<div class="text-black/30 dark:text-white/30 text-sm italic">预览区域</div>';
        if (fullscreenContent) fullscreenContent.innerHTML = preview.innerHTML;
        updateCounts(md);
      }, 30);
    });
  }

  function updateCounts(text) {
    const lines = text.split('\n').length;
    const chars = text.length;
    const cjk = (text.match(/[\u4e00-\u9fff\u3400-\u4dbf]/g) || []).length;
    const words = (text.match(/[a-zA-Z]+/g) || []).length;
    document.getElementById('word-count').textContent = (cjk + words) + ' 词';
    document.getElementById('char-count').textContent = chars + ' 字符';
    document.getElementById('line-count').textContent = lines + ' 行';
  }

  textarea.addEventListener('input', updatePreview);

  // 自动保存
  const AUTOSAVE_KEY = 'editor-autosave-draft';
  function saveDraft() {
    const getVal = (id) => { const el = document.getElementById(id); return el ? el.value : ''; };
    const data = {
      content: textarea.value,
      title: getVal('post-title'),
      desc: getVal('post-desc'),
      category: getVal('post-category'),
      tags: getVal('post-tags'),
      cover: getVal('post-cover'),
      slug: getVal('post-slug'),
      password: getVal('post-password'),
      passwordHint: getVal('post-password-hint'),
      pinned: window.__editorMetaCheckbox ? window.__editorMetaCheckbox.pinned : false,
      comment: window.__editorMetaCheckbox ? window.__editorMetaCheckbox.comment : true,
      savedAt: new Date().toISOString(),
    };
    try { localStorage.setItem(AUTOSAVE_KEY, JSON.stringify(data)); } catch(e) {}
  }
  setInterval(saveDraft, 30000);

  // 工具栏按钮
  const toolbarConfig = {
    bold:          { prefix: '**',        suffix: '**',     placeholder: '粗体文本' },
    italic:        { prefix: '*',         suffix: '*',      placeholder: '斜体文本' },
    strikethrough: { prefix: '~~',        suffix: '~~',     placeholder: '删除线' },
    h1:            { prefix: '# ',        suffix: '',       placeholder: '标题' },
    h2:            { prefix: '## ',       suffix: '',       placeholder: '标题' },
    h3:            { prefix: '### ',      suffix: '',       placeholder: '标题' },
    h4:            { prefix: '#### ',     suffix: '',       placeholder: '标题' },
    ul:            { prefix: '- ',        suffix: '',       placeholder: '列表项' },
    ol:            { prefix: '1. ',       suffix: '',       placeholder: '列表项' },
    checklist:     { prefix: '- [ ] ',    suffix: '',       placeholder: '任务' },
    quote:         { prefix: '> ',        suffix: '',       placeholder: '引用' },
    code:          { prefix: '`',         suffix: '`',      placeholder: '代码' },
    codeblock:     { prefix: '```javascript\n', suffix: '\n```', placeholder: '代码' },
    table:         { prefix: '| 列1 | 列2 | 列3 |\n| --- | --- | --- |\n| 内容 | 内容 | 内容 |', suffix: '', placeholder: null },
    hr:            { prefix: '\n---\n',   suffix: '',       placeholder: null },
  };
  function toolbarInsert(insert, selectStart, selectEnd) {
    const start = textarea.selectionStart;
    const end = textarea.selectionEnd;
    textarea.focus();
    textarea.selectionStart = start;
    textarea.selectionEnd = end;
    document.execCommand('insertText', false, insert);
    textarea.selectionStart = selectStart;
    textarea.selectionEnd = selectEnd;
    updatePreview();
  }
  document.querySelectorAll('#toolbar [data-action]').forEach(btn => {
    btn.addEventListener('click', () => {
      const action = btn.dataset.action;
      if (action === 'link' || action === 'image') return;
      if (action === 'undo' || action === 'redo') {
        textarea.focus();
        document.execCommand(action);
        return;
      }
      const config = toolbarConfig[action];
      if (!config) return;
      const start = textarea.selectionStart;
      const end = textarea.selectionEnd;
      const selected = textarea.value.substring(start, end);
      let insert, selectStart, selectEnd;
      if (selected) {
        insert = config.prefix + selected + config.suffix;
        selectStart = start + config.prefix.length;
        selectEnd = selectStart + selected.length;
      } else if (config.placeholder) {
        insert = config.prefix + config.placeholder + config.suffix;
        selectStart = start + config.prefix.length;
        selectEnd = selectStart + config.placeholder.length;
      } else {
        insert = config.prefix;
        selectStart = selectEnd = start + insert.length;
      }
      toolbarInsert(insert, selectStart, selectEnd);
    });
  });

  // Enter 键自动延续列表（有序/无序/任务/引用）
  textarea.addEventListener('keydown', (e) => {
    if (e.key !== 'Enter') return;
    const start = textarea.selectionStart;
    const val = textarea.value;
    const lineStart = val.lastIndexOf('\n', start - 1) + 1;
    const line = val.substring(lineStart, start);
    const olMatch = line.match(/^(\d+)\.\s/);
    const clMatch = line.match(/^[-*]\s\[[ x]\]\s/);
    const ulMatch = line.match(/^[-*]\s/);
    const qtMatch = line.match(/^>\s/);
    let insert = '\n';
    if (olMatch) {
      const num = parseInt(olMatch[1]);
      const lineContent = line.slice(olMatch[0].length);
      insert = lineContent.trim() ? '\n' + (num + 1) + '. ' : '\n';
    } else if (clMatch) {
      const lineContent = line.slice(clMatch[0].length);
      insert = lineContent.trim() ? '\n- [ ] ' : '\n';
    } else if (ulMatch) {
      const lineContent = line.slice(ulMatch[0].length);
      insert = lineContent.trim() ? '\n' + line.slice(0, ulMatch[0].length) : '\n';
    } else if (qtMatch) {
      const lineContent = line.slice(qtMatch[0].length);
      insert = lineContent.trim() ? '\n> ' : '\n';
    }
    e.preventDefault();
    textarea.focus();
    document.execCommand('insertText', false, insert);
    updatePreview();
  });

  // 视图切换
  const editorPane = document.getElementById('editor-pane');
  const previewPane = document.getElementById('preview-pane');
  const btnEditor = document.getElementById('btn-view-editor');
  const btnSplit = document.getElementById('btn-view-split');
  const btnPreview = document.getElementById('btn-view-preview');

  function setView(view) {
    [btnEditor, btnSplit, btnPreview].forEach(b => b && b.classList.remove('active'));
    if (view === 'editor') {
      editorPane.style.display = 'flex';
      previewPane.style.display = 'none';
      btnEditor && btnEditor.classList.add('active');
    } else if (view === 'preview') {
      editorPane.style.display = 'none';
      previewPane.style.display = 'flex';
      btnPreview && btnPreview.classList.add('active');
    } else {
      editorPane.style.display = 'flex';
      previewPane.style.display = 'flex';
      btnSplit && btnSplit.classList.add('active');
    }
  }

  btnEditor && btnEditor.addEventListener('click', () => setView('editor'));
  btnSplit && btnSplit.addEventListener('click', () => setView('split'));
  btnPreview && btnPreview.addEventListener('click', () => setView('preview'));

  // [Editor] 同步滚动 + 打字机模式
  var syncScrollEnabled = false;
  var typewriterEnabled = false;
  var isSyncingScroll = false;
  var syncScrollTimer = null;
  var previewContent = document.getElementById('preview-content');
  var btnSyncScroll = document.getElementById('btn-sync-scroll');
  var btnTypewriter = document.getElementById('btn-typewriter');

  // 从 localStorage 恢复状态
  if (localStorage.getItem('editor-sync-scroll') === 'true') {
    syncScrollEnabled = true;
    btnSyncScroll && btnSyncScroll.classList.add('active');
  }
  if (localStorage.getItem('editor-typewriter') === 'true') {
    typewriterEnabled = true;
    btnTypewriter && btnTypewriter.classList.add('active');
  }

  btnSyncScroll && btnSyncScroll.addEventListener('click', function() {
    syncScrollEnabled = !syncScrollEnabled;
    this.classList.toggle('active', syncScrollEnabled);
    localStorage.setItem('editor-sync-scroll', syncScrollEnabled);
  });

  btnTypewriter && btnTypewriter.addEventListener('click', function() {
    typewriterEnabled = !typewriterEnabled;
    this.classList.toggle('active', typewriterEnabled);
    localStorage.setItem('editor-typewriter', typewriterEnabled);
    if (typewriterEnabled) {
      textarea.style.scrollBehavior = 'smooth';
      scrollCursorToCenter();
      setTimeout(function() { textarea.style.scrollBehavior = ''; }, 300);
    }
  });

  // 同步滚动：编辑器 → 预览
  textarea.addEventListener('scroll', function() {
    if (!syncScrollEnabled || isSyncingScroll || !previewContent) return;
    var editorMax = textarea.scrollHeight - textarea.clientHeight;
    if (editorMax <= 0) return;
    var ratio = textarea.scrollTop / editorMax;
    isSyncingScroll = true;
    previewContent.scrollTop = ratio * (previewContent.scrollHeight - previewContent.clientHeight);
    cancelAnimationFrame(syncScrollTimer);
    syncScrollTimer = requestAnimationFrame(function() { isSyncingScroll = false; });
  });

  // 同步滚动：预览 → 编辑器
  if (previewContent) {
    previewContent.addEventListener('scroll', function() {
      if (!syncScrollEnabled || isSyncingScroll) return;
      var previewMax = previewContent.scrollHeight - previewContent.clientHeight;
      if (previewMax <= 0) return;
      var ratio = previewContent.scrollTop / previewMax;
      isSyncingScroll = true;
      textarea.scrollTop = ratio * (textarea.scrollHeight - textarea.clientHeight);
      cancelAnimationFrame(syncScrollTimer);
      syncScrollTimer = requestAnimationFrame(function() { isSyncingScroll = false; });
    });
  }

  // 打字机模式：光标所在行垂直居中
  function scrollCursorToCenter() {
    if (!typewriterEnabled) return;
    var pos = textarea.selectionStart;
    var text = textarea.value;
    // 全选时跳过（selectionStart=0 会滚到顶部）
    if (pos === 0 && textarea.selectionEnd === text.length) return;
    var lines = text.substring(0, pos).split('\n');
    var lineNum = lines.length - 1;
    var style = getComputedStyle(textarea);
    var lineHeight = parseFloat(style.lineHeight) || 28;
    var paddingTop = parseFloat(style.paddingTop) || 0;
    var cursorY = paddingTop + lineNum * lineHeight;
    var textareaHeight = textarea.clientHeight;
    var target = cursorY - textareaHeight / 2 + lineHeight / 2;
    textarea.scrollTop = target;
  }

  textarea.addEventListener('input', function() { scrollCursorToCenter(); });
  textarea.addEventListener('keyup', function() { scrollCursorToCenter(); });

  // 初始加载时如果打字机模式开启，自动居中光标
  if (typewriterEnabled) {
    requestAnimationFrame(function() { scrollCursorToCenter(); });
  }

  // [Editor] 自定义滚动条
  function initCustomScrollbars() {
    document.querySelectorAll('.custom-scrollbar').forEach(function(bar) {
      var targetId = bar.getAttribute('data-target');
      var target = document.getElementById(targetId);
      if (!target) return;
      var thumb = bar.querySelector('.custom-scrollbar-thumb');
      var isDragging = false;
      var startY = 0;
      var startScrollTop = 0;

      function updateThumb() {
        var scrollH = target.scrollHeight;
        var clientH = target.clientHeight;
        if (scrollH <= clientH) { bar.style.display = 'none'; return; }
        bar.style.display = '';
        var ratio = clientH / scrollH;
        var thumbH = Math.max(ratio * clientH, 20);
        var maxTop = clientH - thumbH;
        var scrollRatio = target.scrollTop / (scrollH - clientH);
        thumb.style.height = thumbH + 'px';
        thumb.style.top = (scrollRatio * maxTop) + 'px';
      }

      target.addEventListener('scroll', updateThumb);
      updateThumb();

      // 点击轨道跳转
      bar.addEventListener('click', function(e) {
        if (e.target === thumb) return;
        var rect = bar.getBoundingClientRect();
        var clickY = e.clientY - rect.top;
        var scrollH = target.scrollHeight;
        var clientH = target.clientHeight;
        var ratio = clickY / clientH;
        target.scrollTop = ratio * (scrollH - clientH);
      });

      // 拖拽 thumb
      thumb.addEventListener('mousedown', function(e) {
        e.preventDefault();
        isDragging = true;
        startY = e.clientY;
        startScrollTop = target.scrollTop;
        bar.classList.add('active');
        document.addEventListener('mousemove', onDrag);
        document.addEventListener('mouseup', onDragEnd);
      });

      function onDrag(e) {
        if (!isDragging) return;
        var dy = e.clientY - startY;
        var scrollH = target.scrollHeight;
        var clientH = target.clientHeight;
        var thumbH = parseFloat(thumb.style.height) || 20;
        var maxTop = clientH - thumbH;
        var scrollRange = scrollH - clientH;
        var deltaScroll = (dy / maxTop) * scrollRange;
        target.scrollTop = startScrollTop + deltaScroll;
      }

      function onDragEnd() {
        isDragging = false;
        bar.classList.remove('active');
        document.removeEventListener('mousemove', onDrag);
        document.removeEventListener('mouseup', onDragEnd);
      }
    });
  }
  initCustomScrollbars();

  // 置顶/评论切换
  function setToggle(btnId, inputId, value) {
    const btn = document.getElementById(btnId);
    const input = document.getElementById(inputId);
    if (value) { btn.classList.add('active'); input.value = 'true'; }
    else { btn.classList.remove('active'); input.value = 'false'; }
  }

  // 置顶/评论由 IIFE 事件委托处理，此处不再重复绑定

  // [Editor] 封面图上传由右侧面板 IIFE 的事件委托处理（此处跳过）

  // GitHub 弹窗由 IIFE 处理，此处不再重复绑定

  // 图片/链接/草稿弹窗由 IIFE 处理，此处不再重复绑定

  // 快捷键保存（快捷键保留，按钮由 IIFE 处理）
  document.addEventListener('keydown', (e) => {
    if (e.ctrlKey && e.shiftKey && e.key === 'S') { e.preventDefault(); document.getElementById('btn-quick-save').click(); }
  });

  // 初始化
  updatePreview();
}
</script>

<!-- 右侧面板逻辑（独立，不依赖外部脚本） -->
<script is:inline>
(function() {
  var slidePanel = document.getElementById('slide-panel');
  var panelTitle = document.getElementById('panel-title');
  var panelContent = document.getElementById('panel-content');
  var panelClose = document.getElementById('panel-close');

  if (!slidePanel) { console.error('slide-panel not found'); return; }

  // [Editor] 追踪文章信息 checkbox 状态（面板关闭后 DOM 元素消失，用变量保存）
  // 挂到 window 上供其他 IIFE（自动保存等）访问
  if (!window.__editorMetaCheckbox) window.__editorMetaCheckbox = { pinned: false, comment: true };
  var metaCheckboxState = window.__editorMetaCheckbox;

  var templates = {
    publish: { title: '发布', html: '<div class="space-y-3"><button id="btn-github" class="w-full py-2.5 rounded-lg bg-[var(--primary)] text-white dark:text-black/80 text-sm font-medium hover:opacity-90 transition cursor-pointer">发布到 GitHub</button><button id="btn-download" class="w-full py-2 rounded-lg border border-[var(--line-divider)] text-sm text-black/60 dark:text-white/60 hover:bg-black/5 dark:hover:bg-white/5 transition cursor-pointer">下载 .md 文件</button></div>' },
    meta: { title: '文章信息', html: '<div class="space-y-3"><div><label class="block text-xs font-medium text-black/60 dark:text-white/60 mb-1">标题 <span class="text-red-500">*</span></label><div class="flex gap-2"><input id="post-title-input" type="text" placeholder="请输入文章标题" class="flex-1 px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" /><label class="px-2 py-1.5 rounded-lg border border-[var(--line-divider)] text-xs cursor-pointer select-none flex items-center gap-1 hover:border-[var(--primary)]/40 transition" id="lbl-pinned"> 📌 置顶 <input type="checkbox" id="chk-pinned-panel" class="hidden" /> </label> <label class="px-2 py-1.5 rounded-lg border border-[var(--line-divider)] text-xs cursor-pointer select-none flex items-center gap-1 hover:border-[var(--primary)]/40 transition" id="lbl-comment"> 💬 评论 <input type="checkbox" id="chk-comment-panel" class="hidden" checked /> </label></div></div><div><label class="block text-xs font-medium text-black/60 dark:text-white/60 mb-1">描述</label><textarea id="post-desc" rows="2" placeholder="一句话描述文章内容" class="w-full px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50 resize-none"></textarea></div><div><label class="block text-xs font-medium text-black/60 dark:text-white/60 mb-1">分类</label><input id="post-category" type="text" placeholder="如：技术笔记" class="w-full px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" /></div><div><label class="block text-xs font-medium text-black/60 dark:text-white/60 mb-1">标签</label><div class="flex gap-2"><input id="post-tag-1" type="text" placeholder="标签1" class="flex-1 min-w-0 px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" /><input id="post-tag-2" type="text" placeholder="标签2" class="flex-1 min-w-0 px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" /></div><div class="mt-1"><span class="text-xs text-black/40 dark:text-white/40">（用,隔开）</span><input id="post-tag-3" type="text" placeholder="自定义标签" class="w-full min-w-0 px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" /></div></div><div><label class="block text-xs font-medium text-black/60 dark:text-white/60 mb-1">封面图</label><div class="flex gap-2"><input id="post-cover" type="text" placeholder="图片 URL" class="flex-1 px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" /><label class="px-3 py-2 rounded-lg border border-[var(--line-divider)] text-xs text-black/60 dark:text-white/60 hover:border-[var(--primary)]/40 cursor-pointer">上传<input id="cover-upload" type="file" accept="image/*" class="hidden" /></label><button id="btn-remove-cover" type="button" class="px-3 py-2 rounded-lg border border-[var(--line-divider)] text-xs text-red-400 hover:text-red-600 hover:border-red-400 cursor-pointer">删除</button></div><div id="cover-preview" class="mt-2 hidden"><img id="cover-preview-img" class="w-full h-24 object-cover rounded-lg" /></div></div><div><label class="block text-xs font-medium text-black/60 dark:text-white/60 mb-1">密码</label><div class="flex gap-2"><input id="post-password-hint" type="text" placeholder="密码提示" class="w-1/3 min-w-0 px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" /><input id="post-password" type="text" placeholder="输入密码（留空不加密）" class="flex-1 min-w-0 px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" /></div></div></div>' },
    tags: { title: '标签', html: '<div class="space-y-3"><div><label class="block text-xs font-medium text-black/60 dark:text-white/60 mb-1">标签（逗号分隔）</label><input id="post-tags" type="text" placeholder="JavaScript, Astro" class="w-full px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" /></div></div>' },
    cover: { title: '封面图', html: '<div class="space-y-3"><div><label class="block text-xs font-medium text-black/60 dark:text-white/60 mb-1">封面图 URL</label><input id="post-cover" type="text" placeholder="https://..." class="w-full px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50" /></div></div>' },
    settings: { title: '设置', html: '<div class="text-sm text-black/50 dark:text-white/50">更多设置开发中...</div>' },
    drafts: { title: '草稿箱', html: '<div class="space-y-3"><div class="flex gap-2"><input id="draft-name-input" type="text" placeholder="草稿名称" class="flex-1 px-3 py-2 rounded-lg border border-[var(--line-divider)] bg-transparent text-sm text-black/90 dark:text-white/90 focus:outline-none" /><button id="btn-save-draft" class="px-4 py-2 rounded-lg bg-[var(--primary)] text-white text-sm cursor-pointer">保存</button></div><div id="draft-list" class="text-sm text-black/40 dark:text-white/40 text-center py-8">暂无草稿</div></div>' }
  };

  var currentPanel = '';

  function openPanel(name) {
    if (currentPanel === name && slidePanel.style.width === '288px') {
      closePanel();
      return;
    }
    currentPanel = name;
    var t = templates[name];
    if (!t) return;
    panelTitle.textContent = t.title;
    panelContent.innerHTML = t.html;
    slidePanel.style.width = '288px';
    document.querySelectorAll('[data-panel]').forEach(function(b) { b.classList.remove('active'); });
    document.querySelectorAll('[data-panel="' + name + '"]').forEach(function(b) { b.classList.add('active'); });
    // [Editor] 打开文章信息面板时，从隐藏字段同步值到面板
    if (name === 'meta') {
      var titleInput = document.getElementById('post-title-input');
      var mainTitle = document.getElementById('post-title');
      if (titleInput && mainTitle) titleInput.value = mainTitle.value;
      // 同步隐藏字段值到面板新元素（querySelector 优先找面板内的元素）
      var syncFields = ['post-desc', 'post-category', 'post-cover', 'post-slug', 'post-password', 'post-password-hint'];
      syncFields.forEach(function(id) {
        var hidden = document.getElementById(id);
        var panel = panelContent.querySelector('#' + id);
        if (hidden && panel && hidden !== panel) panel.value = hidden.value;
      });
      // [Editor] 标签：从隐藏字段拆分到输入框（前两个单标签 + 第三个自定义多标签）
      var hiddenTags = document.getElementById('post-tags');
      if (hiddenTags) {
        var tagArr = hiddenTags.value.split(',').map(function(t) { return t.trim(); }).filter(Boolean);
        var tag1 = panelContent.querySelector('#post-tag-1');
        var tag2 = panelContent.querySelector('#post-tag-2');
        var tag3 = panelContent.querySelector('#post-tag-3');
        if (tag1) tag1.value = tagArr[0] || '';
        if (tag2) tag2.value = tagArr[1] || '';
        if (tag3) tag3.value = tagArr.slice(2).join(', ');
      }
      // 同步隐藏 checkbox 到面板 checkbox（面板用 -panel 后缀避免 ID 冲突）
      [['chk-pinned', 'chk-pinned-panel', 'pinned'], ['chk-comment', 'chk-comment-panel', 'comment']].forEach(function(pair) {
        var hidden = document.getElementById(pair[0]);
        var panel = panelContent.querySelector('#' + pair[1]);
        if (hidden && panel) {
          panel.checked = hidden.checked;
          metaCheckboxState[pair[2]] = hidden.checked;
          syncCheckboxStyle(panel);
        }
      });
    }
    // 草稿列表
    if (name === 'drafts') renderDraftList();
  }

  function closePanel() {
    slidePanel.style.width = '0px';
    currentPanel = '';
    document.querySelectorAll('[data-panel]').forEach(function(b) { b.classList.remove('active'); });
  }

  // [Editor] 格式化时间为 YYYY-MM-DD HH:mm
  function formatDraftTime(isoStr) {
    if (!isoStr) return '';
    var d = new Date(isoStr);
    var pad = function(n) { return n < 10 ? '0' + n : n; };
    return d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate()) + ' ' + pad(d.getHours()) + ':' + pad(d.getMinutes());
  }

  // 草稿列表渲染
  function renderDraftList() {
    var list = document.getElementById('draft-list');
    if (!list) return;
    var drafts = JSON.parse(localStorage.getItem('editor-drafts') || '[]');
    if (drafts.length === 0) {
      list.innerHTML = '<div class="text-sm text-black/40 dark:text-white/40 text-center py-8">暂无草稿</div>';
      return;
    }
    list.innerHTML = drafts.map(function(d, i) {
      return '<div class="flex items-center justify-between p-2.5 rounded-lg hover:bg-black/5 dark:hover:bg-white/5 cursor-pointer draft-item border border-transparent hover:border-[var(--line-divider)] transition-colors" data-index="' + i + '">' +
        '<div class="flex-1 min-w-0">' +
          '<div class="text-sm font-bold text-[var(--primary)] truncate">' + (d.name || '未命名草稿') + '</div>' +
          '<div class="text-xs text-black/50 dark:text-white/50 truncate mt-0.5">' + (d.title ? '标题：' + d.title : '无标题') + '</div>' +
          '<div class="text-[10px] text-black/30 dark:text-white/30 mt-1">' + formatDraftTime(d.savedAt) + '</div>' +
        '</div>' +
        '<button class="text-xs text-red-400 hover:text-red-600 ml-2 shrink-0 draft-delete" data-index="' + i + '">删除</button></div>';
    }).join('');
  }

  // checkbox 切换样式 + 初始化
  function syncCheckboxStyle(chk) {
    var lbl = chk.closest('label');
    if (!lbl) return;
    if (chk.checked) {
      lbl.style.borderColor = 'var(--primary)';
      lbl.style.background = 'color-mix(in srgb, var(--primary) 10%, transparent)';
      lbl.style.color = 'var(--primary)';
    } else {
      lbl.style.borderColor = '';
      lbl.style.background = '';
      lbl.style.color = '';
    }
  }
  panelContent.addEventListener('change', function(e) {
    if (e.target.id === 'chk-pinned-panel' || e.target.id === 'chk-comment-panel') {
      syncCheckboxStyle(e.target);
      // [Editor] 同步到追踪变量和隐藏 checkbox
      var key = e.target.id === 'chk-pinned-panel' ? 'pinned' : 'comment';
      metaCheckboxState[key] = e.target.checked;
      var hiddenId = e.target.id.replace('-panel', '');
      var hidden = document.getElementById(hiddenId);
      if (hidden) hidden.checked = e.target.checked;
    }
  });
  // [Editor] 面板输入时同步回隐藏字段（确保保存时可读取）
  panelContent.addEventListener('input', function(e) {
    var metaFields = ['post-desc', 'post-category', 'post-cover', 'post-slug', 'post-password', 'post-password-hint'];
    if (metaFields.indexOf(e.target.id) !== -1) {
      var hidden = document.getElementById(e.target.id);
      if (hidden && hidden !== e.target) hidden.value = e.target.value;
    }
    // [Editor] 标签：输入框合并到隐藏字段（第三个框支持逗号分隔多个标签）
    if (e.target.id === 'post-tag-1' || e.target.id === 'post-tag-2' || e.target.id === 'post-tag-3') {
      var tags = [];
      var tag1 = panelContent.querySelector('#post-tag-1');
      var tag2 = panelContent.querySelector('#post-tag-2');
      var tag3 = panelContent.querySelector('#post-tag-3');
      if (tag1 && tag1.value.trim()) tags.push(tag1.value.trim());
      if (tag2 && tag2.value.trim()) tags.push(tag2.value.trim());
      if (tag3 && tag3.value.trim()) {
        tag3.value.split(',').forEach(function(t) {
          var trimmed = t.trim();
          if (trimmed) tags.push(trimmed);
        });
      }
      var hiddenTags = document.getElementById('post-tags');
      if (hiddenTags) hiddenTags.value = tags.join(', ');
    }
  });
  // 打开面板时初始化已有 checkbox 的样式
  var origOpenPanel = openPanel;
  openPanel = function(name) {
    origOpenPanel(name);
    setTimeout(function() {
      var chks = panelContent.querySelectorAll('#chk-pinned-panel, #chk-comment-panel');
      chks.forEach(function(c) { syncCheckboxStyle(c); });
    }, 0);
  };

  // 事件委托 - 面板内所有按钮
  panelContent.addEventListener('click', function(e) {
    var target = e.target;

    // 置顶
    if (target.id === 'btn-pinned' || target.closest('#btn-pinned')) {
      var btn = target.id === 'btn-pinned' ? target : target.closest('#btn-pinned');
      btn.classList.toggle('active');
      return;
    }
    // 评论
    if (target.id === 'btn-comment' || target.closest('#btn-comment')) {
      var btn = target.id === 'btn-comment' ? target : target.closest('#btn-comment');
      btn.classList.toggle('active');
      return;
    }
    // 发布到 GitHub
    if (target.id === 'btn-github' || target.closest('#btn-github')) {
      document.getElementById('github-modal').classList.remove('hidden');
      closePanel();
      return;
    }
    // 下载 MD
    if (target.id === 'btn-download' || target.closest('#btn-download')) {
      var title = document.getElementById('post-title').value || 'untitled';
      var textarea = document.getElementById('markdown-input');
      var blob = new Blob([textarea.value], { type: 'text/markdown' });
      var a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = title + '.md';
      a.click();
      return;
    }
    // [Editor] 保存草稿 — 收集所有表单字段
    if (target.id === 'btn-save-draft' || target.closest('btn-save-draft')) {
      var draftName = document.getElementById('draft-name-input').value || '未命名草稿';
      var getVal = function(id) { var el = document.getElementById(id); return el ? el.value : ''; };
      var getChecked = function(id) { var el = document.getElementById(id); return el ? el.checked : false; };
      var drafts = JSON.parse(localStorage.getItem('editor-drafts') || '[]');
      drafts.push({
        name: draftName,
        title: getVal('post-title'),
        content: document.getElementById('markdown-input').value,
        desc: getVal('post-desc'),
        category: getVal('post-category'),
        tags: getVal('post-tags'),
        cover: getVal('post-cover'),
        slug: getVal('post-slug'),
        password: getVal('post-password'),
        passwordHint: getVal('post-password-hint'),
        pinned: metaCheckboxState.pinned,
        comment: metaCheckboxState.comment,
        savedAt: new Date().toISOString()
      });
      localStorage.setItem('editor-drafts', JSON.stringify(drafts));
      document.getElementById('draft-name-input').value = '';
      renderDraftList();
      showToast('草稿已保存');
      return;
    }
    // 删除草稿（必须在加载草稿之前判断）
    if (target.classList.contains('draft-delete')) {
      e.stopPropagation();
      var idx = parseInt(target.dataset.index);
      var drafts = JSON.parse(localStorage.getItem('editor-drafts') || '[]');
      drafts.splice(idx, 1);
      localStorage.setItem('editor-drafts', JSON.stringify(drafts));
      renderDraftList();
      return;
    }
    // 加载草稿
    if (target.classList.contains('draft-item') || target.closest('.draft-item')) {
      var item = target.classList.contains('draft-item') ? target : target.closest('.draft-item');
      var idx = parseInt(item.dataset.index);
      var drafts = JSON.parse(localStorage.getItem('editor-drafts') || '[]');
      if (drafts[idx]) {
        var d = drafts[idx];
        var setVal = function(id, val) { var el = document.getElementById(id); if (el) el.value = val || ''; };
        var setChecked = function(id, val) { var el = document.getElementById(id); if (el) el.checked = !!val; };
        // 恢复所有表单字段
        setVal('post-title', d.title);
        setVal('post-desc', d.desc);
        setVal('post-category', d.category);
        setVal('post-tags', d.tags);
        setVal('post-cover', d.cover);
        setVal('post-slug', d.slug);
        setVal('post-password', d.password);
        setVal('post-password-hint', d.passwordHint);
        setChecked('chk-pinned', d.pinned);
        setChecked('chk-comment', d.comment);
        // 恢复编辑器内容
        document.getElementById('markdown-input').value = d.content || '';
        // 同步标题到面板内输入框（如果面板打开的话）
        var titleInput = document.getElementById('post-title-input');
        if (titleInput) titleInput.value = d.title || '';
        closePanel();
        showToast('草稿已加载');
      }
      return;
    }
  });

  // 标题同步（面板内输入 → 顶部标题）
  panelContent.addEventListener('input', function(e) {
    if (e.target.id === 'post-title-input') {
      document.getElementById('post-title').value = e.target.value;
    }
  });

  // [Editor] 删除封面图
  panelContent.addEventListener('click', function(e) {
    if (e.target.id === 'btn-remove-cover' || e.target.closest('#btn-remove-cover')) {
      var coverInput = document.getElementById('post-cover');
      if (coverInput) coverInput.value = '';
      var preview = document.getElementById('cover-preview');
      if (preview) preview.classList.add('hidden');
      var fileInput = document.getElementById('cover-upload');
      if (fileInput) fileInput.value = '';
    }
  });

  // [Editor] 封面图上传 — 通过事件委托处理（元素动态生成）
  panelContent.addEventListener('change', function(e) {
    if (e.target.id === 'cover-upload') {
      var file = e.target.files[0];
      if (!file) return;

      // 预览
      var reader = new FileReader();
      reader.onload = function(ev) {
        var preview = document.getElementById('cover-preview');
        var img = document.getElementById('cover-preview-img');
        if (img) img.src = ev.target.result;
        if (preview) preview.classList.remove('hidden');
      };
      reader.readAsDataURL(file);

      // 上传到 GitHub
      var token = localStorage.getItem('gh-token') || '';
      var repo = localStorage.getItem('gh-repo') || '';
      if (!token || !repo) {
        window.__editorShowToast('请先在发布弹窗中配置 GitHub Token 和仓库');
        return;
      }

      window.__editorShowToast('⏳ 封面图上传中...');
      var uploadReader = new FileReader();
      uploadReader.onload = function(ev2) {
        var base64 = ev2.target.result.split(',')[1];
        var ext = file.name.split('.').pop();
        var filename = Date.now() + '-' + Math.random().toString(36).slice(2, 8) + '.' + ext;

        fetch('https://api.github.com/repos/' + repo + '/contents/public/uploads/' + filename, {
          method: 'PUT',
          headers: {
            'Authorization': 'token ' + token,
            'Accept': 'application/vnd.github.v3+json',
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            message: 'upload cover: ' + filename,
            content: base64,
            branch: 'main',
          }),
        }).then(function(res) {
          if (!res.ok) return res.json().then(function(e) { throw new Error(e.message || '上传失败'); });
          return res.json();
        }).then(function() {
          var coverInput = document.getElementById('post-cover');
          if (coverInput) coverInput.value = '/uploads/' + filename;
          window.__editorShowToast('✅ 封面图上传成功');
        }).catch(function(err) {
          window.__editorShowToast('❌ 上传失败: ' + err.message);
        });
      };
      uploadReader.readAsDataURL(file);
    }
  });

  // 绑定所有 data-panel 按钮（图标栏 + 底部栏）
  document.querySelectorAll('[data-panel]').forEach(function(btn) {
    btn.addEventListener('click', function() { openPanel(this.dataset.panel); });
  });

  // 关闭按钮
  if (panelClose) panelClose.addEventListener('click', closePanel);

  // 侧边栏导出MD按钮
  var exportBtn = document.getElementById('btn-export-md');
  if (exportBtn) exportBtn.addEventListener('click', function() {
    var title = document.getElementById('post-title').value || 'untitled';
    var textarea = document.getElementById('markdown-input');
    var blob = new Blob([textarea.value], { type: 'text/markdown' });
    var a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = title + '.md';
    a.click();
  });

  // 底部保存草稿按钮
  // [Editor] 底部栏快速保存 — 收集所有表单字段
  var quickSaveBtn = document.getElementById('btn-quick-save');
  if (quickSaveBtn) quickSaveBtn.addEventListener('click', function() {
    var getVal = function(id) { var el = document.getElementById(id); return el ? el.value : ''; };
    var getChecked = function(id) { var el = document.getElementById(id); return el ? el.checked : false; };
    var title = document.getElementById('post-title').value;
    var textarea = document.getElementById('markdown-input');
    var drafts = JSON.parse(localStorage.getItem('editor-drafts') || '[]');
    drafts.push({
      name: title || '快速保存',
      title: title,
      content: textarea.value,
      desc: getVal('post-desc'),
      category: getVal('post-category'),
      tags: getVal('post-tags'),
      cover: getVal('post-cover'),
      slug: getVal('post-slug'),
      password: getVal('post-password'),
      passwordHint: getVal('post-password-hint'),
      pinned: getChecked('chk-pinned'),
      comment: getChecked('chk-comment'),
      savedAt: new Date().toISOString()
    });
    localStorage.setItem('editor-drafts', JSON.stringify(drafts));
    showToast('草稿已保存');
  });

  // 轻提示
  // [Editor] showToast 挂到 window 上供其他 IIFE 使用
  window.__editorShowToast = function(msg) {
    var toast = document.createElement('div');
    toast.textContent = msg;
    toast.style.cssText = 'position:fixed;bottom:60px;left:50%;transform:translateX(-50%);background:#333;color:#fff;padding:8px 20px;border-radius:8px;font-size:13px;z-index:9999;opacity:0;transition:opacity .3s;';
    document.body.appendChild(toast);
    requestAnimationFrame(function() { toast.style.opacity = '1'; });
    setTimeout(function() { toast.style.opacity = '0'; setTimeout(function() { toast.remove(); }, 300); }, 1500);
  };
  var showToast = window.__editorShowToast;

  // 底部发布按钮 → 直接打开 GitHub 弹窗
  var publishBtn = document.querySelector('[data-panel="publish"]');
  if (publishBtn) {
    publishBtn.removeAttribute('data-panel');
    publishBtn.addEventListener('click', function() {
      var modal = document.getElementById('github-modal');
      if (modal) modal.classList.remove('hidden');
    });
  }

  // GitHub 弹窗按钮
  var ghCancel = document.getElementById('gh-cancel');
  var ghConfirm = document.getElementById('gh-confirm');
  if (ghCancel) ghCancel.addEventListener('click', function() {
    var modal = document.getElementById('github-modal');
    if (modal) modal.classList.add('hidden');
  });
  if (ghConfirm) ghConfirm.addEventListener('click', function() {
    var token = document.getElementById('gh-token').value;
    var repo = document.getElementById('gh-repo').value;
    // [Editor] 保存到 localStorage 供封面图上传等功能使用
    if (token) localStorage.setItem('gh-token', token);
    if (repo) localStorage.setItem('gh-repo', repo);
    var branch = document.getElementById('gh-branch').value;
    var title = document.getElementById('post-title').value;
    var textarea = document.getElementById('markdown-input');
    var content = textarea.value;
    var status = document.getElementById('gh-status');

    if (!token || !title) {
      status.textContent = '❌ 请填写 Token 和标题';
      status.className = 'text-sm text-red-500';
      status.classList.remove('hidden');
      return;
    }

    status.textContent = '⏳ 发布中...';
    status.className = 'text-sm text-blue-500';
    status.classList.remove('hidden');

    // [Editor] 读取所有表单字段生成完整 frontmatter
    var getVal = function(id) { var el = document.getElementById(id); return el ? el.value : ''; };
    var desc = getVal('post-desc');
    var category = getVal('post-category');
    var tags = getVal('post-tags');
    var cover = getVal('post-cover');
    var password = getVal('post-password');
    var passwordHint = getVal('post-password-hint');
    // [Editor] checkbox 从追踪变量读取（面板关闭后 DOM 元素不存在）
    var pinned = metaCheckboxState.pinned;
    var comment = metaCheckboxState.comment;

    var slug = title.toLowerCase().replace(/[^a-z0-9\u4e00-\u9fff]+/g, '-').replace(/^-|-$/g, '');
    var filename = 'src/content/posts/' + slug + '.md';

    // 构建 frontmatter
    var fm = '---\n';
    fm += 'title: "' + title + '"\n';
    fm += 'published: ' + new Date().toISOString().split('T')[0] + '\n';
    fm += 'draft: false\n';
    if (desc) fm += 'description: "' + desc + '"\n';
    if (category) fm += 'category: "' + category + '"\n';
    if (tags) {
      var tagArr = tags.split(',').map(function(t) { return t.trim(); }).filter(Boolean);
      if (tagArr.length > 0) fm += 'tags: [' + tagArr.join(', ') + ']\n';
    }
    // [Editor] 跳过 base64 数据 URL（太长不适合 frontmatter，博客不支持）
    if (cover && cover.indexOf('data:') !== 0) fm += 'image: "' + cover + '"\n';
    if (password) fm += 'password: "' + password + '"\n';
    if (passwordHint) fm += 'passwordHint: "' + passwordHint + '"\n';
    if (pinned) fm += 'pinned: true\n';
    if (comment === false) fm += 'comment: false\n';
    fm += '---\n\n';

    var base64 = btoa(unescape(encodeURIComponent(fm + content)));
    var apiUrl = 'https://api.github.com/repos/' + repo + '/contents/' + filename;

    // [Editor] 先查询文件是否存在，获取 sha（更新已有文件时 GitHub 要求提供 sha）
    fetch(apiUrl + '?ref=' + branch, {
      headers: { 'Authorization': 'token ' + token, 'Accept': 'application/vnd.github.v3+json' },
    }).then(function(res) {
      if (res.status === 404) return null; // 新文件，无需 sha
      if (!res.ok) return res.json().then(function(e) { throw new Error(e.message); });
      return res.json();
    }).then(function(existing) {
      var body = {
        message: (existing ? 'update' : 'post') + ': "' + title + '"',
        content: base64,
        branch: branch,
      };
      if (existing && existing.sha) body.sha = existing.sha; // 更新时提供 sha
      return fetch(apiUrl, {
        method: 'PUT',
        headers: {
          'Authorization': 'token ' + token,
          'Accept': 'application/vnd.github.v3+json',
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(body),
      });
    }).then(function(res) {
      if (!res.ok) return res.json().then(function(e) { throw new Error(e.message || '发布失败'); });
      return res.json();
    }).then(function() {
      status.textContent = '✅ 发布成功！';
      status.className = 'text-sm text-green-500';
    }).catch(function(e) {
      status.textContent = '❌ ' + e.message;
      status.className = 'text-sm text-red-500';
    });
  });

  // 图片弹窗
  var imgModal = document.getElementById('image-modal');
  var imgCancel = document.getElementById('img-cancel');
  var imgConfirm = document.getElementById('img-confirm');
  var imgUrlInput = document.getElementById('img-url-input');
  var imgFileInput = document.getElementById('img-file-input');
  var imgPreview = document.getElementById('img-preview');
  var imgPreviewThumb = document.getElementById('img-preview-thumb');
  var imgStatus = document.getElementById('img-status');
  var pendingImgUrl = '';

  // 打开图片弹窗
  var imgToolBtn = document.querySelector('[data-action="image"]');
  if (imgToolBtn && imgModal) imgToolBtn.addEventListener('click', function() {
    imgModal.classList.remove('hidden');
    if (imgUrlInput) imgUrlInput.value = '';
    if (imgPreview) imgPreview.classList.add('hidden');
    if (imgStatus) { imgStatus.classList.add('hidden'); imgStatus.textContent = ''; }
    pendingImgUrl = '';
    setTimeout(function() { if (imgUrlInput) imgUrlInput.focus(); }, 100);
  });

  // 取消
  if (imgCancel && imgModal) imgCancel.addEventListener('click', function() {
    imgModal.classList.add('hidden');
  });

  // 本地文件选择 → 上传到 GitHub
  if (imgFileInput) imgFileInput.addEventListener('change', function(e) {
    var file = e.target.files[0];
    if (!file) return;

    // 预览
    var reader = new FileReader();
    reader.onload = function(ev) {
      if (imgPreviewThumb) imgPreviewThumb.src = ev.target.result;
      if (imgPreview) imgPreview.classList.remove('hidden');
    };
    reader.readAsDataURL(file);

    // 上传到 GitHub
    var token = localStorage.getItem('gh-token') || '';
    var repo = localStorage.getItem('gh-repo') || '';
    if (!token || !repo) {
      if (imgStatus) { imgStatus.textContent = '❌ 请先在发布弹窗中配置 GitHub Token 和仓库'; imgStatus.className = 'text-sm text-red-500'; imgStatus.classList.remove('hidden'); }
      return;
    }

    if (imgStatus) { imgStatus.textContent = '⏳ 上传中...'; imgStatus.className = 'text-sm text-blue-500'; imgStatus.classList.remove('hidden'); }

    var uploadReader = new FileReader();
    uploadReader.onload = function(ev2) {
      var base64 = ev2.target.result.split(',')[1];
      var ext = file.name.split('.').pop();
      var filename = Date.now() + '-' + Math.random().toString(36).slice(2, 8) + '.' + ext;

      fetch('https://api.github.com/repos/' + repo + '/contents/public/uploads/' + filename, {
        method: 'PUT',
        headers: {
          'Authorization': 'token ' + token,
          'Accept': 'application/vnd.github.v3+json',
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          message: 'upload: ' + filename,
          content: base64,
          branch: 'main',
        }),
      }).then(function(res) {
        if (!res.ok) return res.json().then(function(e) { throw new Error(e.message || '上传失败'); });
        return res.json();
      }).then(function() {
        pendingImgUrl = '/uploads/' + filename;
        if (imgUrlInput) imgUrlInput.value = pendingImgUrl;
        if (imgStatus) { imgStatus.textContent = '✅ 上传成功'; imgStatus.className = 'text-sm text-green-500'; }
      }).catch(function(err) {
        if (imgStatus) { imgStatus.textContent = '❌ ' + err.message; imgStatus.className = 'text-sm text-red-500'; }
      });
    };
    uploadReader.readAsDataURL(file);
  });

  // 确认插入
  if (imgConfirm && imgModal) imgConfirm.addEventListener('click', function() {
    var url = pendingImgUrl || (imgUrlInput ? imgUrlInput.value.trim() : '');
    if (!url) { imgUrlInput.focus(); return; }
    var textarea = document.getElementById('markdown-input');
    if (!textarea) return;
    var start = textarea.selectionStart;
    textarea.setRangeText('\n![' + '图片' + '](' + url + ')\n', start, start, 'end');
    textarea.focus();
    textarea.dispatchEvent(new Event('input'));
    // 重置
    if (imgUrlInput) imgUrlInput.value = '';
    if (imgPreview) imgPreview.classList.add('hidden');
    if (imgStatus) { imgStatus.classList.add('hidden'); imgStatus.textContent = ''; }
    pendingImgUrl = '';
    imgModal.classList.add('hidden');
  });

  // 回车确认
  if (imgUrlInput) imgUrlInput.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') { e.preventDefault(); if (imgConfirm) imgConfirm.click(); }
  });

  // 链接弹窗
  var linkModal = document.getElementById('link-modal');
  var linkCancel = document.getElementById('link-cancel');
  var linkConfirm = document.getElementById('link-confirm');
  var linkToolBtn = document.querySelector('[data-action="link"]');

  if (linkToolBtn && linkModal) linkToolBtn.addEventListener('click', function() { linkModal.classList.remove('hidden'); });
  if (linkCancel && linkModal) linkCancel.addEventListener('click', function() { linkModal.classList.add('hidden'); });
  if (linkConfirm && linkModal) linkConfirm.addEventListener('click', function() {
    var text = document.getElementById('link-text-input').value;
    var url = document.getElementById('link-url-input').value;
    if (url) {
      var textarea = document.getElementById('markdown-input');
      var start = textarea.selectionStart;
      textarea.setRangeText('[' + (text || '链接') + '](' + url + ')', start, start, 'end');
      textarea.focus();
      textarea.dispatchEvent(new Event('input'));
      linkModal.classList.add('hidden');
    }
  });

  // 初始化隐藏
  slidePanel.style.width = '0px';
})();
</script>

</MainGridLayout>
