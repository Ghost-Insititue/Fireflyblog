---
import { getLqipProps } from "@/utils/lqip-utils";

interface Props {
	src: string;
	albumId: string;
	alt?: string;
}

const { src, albumId, alt = "" } = Astro.props;

// LQIP 渐变占位
const lqipProps = getLqipProps(src, undefined, true);
---

<div class="gallery-photo-card break-inside-avoid mb-3">
  <div
    data-fancybox={`gallery-${albumId}`}
    data-src={src}
    data-type="image"
    class="block rounded-xl overflow-hidden relative group cursor-pointer"
  >
    <div class="lqip-placeholder absolute inset-0 pointer-events-none" style={lqipProps.style} aria-hidden="true"></div>
    <img
      src={src}
      alt={alt}
      loading="lazy"
      decoding="async"
      class="w-full h-auto object-cover opacity-0 transition-all duration-500 ease-out group-hover:scale-105"
    />
    <!-- 删除按钮（悬停显示） -->
    <button
      data-action="delete-photo"
      data-src={src}
      class="absolute top-2 right-2 p-1.5 rounded-lg bg-red-500/80 hover:bg-red-500 text-white opacity-0 group-hover:opacity-100 transition-all cursor-pointer backdrop-blur-sm"
      title="删除照片"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
    </button>
  </div>
</div>
